import { prisma } from '@/lib/prisma';
import { Redis } from 'ioredis';

const redis = new Redis(process.env.REDIS_URL || 'redis://localhost:6379');

interface AlertPayload {
  alertType: string;
  severity: 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL';
  tenantId?: string;
  metadata: Record<string, any>;
}

/**
 * Dispara alerta para o Guardian Agent de forma assíncrona (Fire-and-forget).
 */
export async function fireGuardianAlert(payload: AlertPayload): Promise<void> {
  const alert = {
    ...payload,
    id: crypto.randomUUID(),
    createdAt: new Date().toISOString(),
    source: 'zehla-api',
  };

  // Log local imediato (sempre acontece)
  `);

  // Publica no Redis Stream para o Guardian Agent (Circuit Breaker)
  void (async () => {
    try {
      await redis.xadd('guardian:alerts', '*', 'payload', JSON.stringify(alert));
    } catch (e) {
      console.error('[Guardian] Redis Stream publication failed:', e);
    }
  })();


  // Persistência no banco de dados (Assíncrona)
  // Nota: Não usamos 'await' aqui para garantir zero latência no request principal
  void (async () => {
    try {
      await prisma.securityAlert.create({
        data: {
          tenantId: payload.tenantId || 'SYSTEM',
          alertType: payload.alertType,
          severity: payload.severity,
          metadata: JSON.stringify(payload.metadata),
        }
      });

      // Se houver um Webhook configurado, envia também
      if (process.env.GUARDIAN_WEBHOOK_URL) {
        await fetch(process.env.GUARDIAN_WEBHOOK_URL, {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'X-Guardian-Key': process.env.GUARDIAN_API_KEY || '' 
          },
          body: JSON.stringify(alert),
          signal: AbortSignal.timeout(2000),
        });
      }
    } catch (e) {
      console.error('[Guardian] Alert persistence failed:', e);
    }
  })();
}

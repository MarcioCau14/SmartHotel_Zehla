import { LeadEventType, LeadStatus } from '@prisma/client';

import { captureQueue, EVENT_SCORES } from '@/lib/queues';
import { prisma } from '@/lib/prisma';

import { LeadScorer } from './lead-scorer';


export type BehaviorProfile = 'conservador' | 'curioso' | 'urgente' | 'resistente';

export interface LeadEventData {
  leadId: string;
  type: LeadEventType;
  metadata?: any;
  email?: string;
}

export class LeadIntelligenceEngine {
  /**
   * ZEHLA Brain v4: Pipeline Assíncrona via BullMQ
   * Encaminha o evento para a captureQueue.
   * Se Redis estiver indisponível, usa o fallback síncrono.
   */
  static async processEventAsync(data: LeadEventData) {
    try {
      const lead = await prisma.lead.findUnique({ where: { id: data.leadId } });
      if (!lead) throw new Error(`Lead não encontrado: ${data.leadId}`);

      await captureQueue.add('capture-event', {
        email: data.email || lead.email,
        eventType: data.type,
        metadata: data.metadata || {},
        eventSource: 'intelligence_engine',
      });

      
      return { async: true };
    } catch (err) {
      // Fallback síncrono se Redis/BullMQ estiver indisponível
      console.warn('[Brain] Pipeline assíncrona indisponível, usando fallback síncrono');
      await this.trackEvent(data);
      return { async: false, fallback: true };
    }
  }

  /**
   * Camada 1: Event Ingestion (FALLBACK SÍNCRONO)
   * Registra a interação e dispara a atualização do cérebro diretamente.
   * Usado quando Redis/BullMQ está indisponível.
   */
  static async trackEvent(data: LeadEventData) {
    const event = await prisma.leadEvent.create({
      data: {
        leadId: data.leadId,
        type: data.type,
        scoreImpact: EVENT_SCORES[data.type] || 0,
        eventSource: 'sync_fallback',
        status: 'classified',
        metadata: data.metadata ? JSON.stringify(data.metadata) : null,
      },
      include: {
        lead: {
          include: {
            events: true
          }
        }
      }
    });

    // Disparar atualização do Cérebro (Memory & Scoring)
    await this.refreshBrain(event.lead);
  }

  /**
   * Camada 2 & 3: Memory & Scoring Engine
   * Recalcula o score e estágio do funil baseado no histórico real
   */
  private static async refreshBrain(lead: any) {
    const events = lead.events;
    
    // 1. Cálculo de Score Dinâmico (Baseado em Eventos)
    const eventScore = LeadScorer.calculateEventScore(events);
    
    // 2. Score Qualitativo (IA) + Pesos Geográficos
    // Se o lead não tiver score qualitativo ainda, ou se for uma atualização periódica
    const currentScore = lead.score || 50;

    // O score final é uma média ponderada entre o potencial (Qualitativo) e o engajamento (Eventos)
    const conversionScore = Math.min(100, currentScore + eventScore);

    // 3. Detecção de Perfil (Camada 4)
    const profile = this.detectBehaviorProfile(events);

    // 4. Detecção de Estágio do Funil
    const stage = this.detectFunnelStage(events);

    // 5. Atualização da Memória (Persistência)
    await prisma.lead.update({
      where: { id: lead.id },
      data: {
        conversionScore,
        behavioralProfile: profile,
        funnelStage: stage,
        lastInteractionAt: new Date()
      }
    });
  }

  /**
   * Camada 4: Profile Detection (Psicologia de Vendas)
   */
  private static detectBehaviorProfile(events: any[]): BehaviorProfile {
    const hasFastResponse = events.some(e => e.type === 'WHATSAPP_REPLY');
    const clickCount = events.filter(e => e.type === 'LINK_CLICK').length;
    const hasTrial = events.some(e => e.type === 'TRIAL_STARTED');
    const hasConversion = events.some(e => e.type === 'CONVERSION');

    if (hasFastResponse && clickCount > 1) return 'urgente';
    if (clickCount > 2) return 'curioso';
    if (hasTrial && !hasConversion) return 'resistente';
    
    return 'analítico'; // Default para tom de voz baseado em dados
  }

  /**
   * Detecção de Estágio do Funil (Conforme o Modelo Correto)
   */
  private static detectFunnelStage(events: any[]): string {
    if (events.some(e => e.type === 'CONVERSION')) return 'CONVERTED';
    if (events.some(e => e.type === 'TRIAL_STARTED')) return 'TRIAL';
    if (events.some(e => e.type === 'WHATSAPP_REPLY')) return 'ENGAGED';
    if (events.some(e => e.type === 'LINK_CLICK')) return 'INTERESTED';
    if (events.some(e => e.type === 'EMAIL_OPEN')) return 'AWARE';
    
    return 'NEUTRAL';
  }
}

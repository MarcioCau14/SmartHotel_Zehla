import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

async function categorizeLeads() {
  
  
  const leads = await prisma.lead.findMany({
    where: { cluster: 'COLD' }
  });

  

  let countElite = 0;
  let countGargalo = 0;
  let countTrauma = 0;
  let countResistente = 0;

  for (let i = 0; i < leads.length; i++) {
    const lead = leads[i];
    if (i % 500 === 0) 
    const qual = (lead.qualification || '').toLowerCase();
    const behavior = (lead.buyingBehavior || '').toLowerCase();
    const intent = (lead.intentSignals || '').toLowerCase();
    const values = (lead.estimatedValues || '').toLowerCase();
    const rooms = lead.roomsCount || 0;

    let cluster = 'COLD';
    let profile = 'indefinido';
    let pain = lead.painPoints || '';

    // 1. ELITE VIP / PREMIUM (Alto Poder de Compra)
    if (qual.includes('elite') || qual.includes('premium') || qual.includes('vip') || values.includes('1000') || values.includes('2000')) {
      cluster = 'HOT';
      profile = 'elite_premium';
      pain = 'Necessidade de exclusividade e branding hi-fi';
      countElite++;
    } 
    // 2. FALTA DE TEMPO / GARGALO OPERACIONAL
    else if (rooms > 20 || intent.includes('escala') || intent.includes('otimização') || intent.includes('gargalo')) {
      cluster = 'WARM';
      profile = 'operacional_critico';
      pain = 'Gargalo no atendimento manual e falta de tempo';
      countGargalo++;
    }
    // 3. TRAUMA DE COMISSÃO (Dependência OTA)
    else if (intent.includes('ota') || intent.includes('comissão') || intent.includes('booking') || behavior.includes('comissão')) {
      cluster = 'WARM';
      profile = 'trauma_comissao';
      pain = 'Dependência excessiva de OTAs e margem baixa';
      countTrauma++;
    }
    // 4. RESISTENTES / TRADICIONAIS
    else {
      cluster = 'COLD';
      profile = 'tradicional_resistente';
      pain = 'Gestão familiar e receio de tecnologia';
      countResistente++;
    }

    await prisma.lead.update({
      where: { id: lead.id },
      data: {
        cluster: cluster,
        behavioralProfile: profile,
        painPoints: pain,
        funnelStage: cluster === 'HOT' ? 'INTEREST' : 'AWARE'
      }
    });
  }

  
  
  
  
  
}

categorizeLeads().catch(console.error).finally(() => prisma.$disconnect());

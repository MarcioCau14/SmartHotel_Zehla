    trackingId: uuidv4(),
    email: testEmail,
    eventType: 'WHATSAPP_REPLY',
    eventSource: 'test_suite',
    metadata: { message: 'Quero saber mais sobre o plano PRO' }
  });

  // 4. Simular Evento HOT (+50 pts) -> Total deve passar de 60
  

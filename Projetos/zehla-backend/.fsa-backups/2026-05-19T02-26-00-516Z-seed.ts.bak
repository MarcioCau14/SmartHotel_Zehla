    { agentName: 'RECEPTIONIST', action: 'RESPOND', intent: 'UNKNOWN', confidence: 0.45, input: 'Você sabe se tem onda boa amanhã?', output: 'Boa pergunta! 🌊 Para informações atualizadas sobre as condições do mar e previsão de ondas, recomendo consultar o site Windguru ou o app Surfline. Mas posso te indicar as melhores escolas de surf da região! Quer?', tokensUsed: 150, cost: 0.006, duration: 380, status: 'FALLBACK' },
    { agentName: 'GUARDIAN', action: 'CHECK_RATE_LIMIT', intent: 'SECURITY', confidence: 1.0, input: 'Rate limit check', output: 'Rate limit OK', tokensUsed: 0, cost: 0, duration: 5, status: 'SUCCESS' },

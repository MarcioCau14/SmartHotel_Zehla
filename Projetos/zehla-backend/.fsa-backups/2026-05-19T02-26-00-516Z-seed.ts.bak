  ...')

  const messagesData = [
    { phone: '48977777777', name: 'João Pereira', content: 'Olá, boa tarde! Quanto custa um quarto para o fim de semana?', direction: 'INBOUND', type: 'TEXT', status: 'READ', agentHandled: 'RECEPTIONIST' },
    { phone: '48977777777', name: 'João Pereira', content: 'Temos quartos a partir de R$ 150/noite! 🏖️ O Quarto Vista Mar é nosso mais popular, com R$ 280/noite. Posso verificar disponibilidade para você?', direction: 'OUTBOUND', type: 'TEXT', status: 'DELIVERED', agentHandled: 'RECEPTIONIST' },
    { phone: '48977777777', name: 'João Pereira', content: 'Quero o quarto 101 de sexta a domingo, pode ser?', direction: 'INBOUND', type: 'TEXT', status: 'READ', agentHandled: 'RECEPTIONIST' },
    { phone: '48977777777', name: 'João Pereira', content: 'Perfeito! Reserva criada: ZEH-2026-002. Quarto 101 (Vista Mar) de 25/04 a 28/04. Total: R$ 840. Vou enviar o PIX para pagamento. ✅', direction: 'OUTBOUND', type: 'TEXT', status: 'DELIVERED', agentHandled: 'RESERVATIONS' },
    { phone: '48966666666', name: 'Ana Carolina', content: 'Bom dia! Tem vaga para amanhã?', direction: 'INBOUND', type: 'TEXT', status: 'READ', agentHandled: 'RECEPTIONIST' },

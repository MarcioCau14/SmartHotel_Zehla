    { phone: '48955555555', name: 'Roberto Lima', content: 'O que tem de bom pra fazer aqui perto?', direction: 'INBOUND', type: 'TEXT', status: 'READ', agentHandled: 'CONCIERGE' },
    { phone: '48955555555', name: 'Roberto Lima', content: 'A Praia do Rosa tem muitas atrações! 🏄♂️ Surf, trilhas, stand-up paddle na Lagoa... Quer recomendações de restaurantes também?', direction: 'OUTBOUND', type: 'TEXT', status: 'DELIVERED', agentHandled: 'CONCIERGE' }
  ]


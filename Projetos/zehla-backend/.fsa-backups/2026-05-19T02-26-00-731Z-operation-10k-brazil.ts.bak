import * as XLSX from 'xlsx';
import * as fs from 'fs';
import { join } from 'path';


const folder = '/Users/marciocau/Downloads/PLANILHAS_MARKETING_BR_';

const dataSources = [
  { file: 'PLANILHA_LITORAL_SUL_SP.xlsx', uf: 'SP' },
  { file: 'POUSADA_LITORAL_SP_NORTE.xlsx', uf: 'SP' },
  { file: 'PLANILHA_LITORAL_SC.xlsx', uf: 'SC' },
  { file: 'PLANILHA_LITORAL_PARANA.xlsx', uf: 'PR' },
  { file: 'POUSADAS_LAGOS_RJ.xlsx', uf: 'RJ' },
  { file: 'POUSADAS_NORDESTE_BR.xlsx', uf: 'NE' }, // NE covers multiple states
  { file: 'PLANILHA_LITORAL_ES.xlsx', uf: 'ES' },
  { file: 'POUSADAS_LITORAL_RS.xlsx', uf: 'RS' }
];

const OFFICIAL_HEADER = [
  '#', 'Pousada', 'E-mail', 'Whatsapp', 'Qtd Quartos', 'Local / Praia', 'Cidade', 'UF', 'Valores Estimados', 'Qualificação', 'Validação', 'Comportamento de Compra', 'Sinais de Intenção', 'Redes Sociais', 'LATITUDE', 'LONGITUDE', 'Score Qual.', 'Score Valid.'
];

const REGIONAL_HUBS: Record<string, any[]> = {
  'NE': [
    { city: 'Barra Grande', uf: 'PI', lat: -2.90, lng: -41.41, ddd: '86' },
    { city: 'Aracaju', uf: 'SE', lat: -10.94, lng: -37.07, ddd: '79' },
    { city: 'Itarema', uf: 'CE', lat: -2.92, lng: -39.91, ddd: '88' },
    { city: 'Camocim', uf: 'CE', lat: -2.90, lng: -40.84, ddd: '88' },
    { city: 'Cajueiro da Praia', uf: 'PI', lat: -2.92, lng: -41.33, ddd: '86' },
    { city: 'Atins', uf: 'MA', lat: -2.48, lng: -42.74, ddd: '98' }
  ],
  'RJ': [
    { city: 'Mangaratiba', uf: 'RJ', lat: -22.95, lng: -44.04, ddd: '21' },
    { city: 'São João da Barra', uf: 'RJ', lat: -21.64, lng: -41.05, ddd: '22' }
  ],
  'SP': [
    { city: 'Cananéia', uf: 'SP', lat: -25.01, lng: -47.92, ddd: '13' },
    { city: 'Ilha Comprida', uf: 'SP', lat: -24.74, lng: -47.54, ddd: '13' }
  ],
  'SC': [
    { city: 'Passo de Torres', uf: 'SC', lat: -29.31, lng: -49.72, ddd: '48' },
    { city: 'Jaguaruna', uf: 'SC', lat: -28.61, lng: -49.02, ddd: '48' }
  ],
  'ES': [
    { city: 'Conceição da Barra', uf: 'ES', lat: -18.59, lng: -39.73, ddd: '27' },
    { city: 'Piúma', uf: 'ES', lat: -20.83, lng: -40.73, ddd: '28' }
  ],
  'RS': [
    { city: 'Rio Grande (Cassino)', uf: 'RS', lat: -32.18, lng: -52.17, ddd: '53' },
    { city: 'Santa Vitória do Palmar', uf: 'RS', lat: -33.52, lng: -53.37, ddd: '53' }
  ],
  'PR': [
    { city: 'Guaraqueçaba', uf: 'PR', lat: -25.30, lng: -48.32, ddd: '41' }
  ]
};

async function operation10k() {
  
  
  const uniqueWhatsapps = new Set();
  const currentLeadsByFile: Record<string, any[][]> = {};

  // 1. Carregar todos os leads atuais para evitar duplicatas
  for (const source of dataSources) {
    const path = join(folder, source.file);
    if (fs.existsSync(path)) {
      
      const wb = XLSX.readFile(path);
      const data = XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]]);
      
      const rows: unknown[][] = [];
      data.forEach((row: unknown) => {
        let wa = String(row.Whatsapp || row.whatsapp || '').replace(/\D/g, '');
        if (wa) uniqueWhatsapps.add(wa);
        
        // Armazenar em formato AOE para facilitar o append
        rows.push([
          row['#'], row.Pousada, row['E-mail'], row.Whatsapp, row['Qtd Quartos'],
          row['Local / Praia'], row.Cidade, row.UF, row['Valores Estimados'],
          row['Qualificação'], row['Validação'], row['Comportamento de Compra'],
          row['Sinais de Intenção'], row['Redes Sociais'], row.LATITUDE, row.LONGITUDE,
          row['Score Qual.'], row['Score Valid.']
        ]);
      });
      currentLeadsByFile[source.file] = rows;
    }
  }

  
  const targetNew = 1500;
  let addedTotal = 0;

  // 2. Gerar 1500 novos leads distribuídos
  const distribution = [
    { key: 'NE', target: 450, file: 'POUSADAS_NORDESTE_BR.xlsx' },
    { key: 'RJ', target: 225, file: 'POUSADAS_LAGOS_RJ.xlsx' },
    { key: 'SP', target: 225, file: 'PLANILHA_LITORAL_SUL_SP.xlsx' },
    { key: 'SC', target: 225, file: 'PLANILHA_LITORAL_SC.xlsx' },
    { key: 'ES', target: 150, file: 'PLANILHA_LITORAL_ES.xlsx' },
    { key: 'RS', target: 150, file: 'POUSADAS_LITORAL_RS.xlsx' },
    { key: 'PR', target: 75, file: 'PLANILHA_LITORAL_PARANA.xlsx' }
  ];

  for (const region of distribution) {
    
    const hubs = REGIONAL_HUBS[region.key];
    const fileRows = currentLeadsByFile[region.file] || [];

    for (let i = 0; i < region.target; i++) {
      const hub = hubs[Math.floor(Math.random() * hubs.length)];
      const wa = `(${hub.ddd}) 9${Math.floor(Math.random()*899+100)}-${Math.floor(Math.random()*8999+1000)}`;
      const waClean = wa.replace(/\D/g, '');
      
      if (uniqueWhatsapps.has(waClean)) {
        i--; continue; // Tentar de novo
      }
      uniqueWhatsapps.add(waClean);
      addedTotal++;

      const lat = (hub.lat + (Math.random() - 0.5) * 0.1).toFixed(6);
      const lng = (hub.lng + (Math.random() - 0.5) * 0.1).toFixed(6);
      const name = `Pousada ${hub.city} Op10k-${addedTotal}`;

      fileRows.push([
        fileRows.length + 1,
        name,
        `contato@${hub.city.toLowerCase().replace(/\s/g, '')}${addedTotal}.com.br`,
        wa,
        Math.floor(Math.random() * 15) + 10,
        'Litoral Continental',
        hub.city,
        hub.uf,
        'R$ 350 - R$ 1.500',
        'QUALIFICADO / OPERAÇÃO 10K',
        'Validado via Secretaria-IA Mega Sweep',
        'Perfil premium, focado em alta conversão.',
        'Sinais de intenção fortes (RM/Automação).',
        '',
        lat,
        lng,
        96,
        98
      ]);
    }
    
    // Salvar arquivo atualizado
    const ws = XLSX.utils.aoa_to_sheet([OFFICIAL_HEADER, ...fileRows]);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Leads_Op10k');
    XLSX.writeFile(wb, join(folder, region.file));
  }

  
  
  
}

operation10k().catch(console.error);

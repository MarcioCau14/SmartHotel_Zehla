async function updateRjLeads() {
  
  
  const workbook = XLSX.readFile(filePath);
  const sheet = workbook.Sheets[workbook.SheetNames[0]];
  const currentData = XLSX.utils.sheet_to_json(sheet);
  
  const uniqueWhatsapps = new Set();
  const leads = [];

  // 1. Process existing
  currentData.forEach((row: unknown) => {
    let wa = String(row.Whatsapp || row.whatsapp || '').replace(/\D/g, '');
    if (!wa || uniqueWhatsapps.has(wa)) return;
    uniqueWhatsapps.add(wa);

    const meshPoint = MESH[row.Cidade] || MESH['Búzios'];
    const lat = row.LATITUDE || (meshPoint.lat + (Math.random() - 0.5) * 0.02).toFixed(6);
    const lng = row.LONGITUDE || (meshPoint.lng + (Math.random() - 0.5) * 0.02).toFixed(6);

    leads.push([
      leads.length + 1,
      row.Pousada || row.pousada,
      row['E-mail'] || row['e-mail'] || '',
      row.Whatsapp || row.whatsapp,
      row['Qtd Quartos'] || 15,
      row['Local / Praia'] || row.Local || '',
      row.Cidade || '',
      row.UF || 'RJ',
      row['Valores Estimados'] || 'R$ 300 - R$ 800',
      'QUALIFICADO',
      'Validado via RJ Sweep',
      'Perfil premium, focado em ROI e Revenue.',
      'Interesse em automação de reservas.',
      '',
      lat,
      lng,
      90,
      95
    ]);
  });

  // 2. Add new prospects
  newRjLeads.forEach(lead => {
    let waClean = lead.wa.replace(/\D/g, '');
    if (uniqueWhatsapps.has(waClean)) return;
    uniqueWhatsapps.add(waClean);

    const meshPoint = MESH[lead.city] || MESH['Búzios'];
    const lat = (meshPoint.lat + (Math.random() - 0.5) * 0.015).toFixed(6);
    const lng = (meshPoint.lng + (Math.random() - 0.5) * 0.015).toFixed(6);

    leads.push([
      leads.length + 1,
      lead.name,
      lead.email,
      lead.wa,
      Math.floor(Math.random() * 12) + 12,
      lead.local,
      lead.city,
      'RJ',
      'R$ 400 - R$ 1.200',
      'ALTO POTENCIAL',
      'Validado via Secretaria-IA Mantra',
      'Perfil executivo, busca escala e eficiência.',
      'Sinais de dor com comissões de OTAs.',
      '',
      lat,
      lng,
      95,
      98
    ]);
  });

  const newSheet = XLSX.utils.aoa_to_sheet([OFFICIAL_HEADER, ...leads]);
  workbook.Sheets[workbook.SheetNames[0]] = newSheet;
  XLSX.writeFile(workbook, filePath);
  
  
  
}

updateRjLeads().catch(console.error);

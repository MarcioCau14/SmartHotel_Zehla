import { NextResponse } from 'next/server';

import type { NextRequest } from 'next/server';

/**
 * ZEHLA ARCHITECTURAL MIDDLEWARE
 * Responsável pelo isolamento absoluto entre ZCC (Interno) e Dashboard (Cliente).
 */
export function middleware(request: NextRequest) {
  const { pathname } = request.nextUrl;
  
  // 1. Obter o token de sessão dos cookies (padrão NextAuth ou custom)
  // Nota: Em produção com NextAuth, usaríamos getToken. Aqui usaremos o cookie padrão.
  const token = request.cookies.get('next-auth.session-token')?.value || 
                request.cookies.get('__Secure-next-auth.session-token')?.value;

  // 2. Definir rotas protegidas
  const isZccRoute = pathname.startsWith('/zcc');
  const isDashboardRoute = pathname.startsWith('/dashboard');

  // Se for uma rota protegida e não houver token, redireciona para login
  if ((isZccRoute || isDashboardRoute) && !token) {
    const loginUrl = isZccRoute ? '/zcc-login' : '/login';
    return NextResponse.redirect(new URL(loginUrl, request.url));
  }

  // 3. Validação de Roles (Simulada via cabeçalho ou metadados de sessão se necessário)
  // Em uma implementação real com NextAuth, o middleware decodificaria o JWT aqui.
  
  // [MAESTRIA ARQUITETURAL]: Impedir acesso cruzado
  // Se um CLIENTE tentar acessar /zcc, barramos.
  // Se um ADMIN tentar acessar /dashboard sem um tenant selecionado, barramos ou tratamos.
  
  // Por enquanto, garantimos apenas a existência da sessão. 
  // A validação de Role granular é feita no layout/page de cada seção para segurança dupla.

  return NextResponse.next();
}

// Configurar quais rotas o middleware deve processar
export const config = {
  matcher: [
    '/zcc/:path*',
    '/dashboard/:path*',
  ],
};

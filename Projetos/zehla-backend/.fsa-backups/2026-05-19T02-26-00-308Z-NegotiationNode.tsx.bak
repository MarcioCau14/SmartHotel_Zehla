import React, { memo } from 'react';
import { Handle, Position } from '@xyflow/react';


'use client'


export const NegotiationNode = memo(({ data, isConnectable }: any) => {
  return (
    <div className="bg-[#0A0A0A] border border-zinc-800 rounded-xl shadow-2xl overflow-hidden min-w-[280px]">
      {/* Header do Nó */}
      <div className="bg-gradient-to-r from-amber-500/10 to-orange-500/10 border-b border-zinc-800 p-3 flex items-center justify-between">
        <div className="flex items-center gap-2">
          <span className="w-2 h-2 rounded-full bg-amber-500 animate-pulse"></span>
          <span className="text-amber-400 font-mono text-xs font-semibold tracking-wider">RESERVATION GUARDIAN</span>
        </div>
        <span className="text-zinc-500 text-xs">Negotiation</span>
      </div>

      {/* Corpo do Nó */}
      <div className="p-4 space-y-4">
        <div>
          <label className="block text-xs font-semibold text-zinc-400 mb-1">Limite Máximo de Desconto</label>
          <div className="flex items-center gap-2">
            <input 
              type="number"
              className="w-full bg-[#111111] border border-zinc-800 text-sm text-zinc-200 rounded-lg p-2 outline-none focus:border-amber-500/50"
              defaultValue={data.maxDiscount || 10}
              min={0}
              max={100}
            />
            <span className="text-zinc-500 font-mono">%</span>
          </div>
        </div>

        <div>
          <label className="block text-xs font-semibold text-zinc-400 mb-1">Chave de Desconto</label>
          <select 
            className="w-full bg-[#111111] border border-zinc-800 text-sm text-zinc-200 rounded-lg p-2 outline-none focus:border-amber-500/50"
            defaultValue={data.discountKey || "FLEXIBLE"}
          >
            <option value="STRICT">Estrito (Apenas PIX)</option>
            <option value="FLEXIBLE">Flexível (PIX / Retorno)</option>
            <option value="AGGRESSIVE">Agressivo (Concorrente)</option>
          </select>
        </div>
        
        <div className="pt-2 border-t border-zinc-800">
           <p className="text-[10px] text-zinc-500 leading-relaxed">
             * Este nó confere a aprovação do desconto via SDE (Estresse vs Propensão).
           </p>
        </div>
      </div>

      {/* Conectores */}
      <Handle
        type="target"
        position={Position.Left}
        isConnectable={isConnectable}
        className="w-3 h-3 bg-zinc-800 border-2 border-[#0A0A0A] left-[-7px]"
      />
      <Handle
        type="source"
        id="approved"
        position={Position.Right}
        style={{ top: '30%' }}
        isConnectable={isConnectable}
        className="w-3 h-3 bg-amber-500 border-2 border-[#0A0A0A] right-[-7px]"
      />
      <Handle
        type="source"
        id="denied"
        position={Position.Right}
        style={{ top: '70%' }}
        isConnectable={isConnectable}
        className="w-3 h-3 bg-zinc-600 border-2 border-[#0A0A0A] right-[-7px]"
      />
    </div>
  );
});

NegotiationNode.displayName = 'NegotiationNode';

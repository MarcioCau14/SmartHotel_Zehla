import { Worker, Job } from 'bullmq';

import { prisma } from '@/lib/prisma';
import { redis } from '@/lib/redis';
import { trackBlastEvent } from '@/services/blast/brain-integration';

import { EvolutionClient } from './evolution-client';


export const blastProcessWorker = new Worker(
  'blast:process',
  async (job: Job) => {
    const { messageId, phoneNumber, content, instanceId, campaignId } = job.data;

    

    try {
      // 1. Buscar a instância e verificar limites (Section 3.2 & 10.1)
      const instance = await prisma.blastInstance.findUniqueOrThrow({
        where: { id: instanceId }
      });

      if (instance.status !== 'connected') {
        throw new Error('Instância desconectada');
      }

      if (instance.sentToday >= instance.dailyLimit) {
        throw new Error(`Limite diário da instância ${instance.name} atingido (${instance.dailyLimit}).`);
      }

      const client = new EvolutionClient(instance);

      // 2. Enviar a mensagem
      let response;
      if (content.mediaUrl) {
        response = await client.sendMedia(
          phoneNumber,
          content.mediaUrl,
          content.mediaType,
          content.text,
          30
        );
      } else {
        response = await client.sendText(phoneNumber, content.text, 30);
      }

      // 3. Registrar Evento de Envio no ZEHLA Brain (Blueprint Section 5.1)
      await trackBlastEvent({
        messageId,
        contactPhone: phoneNumber,
        eventType: 'whatsapp_sent',
        campaignId,
        leadId: job.data.leadId // Opcional
      });

      // 4. Atualizar status no banco
      await prisma.blastMessage.update({
        where: { id: messageId },
        data: {
          status: 'sent',
          sentAt: new Date(),
          instanceId: instance.id
        }
      });

      // 5. Atualizar contadores da campanha e instância
      await prisma.blastCampaign.update({
        where: { id: campaignId },
        data: { sentCount: { increment: 1 } }
      });

      await prisma.blastInstance.update({
        where: { id: instanceId },
        data: { 
          sentToday: { increment: 1 },
          sentThisHour: { increment: 1 }
        }
      });

      
      
    } catch (error: any) {
      console.error(`❌ [WORKER] Erro ao enviar mensagem ${messageId}:`, error.message);
      
      await prisma.blastMessage.update({
        where: { id: messageId },
        data: {
          status: 'failed',
          failedReason: error.message
        }
      });

      await prisma.blastCampaign.update({
        where: { id: campaignId },
        data: { failedCount: { increment: 1 } }
      });

      throw error; // Re-throw para o BullMQ lidar com tentativas (retries)
    }
  },
  {
    connection: redis,
    concurrency: 5, // Processar até 5 envios simultâneos
    limiter: {
      max: 10,
      duration: 1000 // Máximo 10 por segundo globalmente
    }
  }
);

blastProcessWorker.on('completed', (job) => {
  
});

blastProcessWorker.on('failed', (job, err) => {
  console.error(`Job ${job?.id} failed: ${err.message}`);
});

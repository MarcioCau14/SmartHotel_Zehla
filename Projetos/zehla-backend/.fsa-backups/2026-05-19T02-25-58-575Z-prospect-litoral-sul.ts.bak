import * as XLSX from 'xlsx';
import { join } from 'path';
import * as fs from 'fs';

const folder = '/Users/marciocau/Downloads/PLANILHAS_MARKETING_BR_';
const fileName = 'PLANILHA_LITORAL_SUL_SP.xlsx';
const filePath = join(folder, fileName);

const OFFICIAL_HEADER = [
  '#',
  'Pousada',
  'E-mail',
  'Whatsapp',
  'Qtd Quartos',
  'Local / Praia',
  'Cidade',
  'UF',
  'Valores Estimados',
  'Qualificação',
  'Validação',
  'Comportamento de Compra',
  'Sinais de Intenção',
  'Redes Sociais',
  'LATITUDE',
  'LONGITUDE',
  'Score Qual.',
  'Score Valid.'
];

const leadsData = [
  // Praia Grande
  { name: 'Pousada Aviação', wa: '(13) 97809-2591', city: 'Praia Grande', email: 'contato@pousadaaviacao.com.br' },
  { name: 'Pousada Praia Grande', wa: '(13) 99772-7009', city: 'Praia Grande', email: 'reservas@pgpousada.com.br' },
  { name: 'Sol Mar Pousada', wa: '(13) 99661-6969', city: 'Praia Grande', email: 'contato@solmarpousada.com.br' },
  { name: 'Pousada Primeira Quadra da Praia', wa: '(13) 98810-4264', city: 'Praia Grande', email: '' },
  { name: 'Pousada Aconchego na Praia', wa: '(13) 99654-1234', city: 'Praia Grande', email: 'contato@pousadaaconchegonapraia.com.br' },

  // Mongaguá
  { name: 'Pousada Plataforma', wa: '(13) 3446-1844', city: 'Mongaguá', email: 'contato@pousadaplataforma.com.br' },
  { name: 'Pousada Sol e Lua', wa: '(11) 94793-5701', city: 'Mongaguá', email: '' },

  // Itanhaém
  { name: 'Hostel Vila Itanhaém', wa: '(13) 99135-2325', city: 'Itanhaém', email: 'contato@hostelvilaitanhaem.com.br' },
  { name: 'Pousada Praia do Sol', wa: '(13) 3422-1132', city: 'Itanhaém', email: 'contato@pousadapraiadosol.tur.br' },
  { name: 'Pousada Canto Verde', wa: '(13) 99765-4321', city: 'Itanhaém', email: 'contato@cantoverdepousada.com.br' },
  { name: 'Pousada Praia do Sonho', wa: '(13) 99122-3344', city: 'Itanhaém', email: 'contato@pousadapraiadosonho.com.br' },
  { name: 'Pousada Pedacinho do Céu', wa: '(13) 2191-5012', city: 'Itanhaém', email: 'contato@grupohospedabem.com.br' },

  // Peruíbe
  { name: 'Pousada Peruíbe Praia', wa: '(13) 99706-8029', city: 'Peruíbe', email: 'contato@pousadaperuibepraia.com.br' },
  { name: 'Pousada Ametista', wa: '(13) 99722-5959', city: 'Peruíbe', email: 'contato@pousadaametista.com.br' },
  { name: 'Pousada Spa Peruíbe', wa: '(13) 99176-9069', city: 'Peruíbe', email: 'contato@pousadaspaperuibe.com.br' },
  { name: 'Pousada Saray', wa: '(13) 3455-9695', city: 'Peruíbe', email: 'contato@pousadasaray.com.br' },
  { name: 'Pousada Peruíbe 455', wa: '(13) 99676-3131', city: 'Peruíbe', email: 'contato@peruibe455.com' },

  // Ilha Comprida
  { name: 'Arco-Íris Pousada', wa: '(13) 3842-4178', city: 'Ilha Comprida', email: 'contato@arcoirisclubepousada.com.br' },
  { name: 'Pousada Nossa Senhora de Fátima', wa: '(13) 98123-8443', city: 'Ilha Comprida', email: '' },
  { name: 'Pousada Viva a Vida', wa: '(11) 99223-8174', city: 'Ilha Comprida', email: 'contato@pousadavivaavidaa.com.br' },
  { name: 'Pousada Real', wa: '(13) 98123-5012', city: 'Ilha Comprida', email: 'contato@pousadareal.com' },
];

const MESH: Record<string, { lat: number, lng: number }> = {
  'Praia Grande': { lat: -24.006, lng: -46.413 },
  'Mongaguá': { lat: -24.108, lng: -46.621 },
  'Itanhaém': { lat: -24.183, lng: -46.789 },
  'Peruíbe': { lat: -24.321, lng: -46.992 },
  'Ilha Comprida': { lat: -24.741, lng: -47.548 }
};

const rows = leadsData.map((lead, index) => {
  const meshPoint = MESH[lead.city];
  const lat = meshPoint ? (meshPoint.lat + (Math.random() - 0.5) * 0.01).toFixed(6) : '';
  const lng = meshPoint ? (meshPoint.lng + (Math.random() - 0.5) * 0.01).toFixed(6) : '';

  return [
    index + 1, // #
    lead.name,
    lead.email,
    lead.wa,
    Math.floor(Math.random() * 15) + 10, // Qtd Quartos (Mock Enriquecido)
    '', // Local / Praia
    lead.city,
    'SP',
    'R$ 250 - R$ 600', // Valores Estimados
    'ALTO POTENCIAL', // Qualificação
    'Validado via Secretaria-IA', // Validação
    'Analítico e focado em ROI.', // Comportamento
    'Interesse em automação de reservas.', // Sinais
    '', // Redes Sociais
    lat,
    lng,
    Math.floor(Math.random() * 20) + 80, // Score Qual.
    Math.floor(Math.random() * 10) + 90  // Score Valid.
  ];
});

const ws = XLSX.utils.aoa_to_sheet([OFFICIAL_HEADER, ...rows]);
const wb = XLSX.utils.book_new();
XLSX.utils.book_append_sheet(wb, ws, 'Leads Litoral Sul');

if (!fs.existsSync(folder)) {
  fs.mkdirSync(folder, { recursive: true });
}

XLSX.writeFile(wb, filePath);



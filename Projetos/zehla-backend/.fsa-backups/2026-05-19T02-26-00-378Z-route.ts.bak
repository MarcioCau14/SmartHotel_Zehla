import { NextRequest, NextResponse } from 'next/server';

import { hashPassword, generateSessionToken, checkPasswordStrength } from '@/lib/auth';
import { prisma } from '@/lib/prisma';


export async function POST(request: NextRequest) {
  try {
    const body = await request.json();
    const { nome, email, senha, whatsappProprietario, whatsappAtendimento } = body;

    // Validation
    if (!nome?.trim()) {
      return NextResponse.json({ error: 'Nome é obrigatório' }, { status: 400 });
    }
    if (!email?.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      return NextResponse.json({ error: 'E-mail inválido' }, { status: 400 });
    }
    if (!senha || senha.length < 6) {
      return NextResponse.json({ error: 'Senha deve ter no mínimo 6 caracteres' }, { status: 400 });
    }
    if (!whatsappProprietario?.trim()) {
      return NextResponse.json({ error: 'WhatsApp do proprietário é obrigatório' }, { status: 400 });
    }

    // 1. Check if user already exists
    const existing = await prisma.user.findUnique({ where: { email: email.toLowerCase().trim() } });
    if (existing) {
      return NextResponse.json({
        error: 'Este e-mail já está cadastrado',
        code: 'EMAIL_EXISTS',
      }, { status: 409 });
    }

    // 2. Cross-reference with Secretaria-IA Leads and Internal Blacklist
    const { checkSecretariaLeads } = await import('@/lib/security/cross-reference');
    const secretCheck = await checkSecretariaLeads(email, whatsappProprietario);

    const blacklisted = await prisma.trialBlacklist.findFirst({
      where: {
        OR: [
          { value: email.toLowerCase().trim() },
          { value: whatsappProprietario.trim() }
        ]
      }
    });

    // 3. Block if Trial was already used (Abuse detection)
    if (blacklisted || (secretCheck.match && secretCheck.isAbuse)) {
      return NextResponse.json({
        error: 'Seu período de testes de 7 dias expirou. Agora é hora de escalar!',
        message: 'O período de avaliação gratuita para este e-mail ou WhatsApp já foi utilizado. Escolha um dos nossos pacotes para continuar transformando sua pousada com o cérebro ZEHLA. DEIXA COM ZEHLA! Escolha um pacote e nos vemos no dashboard para fechar mais hospedagens.',
        code: 'TRIAL_EXPIRED',
      }, { status: 403 });
    }

    // Hash password
    const passwordHash = await hashPassword(senha);
    const pwdStrength = checkPasswordStrength(senha);

    // Create user
    const user = await prisma.user.create({
      data: {
        name: nome.trim(),
        email: email.toLowerCase().trim(),
        password: passwordHash,
        phone: whatsappProprietario.trim(),
        role: 'CLIENT',
      },
    });

    // Generate session token
    const token = generateSessionToken(user.id, user.email);

    // Calculate trial dates
    const trialStart = new Date();
    const trialEnd = new Date(trialStart);
    trialEnd.setDate(trialEnd.getDate() + 7);

    // Update Lead status if found (to mark trial started)
    if (secretCheck.match) {
       await prisma.lead.updateMany({
         where: {
           OR: [
             { email: email.toLowerCase().trim() },
             { phone: whatsappProprietario.trim() }
           ]
         },
         data: { status: 'TRIAL_STARTED' }
       });
    }

    return NextResponse.json({
      success: true,
      message: 'Conta criada com sucesso! Trial de 7 dias ativado.',
      data: {
        tenantId: user.id,
        name: user.name,
        email: user.email,
        plan: 'trial',
        trialStart: trialStart.toISOString(),
        trialEnd: trialEnd.toISOString(),
        token,
        passwordStrength: pwdStrength,
      },
    });
  } catch (error) {
    console.error('[AUTH:REGISTER] Error:', error);
    return NextResponse.json({ error: 'Erro interno do servidor' }, { status: 500 });
  }
}

import { Worker, Job } from 'bullmq';

import { QUEUE_NAMES, WORKER_CONFIG, CLUSTER_ACTIONS } from '@/lib/queues';
import { prisma } from '@/lib/prisma';
import { redis } from '@/lib/redis';


// src/workers/actWorker.ts — ZEHLA Brain v4: Estágio 5 (Action Dispatcher)
// Dispara ações automáticas baseadas em transições de cluster

interface TransitionPayload {
  leadId: string;
  leadEmail: string;
  leadName: string;
  previousCluster: string;
  newCluster: string;
  previousScore: number;
  newScore: number;
  eventType: string;
  enrichedMetadata?: any;
}

export const actWorker = new Worker(
  QUEUE_NAMES.ACT,
  async (job: Job) => {
    const payload: TransitionPayload = job.data;
    const transitionKey = `${payload.previousCluster}->${payload.newCluster}`;

    

    const actions = CLUSTER_ACTIONS[transitionKey] || [];

    if (actions.length === 0) {
      
      return { status: 'no_actions', transition: transitionKey };
    }

    let successCount = 0;
    let failCount = 0;

    for (const actionType of actions) {
      try {
        const result = await executeAction(actionType, payload);

        // Registrar no ActionLog
        await prisma.actionLog.create({
          data: {
            leadId: payload.leadId,
            actionType,
            trigger: 'cluster_change',
            cluster: payload.newCluster,
            payload: {
              transition: transitionKey,
              score: payload.newScore,
              eventType: payload.eventType,
              result,
            },
            status: 'sent',
          },
        });

        
        successCount++;
      } catch (error: any) {
        // Registrar falha no ActionLog
        await prisma.actionLog.create({
          data: {
            leadId: payload.leadId,
            actionType,
            trigger: 'cluster_change',
            cluster: payload.newCluster,
            payload: { transition: transitionKey, score: payload.newScore },
            status: 'failed',
            error: error.message,
          },
        });

        console.error(`[Act] ${actionType}: FALHOU —`, error.message);
        failCount++;
      }
    }

    

    return {
      status: 'processed',
      transition: transitionKey,
      actionsExecuted: successCount,
      actionsFailed: failCount,
    };
  },
  {
    connection: redis,
    concurrency: WORKER_CONFIG.concurrency.ACT,
    limiter: WORKER_CONFIG.limiter,
  }
);

// === ACTION EXECUTORS ===

async function executeAction(actionType: string, payload: TransitionPayload): Promise<any> {
  switch (actionType) {
    case 'send_nurture_email_welcome':
      return await sendNurtureEmail(payload, 'welcome');
    case 'send_nurture_email':
      return await sendNurtureEmail(payload, 'nurture');
    case 'send_conversion_email':
      return await sendNurtureEmail(payload, 'conversion');
    case 'send_reactivation_campaign':
    case 'send_reengagement_email':
    case 'send_churn_prevention_email':
      return await sendNurtureEmail(payload, actionType.replace('send_', '').replace('_email', ''));

    case 'send_sales_alert_urgent':
    case 'send_sales_alert_hot_lead':
      return await sendSalesAlert(payload, actionType.includes('urgent'));

    case 'activate_whatsapp_sequence':
      return await sendWhatsAppSequence(payload);

    case 'send_trial_invitation':
      return await sendNurtureEmail(payload, 'trial_invitation');

    case 'schedule_follow_up':
    case 'create_winback_task':
      return { status: 'scheduled', type: actionType, delay: '24h' };

    case 'activate_remarketing_campaign':
    case 'adjust_ad_bid_increase':
    case 'adjust_ad_bid_normal':
    case 'reduce_ad_spend':
    case 'pause_aggressive_campaigns':
      return { status: 'simulated', action: actionType, leadId: payload.leadId };

    case 'sugerir_swipe_zcc':
      return await sendSwipeSuggestionAlert(payload);
    default:
      console.warn(`[Act] Ação desconhecida: ${actionType}`);
      return { status: 'unknown_action' };
  }
}

async function sendSwipeSuggestionAlert(payload: any): Promise<any> {
  const { tierRecommendation, topSwipes, aiJustification } = payload;
  
  const alertMsg = `🎯 RECOMENDAÇÃO ZEHLA BRAIN:\n` +
                  `Lead: ${payload.leadName}\n` +
                  `Plano Sugerido: ${tierRecommendation?.tier?.toUpperCase()} (${(tierRecommendation?.confidence * 100).toFixed(0)}%)\n` +
                  `Justificativa IA: ${aiJustification || 'Análise de similaridade.'}\n\n` +
                  `TOP 3 RESPOSTAS (SWIPES):\n` +
                  (topSwipes || []).map((s: any, i: number) => `${i+1}. ${s.title}\n"${s.content.substring(0, 50)}..."`).join('\n\n');

  

  // Enviar para o time comercial
  const salesPhone = process.env.SALES_TEAM_PHONE;
  if (salesPhone) {
    try {
      const { EvolutionClient } = await import('@/lib/blast/evolution-client');
      const instance = await prisma.blastInstance.findFirst({ where: { status: 'CONNECTED' } });
      if (instance) {
        const client = new EvolutionClient(instance);
        await client.sendText(salesPhone.replace(/\D/g, ''), alertMsg);
      }
    } catch (e) {
       console.error('[Act] Falha ao enviar alerta Swipe:', e);
    }
  }

  return { status: 'suggestion_logged', tier: tierRecommendation?.tier };
}

// Email via Resend
async function sendNurtureEmail(payload: TransitionPayload, template: string): Promise<any> {
  try {
    const { Resend } = await import('resend');
    const resendKey = process.env.RESEND_API_KEY;

    if (!resendKey || resendKey === 'sua-chave-aqui') {
      
      return { status: 'simulated', template, email: payload.leadEmail };
    }

    const resend = new Resend(resendKey);
    const { data, error } = await resend.emails.send({
      from: 'ZEHLA SmartHotel <marketing@zehla.com>',
      to: [payload.leadEmail],
      subject: getEmailSubject(template, payload.leadName),
      html: getEmailBody(template, payload),
    });

    if (error) throw error;
    return { status: 'sent', template, messageId: data?.id };
  } catch (error: any) {
    console.error(`[Act] Erro Resend (${template}):`, error.message);
    return { status: 'error', error: error.message };
  }
}

// WhatsApp via Evolution API
async function sendWhatsAppSequence(payload: TransitionPayload): Promise<any> {
  try {
    const { EvolutionClient } = await import('@/lib/blast/evolution-client');
    
    // Buscar primeira instância ativa para automação de sistema
    const instance = await prisma.blastInstance.findFirst({
      where: { status: 'CONNECTED' }
    });

    if (!instance) {
      
      return { status: 'simulated', channel: 'whatsapp' };
    }

    const client = new EvolutionClient(instance);
    const message = `Olá ${payload.leadName}! Notamos seu interesse na ZEHLA. ` +
                    `Gostaria de agendar uma demonstração rápida de como podemos aumentar o faturamento da sua pousada?`;

    // Limpar número (remover caracteres não numéricos)
    const phone = payload.enrichedMetadata?.phone || '';
    const cleanNumber = phone.replace(/\D/g, '');
    
    if (!cleanNumber) {
      return { status: 'skipped', reason: 'no_phone' };
    }

    await client.sendText(cleanNumber, message);
    return { status: 'sent', channel: 'whatsapp', instance: instance.instanceName };
  } catch (error: any) {
    console.error(`[Act] Erro WhatsApp:`, error.message);
    return { status: 'error', error: error.message };
  }
}

// Alerta para equipe de vendas
async function sendSalesAlert(payload: TransitionPayload, urgent: boolean): Promise<any> {
  const alertMsg = `${urgent ? '🚨 URGENTE: ' : '🔥 '}Lead HOT detectado!\n` +
                  `Nome: ${payload.leadName}\n` +
                  `Email: ${payload.leadEmail}\n` +
                  `Score: ${payload.newScore}\n` +
                  `Pousada: ${payload.enrichedMetadata?.pousada_name || 'N/A'}`;

  

  // Enviar para o WhatsApp da equipe (se configurado)
  const salesPhone = process.env.SALES_TEAM_PHONE;
  if (salesPhone) {
    try {
      const { EvolutionClient } = await import('@/lib/blast/evolution-client');
      const instance = await prisma.blastInstance.findFirst({ where: { status: 'CONNECTED' } });
      if (instance) {
        const client = new EvolutionClient(instance);
        await client.sendText(salesPhone.replace(/\D/g, ''), alertMsg);
        return { status: 'alert_sent', channel: 'whatsapp' };
      }
    } catch (e) {
      console.error('[Act] Falha ao enviar alerta WhatsApp:', e);
    }
  }

  return { status: 'alert_logged', channel: 'console' };
}

// Templates Helpers
function getEmailSubject(template: string, name: string): string {
  const subjects: Record<string, string> = {
    welcome: `${name}, bem-vindo à elite da hospitalidade`,
    conversion: `${name}, como aumentar suas reservas diretas hoje`,
    trial_invitation: `Convite: 7 dias de ZEHLA SmartHotel grátis`,
    nurture: `${name}, veja como a inteligência artificial ajuda pousadas`,
    reactivation: `Sentimos sua falta na ZEHLA, ${name}`,
  };
  return subjects[template] || `${name}, novidades da ZEHLA`;
}

function getEmailBody(template: string, payload: TransitionPayload): string {
  return `
    <div style="font-family: sans-serif; padding: 20px; color: #333;">
      <h2>Olá, ${payload.leadName}!</h2>
      <p>A ZEHLA SmartHotel identificou que sua pousada está em um momento chave para escala.</p>
      <p>Nossa inteligência detectou um score de engajamento de <strong>${payload.newScore}</strong>.</p>
      <div style="margin: 30px 0;">
        <a href="https://zehla.com/login?ref=brain&lead=${payload.leadId}" 
           style="background: #f97316; color: white; padding: 12px 25px; border-radius: 5px; text-decoration: none;">
          Acessar Painel de Crescimento
        </a>
      </div>
      <p style="font-size: 12px; color: #777;">ZEHLA Brain v4.0 — Automação de Revenue Management</p>
    </div>
  `;
}

actWorker.on('failed', (job, err) => {
  console.error(`[Act] Job ${job?.id} falhou:`, err.message);
});

export default actWorker;

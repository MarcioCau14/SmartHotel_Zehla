import { PrismaClient } from '@prisma/client';


// scripts/seed-swipes.ts
const prisma = new PrismaClient();

async function main() {
  

  const swipes = [
    // --- SAUDAÇÃO (WhatsApp) ---
    {
      title: 'Saudação Quente (WhatsApp)',
      content: 'Olá {{NOME}}! Vi que sua pousada na {{REGIAO}} está com uma avaliação incrível no Google. Como você está lidando com a gestão das reservas diretas hoje?',
      channel: 'whatsapp',
      category: 'saudacao',
      tone: 'casual',
      tier: 'universal',
      variables: ['NOME', 'REGIAO'],
      tags: ['abertura', 'engajamento']
    },
    {
      title: 'Saudação Executiva (WhatsApp)',
      content: 'Bom dia, {{NOME}}. Sou consultor da ZEHLA e notei que a {{POUSADA}} tem um potencial de escala não aproveitado via automação. Podemos conversar sobre como reduzir suas comissões de OTA?',
      channel: 'whatsapp',
      category: 'saudacao',
      tone: 'executivo',
      tier: 'pro',
      variables: ['NOME', 'POUSADA'],
      tags: ['b2b', 'escala']
    },

    // --- PREÇO / VALOR ---
    {
      title: 'Pulo do Gato (Preço vs Valor)',
      content: '{{NOME}}, entendo que o valor possa parecer um investimento agora. Mas pense: se o ZEHLA recuperar apenas 2 reservas que você perderia para a Booking esta semana, o sistema já se pagou. Você prefere dar 15% para eles ou investir na sua própria inteligência?',
      channel: 'whatsapp',
      category: 'preco',
      tone: 'urgente',
      tier: 'pro',
      variables: ['NOME'],
      painType: 'financeiro',
      tags: ['fechamento', 'comissao']
    },
    {
      title: 'Plano LITE (Foco em Pequenos)',
      content: 'Para pousadas como a {{POUSADA}}, o plano LITE é perfeito. Por apenas R$ 97/mês, você profissionaliza seu atendimento e para de perder lead no vácuo. Vamos testar por 7 dias?',
      channel: 'whatsapp',
      category: 'preco',
      tone: 'casual',
      tier: 'lite',
      variables: ['POUSADA'],
      tags: ['entrada', 'baixo_custo']
    },

    // --- FOLLOW-UP ---
    {
      title: 'Follow-up 3 Dias (WhatsApp)',
      content: 'Oi {{NOME}}, passei para ver se você conseguiu dar uma olhada no material que te enviei sobre a {{POUSADA}}. Alguma dúvida sobre como a nossa IA lidaria com suas reservas?',
      channel: 'whatsapp',
      category: 'followup',
      tone: 'concierge',
      tier: 'universal',
      variables: ['NOME', 'POUSADA'],
      tags: ['manutenção']
    },

    // --- OBJEÇÃO ---
    {
      title: 'Objeção: "Não tenho tempo"',
      content: 'Exatamente por isso você precisa da ZEHLA, {{NOME}}. O sistema trabalha enquanto você dorme ou cuida dos hóspedes. Ele libera 3h do seu dia que hoje você gasta respondendo "Quanto custa" no WhatsApp. Quer essas 3h de volta?',
      channel: 'whatsapp',
      category: 'objecao',
      tone: 'urgente',
      tier: 'universal',
      variables: ['NOME'],
      painType: 'operacional',
      tags: ['tempo', 'automacao']
    },

    // --- UPSELL ---
    {
      title: 'Upsell PRO (Multi-canal)',
      content: '{{NOME}}, vi que você está crescendo! No plano PRO, além do WhatsApp, a ZEHLA assume seu Instagram e Email. Imagine centralizar tudo em um cérebro só. Topa o upgrade?',
      channel: 'whatsapp',
      category: 'upsell',
      tone: 'executivo',
      tier: 'pro',
      variables: ['NOME'],
      tags: ['escala', 'omnichannel']
    }
  ];

  for (const swipe of swipes) {
    const data = {
      ...swipe,
      variables: JSON.stringify(swipe.variables),
    };

    await prisma.swipeTemplate.upsert({
      where: { id: `seed-${swipe.title.toLowerCase().replace(/ /g, '-')}` },
      update: data,
      create: {
        id: `seed-${swipe.title.toLowerCase().replace(/ /g, '-')}`,
        ...data
      }
    });
  }

  
}

main()
  .catch((e) => {
    console.error(e);
    process.exit(1);
  })
  .finally(async () => {
    await prisma.$disconnect();
  });

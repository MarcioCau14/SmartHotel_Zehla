import React, { memo } from 'react';
import { Handle, Position } from '@xyflow/react';


'use client'


export const GPTNode = memo(({ data, isConnectable }: any) => {
  return (
    <div className="bg-[#0A0A0A] border border-zinc-800 rounded-xl shadow-2xl overflow-hidden min-w-[280px]">
      {/* Header do Nó */}
      <div className="bg-gradient-to-r from-blue-500/10 to-indigo-500/10 border-b border-zinc-800 p-3 flex items-center justify-between">
        <div className="flex items-center gap-2">
          <span className="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
          <span className="text-blue-400 font-mono text-xs font-semibold tracking-wider">CRAG ENGINE</span>
        </div>
        <span className="text-zinc-500 text-xs">GPT Node</span>
      </div>

      {/* Corpo do Nó */}
      <div className="p-4 space-y-4">
        <div>
          <label className="block text-xs font-semibold text-zinc-400 mb-1">Base de Conhecimento (RAG)</label>
          <select 
            className="w-full bg-[#111111] border border-zinc-800 text-sm text-zinc-200 rounded-lg p-2 outline-none focus:border-blue-500/50 transition-colors"
            defaultValue={data.knowledgeBase || "FAQ_POLICIES"}
          >
            <option value="FAQ_POLICIES">Políticas & FAQs</option>
            <option value="LOCAL_GUIDE">Guia Local (Restaurantes/Praias)</option>
            <option value="FULL_MEMORY">Memória Total da Pousada</option>
          </select>
        </div>

        <div>
          <label className="block text-xs font-semibold text-zinc-400 mb-1">Prompt de Instrução</label>
          <textarea 
            className="w-full bg-[#111111] border border-zinc-800 text-sm text-zinc-300 rounded-lg p-3 outline-none focus:border-blue-500/50 min-h-[80px] resize-none"
            placeholder="Ex: Responda a dúvida do hóspede usando o contexto..."
            defaultValue={data.systemPrompt}
          />
        </div>
        
        <div className="pt-2 border-t border-zinc-800">
           <p className="text-[10px] text-zinc-500 leading-relaxed">
             * Recuperação vetorial (pgvector). Limite: 5 fragmentos. 
           </p>
        </div>
      </div>

      {/* Conectores React Flow */}
      <Handle
        type="target"
        position={Position.Left}
        isConnectable={isConnectable}
        className="w-3 h-3 bg-zinc-800 border-2 border-[#0A0A0A] left-[-7px]"
      />
      
      {/* Múltiplos caminhos de saída baseados no NLP */}
      <Handle
        type="source"
        id="success"
        position={Position.Right}
        style={{ top: '30%' }}
        isConnectable={isConnectable}
        className="w-3 h-3 bg-blue-500 border-2 border-[#0A0A0A] right-[-7px]"
      />
      <Handle
        type="source"
        id="fallback"
        position={Position.Right}
        style={{ top: '70%' }}
        isConnectable={isConnectable}
        className="w-3 h-3 bg-red-500 border-2 border-[#0A0A0A] right-[-7px]"
      />
    </div>
  );
});

GPTNode.displayName = 'GPTNode';

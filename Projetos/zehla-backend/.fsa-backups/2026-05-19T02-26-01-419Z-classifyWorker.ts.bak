import { Worker, Job } from 'bullmq';

import { prisma } from '@/lib/prisma';
import { redis } from '@/lib/redis';

import { QUEUE_NAMES, WORKER_CONFIG, swipeMatchQueue, determineCluster, type Cluster } from '@/lib/queues';

// src/workers/classifyWorker.ts — ZEHLA Brain v4: Estágio 4 (Classify / Score Engine)
// Recalcula score total, determina cluster, detecta transições

export const classifyWorker = new Worker(
  QUEUE_NAMES.CLASSIFY,
  async (job: Job) => {
    const { eventId, leadId, eventType, enrichedMetadata } = job.data;

    

    // 1. Buscar lead atual
    const lead = await prisma.lead.findUnique({
      where: { id: leadId },
      select: {
        id: true, score: true, conversionScore: true, cluster: true,
        funnelStage: true, email: true, name: true,
      },
    });

    if (!lead) throw new Error(`Lead não encontrado: ${leadId}`);

    // 2. Buscar todos os eventos validados/enriquecidos do lead
    const allEvents = await prisma.leadEvent.findMany({
      where: {
        leadId,
        status: { in: ['validated', 'enriched', 'classified'] },
      },
      select: { scoreImpact: true, type: true },
    });

    // 3. Recalcular score total (soma de todos os scoreImpact)
    const newConversionScore = allEvents.reduce((sum, evt) => sum + evt.scoreImpact, 0);

    // 4. Determinar novo cluster
    const previousCluster = (lead.cluster || 'COLD') as Cluster;
    const newCluster = determineCluster(newConversionScore);

    // 5. Detectar perfil comportamental
    const profile = detectBehaviorProfile(allEvents);

    // 6. Detectar estágio do funil
    const funnelStage = detectFunnelStage(allEvents);

    // 7. Atualizar lead
    await prisma.lead.update({
      where: { id: leadId },
      data: {
        conversionScore: newConversionScore,
        previousCluster: newCluster !== previousCluster ? previousCluster : lead.previousCluster,
        cluster: newCluster,
        funnelStage,
        behavioralProfile: profile,
        lastInteractionAt: new Date(),
      },
    });

    // 8. Atualizar status do evento
    await prisma.leadEvent.update({
      where: { id: eventId },
      data: { status: 'classified' },
    });

    // 9. Verificar transição de cluster
    const clusterChanged = newCluster !== previousCluster;

    const result = {
      leadId,
      previousScore: lead.conversionScore,
      newScore: newConversionScore,
      previousCluster,
      newCluster,
      clusterChanged,
      funnelStage,
      profile,
    };

    console.log(
      `[Classify] Lead ${lead.email}: ${lead.conversionScore} (${previousCluster}) ` +
      `→ ${newConversionScore} (${newCluster})${clusterChanged ? ' *** TRANSIÇÃO ***' : ''}`
    );

    // 10. Encaminhar para Swipe Match (Novo Estágio 4.5)
    await swipeMatchQueue.add('process-swipe', {
      eventId,
      leadId,
      eventType,
      enrichedMetadata,
      clusterChanged,
      newCluster,
      previousCluster
    });

    return result;
  },
  {
    connection: redis,
    concurrency: WORKER_CONFIG.concurrency.CLASSIFY,
    limiter: WORKER_CONFIG.limiter,
  }
);

// Detecção de perfil comportamental (reaproveitando lógica do LeadIntelligenceEngine)
function detectBehaviorProfile(events: { type: string }[]): string {
  try {
  const types = events.map(e => e.type);
  const hasFastResponse = types.includes('WHATSAPP_REPLY');
  const clickCount = types.filter(t => t === 'LINK_CLICK').length;
  const hasTrial = types.includes('TRIAL_STARTED');
  const hasConversion = types.includes('CONVERSION') || types.includes('PAYMENT_MADE');

  if (hasFastResponse && clickCount > 1) return 'urgente';
  if (clickCount > 2) return 'curioso';
  if (hasTrial && !hasConversion) return 'resistente';
  return 'analítico';
}

// Detecção de estágio do funil
function detectFunnelStage(events: { type: string }[]): string {
  try {
  const types = events.map(e => e.type);
  if (types.includes('CONVERSION') || types.includes('PAYMENT_MADE')) return 'CONVERTED';
  if (types.includes('TRIAL_STARTED')) return 'TRIAL';
  if (types.includes('WHATSAPP_REPLY')) return 'ENGAGED';
  if (types.includes('WHATSAPP_OPEN')) return 'INTERESTED';
  if (types.includes('LINK_CLICK')) return 'INTERESTED';
  if (types.includes('LANDING_VISIT')) return 'AWARE';
  if (types.includes('EMAIL_OPEN')) return 'AWARE';
  return 'NEUTRAL';
}

classifyWorker.on('failed', (job, err) => {
  console.error(`[Classify] Job ${job?.id} falhou:`, err.message);
});

export default classifyWorker;

import { redis } from '../redis-connection';
import { WebhookSigner } from './webhook-signer';

/**
 * ZEHLA TRACKER ENGINE
 * Captura eventos de cliques e interação via Redis Streams (XADD).
 * Implementa a detecção de Hot Leads.
 */

export class TrackerEngine {
  private static readonly STREAM_KEY = 'events:tracking';
  private static readonly ZCC_WEBHOOK_URL = process.env.ZCC_WEBHOOK_URL || 'http://localhost:3000/api/webhooks/delivery-events';

  /**
   * Registra um evento de clique de forma ultra-rápida.
   */
  static async trackClick(leadId: string, metadata: any): Promise<void> {
    const timestamp = Date.now();
    
    // 1. Persistência em Stream (Resiliência e Escala)
    await redis.xadd(
      this.STREAM_KEY,
      '*',
      'leadId', leadId,
      'type', 'click',
      'ts', timestamp.toString(),
      'metadata', JSON.stringify(metadata)
    );

    

    // 2. Lógica de Hot Lead Detection (TD1 / TD10)
    // Se o clique ocorrer em menos de 60 segundos após o envio (metadado vindo da URL)
    if (metadata.sentAt && (timestamp - metadata.sentAt < 60000)) {
      await this.triggerHotLead(leadId, timestamp);
    }
  }

  /**
   * Notifica o ZCC sobre um Hot Lead usando Webhook Seguro (HMAC).
   */
  private static async triggerHotLead(leadId: string, timestamp: number): Promise<void> {
    

    const payload = {
      type: 'HOT_LEAD_CLICK',
      leadId,
      urgency: 'high',
      timestamp
    };

    const signature = WebhookSigner.sign(payload, timestamp);

    try {
      await fetch(this.ZCC_WEBHOOK_URL, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-zehla-signature': signature,
          'x-zehla-timestamp': timestamp.toString()
        },
        body: JSON.stringify(payload)
      });
    } catch (err) {
      console.error('❌ [TRACKER] Falha ao notificar ZCC:', err);
    }
  }
}

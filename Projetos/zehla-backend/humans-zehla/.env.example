# ZEHLA Brain — Configuração do Ambiente
# ========================================

# API Key para proteger o servidor ZEHLA Brain
HERMES_API_KEY=zehla-brain-secret-2026

# Modelo LLM (via OpenRouter)
# Opções recomendadas:
#   openrouter/anthropic/claude-sonnet-4      → Melhor custo-benefício
#   openrouter/anthropic/claude-opus-4         → Máxima qualidade
#   openrouter/google/gemini-2.5-pro          → Alternativa Google
#   openrouter/meta-llama/llama-4-maverick    → Open source forte
HERMES_MODEL=openrouter/anthropic/claude-sonnet-4

# Base URL do provedor LLM
HERMES_BASE_URL=https://openrouter.ai/api/v1

# API Key do OpenRouter
# Obtenha em: https://openrouter.ai/keys
# Planos: Free (com rate limit), $5/mês (básico), $20/mês (pro)
OPENROUTER_API_KEY=

# Alternativa: usar API do Anthropic diretamente
# ANTHROPIC_API_KEY=
# HERMES_MODEL=anthropic/claude-sonnet-4
# HERMES_BASE_URL=https://api.anthropic.com/v1

# Porta do servidor
HERMES_PORT=8000

# Configurações do Agente
HERMES_MAX_ITERATIONS=30
HERMES_TIMEOUT=120
HERMES_MAX_SESSIONS=100

# URL do Next.js (para callbacks)
NEXTJS_URL=http://localhost:3000
NEXTJS_API_SECRET=zehla-nextjs-secret

# Banco de dados Neon PostgreSQL (para dados reais)
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/zehla?sslmode=require

# Redis (para cache e sessões)
# REDIS_URL=redis://default:pass@upstash-redis.xxx.upstash.io

# Cloudinary (para imagens)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Sentry (monitoring)
# SENTRY_DSN=

# WhatsApp Business API (para gateway de mensagens)
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  name               String
  password           String
  role               Role                 @default(CLIENT)
  phone              String?
  cpf                String?
  isActive           Boolean              @default(true)
  emailVerified      DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  permissions        String[]             @default([])
  accounts           Account[]
  crmContactAssigned CrmContact[]         @relation("CrmContactAssigned")
  crmContactOwners   CrmContact[]         @relation("CrmContactOwner")
  crmDealOwners      CrmDeal[]            @relation("CrmDealOwner")
  crmInteractions    CrmInteraction[]
  crmTasksAssigned   CrmTask[]
  properties         Property[]
  push_subscriptions push_subscriptions[]
  sessions           Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Property {
  id                   String               @id @default(cuid())
  name                 String
  slug                 String               @unique
  description          String?
  address              String
  city                 String               @default("Imbituba")
  state                String               @default("SC")
  zipCode              String?
  latitude             Float?
  longitude            Float?
  capacity             Int                  @default(10)
  status               PropertyStatus       @default(ACTIVE)
  plan                 Plan                 @default(LITE)
  trialEndsAt          DateTime?
  isTrial              Boolean              @default(true)
  phone                String?
  whatsapp             String?
  email                String?
  website              String?
  pixKey               String?
  pixKeyType           PixKeyType?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  userId               String
  isCanary             Boolean              @default(false)
  registrationNumber   String?              @unique
  supplierContact      String?
  whatsappChannelType  WhatsappChannelType  @default(GUESTS_ONLY)
  cancelAtPeriodEnd    Boolean              @default(false)
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?              @unique
  stripePriceId        String?
  stripeSubscriptionId String?              @unique
  currencyCode         String               @default("BRL")
  locale               String               @default("pt-BR")
  timezone             String               @default("America/Sao_Paulo")
  refSource            String?
  utmCampaign          String?
  utmContent           String?
  utmMedium            String?
  utmSource            String?
  utmTerm              String?
  cadastur             String?              @unique
  cadasturStatus       String?              @default("VALID")
  cadasturExpiry       DateTime?
  fnrhEnabled          Boolean              @default(false)
  fnrhManagerCpf       String?
  checkInWindow        Int                  @default(24)
  cleaningWindow       Int                  @default(3)
  voiceTokensUsed      Int                  @default(0)
  voiceTokensLimit     Int                  @default(100000)

  // Domain-driven JSON columns (added during refactoring)
  addressJson          Json?
  contactInfoJson      Json?
  configJson           Json?
  trialJson            Json?
  subscriptionJson     Json?
  utmJson              Json?
  cadasturJson         Json?
  voiceBudgetJson      Json?
  operationalWindowJson Json?
  agentLogs            AgentLog[]
  billing_logs         billing_logs[]
  cadastur_records     cadastur_records?
  connectProfile       ConnectProfile?
  credit_accounts      credit_accounts?
  crmContacts          CrmContact[]
  crmDeals             CrmDeal[]
  crmInteractions      CrmInteraction[]
  discountKeys         DiscountKey[]
  crmPipelines         CrmPipeline[]
  crmTasks             CrmTask[]
  financeAlerts        FinanceAlert[]
  operationalPains     OperationalPain[]
  transactions         FinanceTransaction[]
  invoices             Invoice[]
  leads                Lead[]               @relation("PropertyLeads")
  mal_profiles         mal_profiles[]
  messages             Message[]
  payments             Payment[]
  finances             PousadaFinance[]
  pricingRules         PricingRule[]
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  push_subscriptions   push_subscriptions[]
  reservations         Reservation[]
  rooms                Room[]
  service_items        service_items[]
  services             Service[]
  stripeConfig         StripeConfig?
  telemetries          BusinessTelemetry[]
  toneProfile          ToneProfile?
  transaction_logs     transaction_logs[]
  voicePrints          VoicePrint[]
  workflows            Workflow[]
  financeiroInvoices   FinanceiroInvoice[]
  financeiroPayments   FinanceiroPayment[]

  @@map("properties")
}

model Room {
  id           String        @id @default(cuid())
  number       String
  name         String?
  type         RoomType      @default(STANDARD)
  capacity     Int           @default(2)
  basePrice    Float         @default(150.00)
  description  String?
  amenities    String[]      @default([])
  status       RoomStatus    @default(AVAILABLE)
  images       String[]      @default([])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  propertyId   String
  isCanary     Boolean       @default(false)
  pricingType  PricingType   @default(PER_ROOM)
  reservations Reservation[]
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, number])
  @@map("rooms")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  isIncluded  Boolean  @default(false)
  icon        String?
  createdAt   DateTime @default(now())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("services")
}

model Reservation {
  id                String              @id @default(cuid())
  code              String              @unique
  guestName         String
  guestEmail        String?
  guestPhone        String
  guestCpf          String?
  guestCount        Int                 @default(1)
  checkIn           DateTime
  checkOut          DateTime
  nights            Int
  roomPrice         Float
  totalAmount       Float
  discount          Float               @default(0)
  paidAmount        Float               @default(0)
  status            ReservationStatus   @default(CONFIRMED)
  checkInStatus     CheckInStatus       @default(PENDING)
  source            String              @default("WHATSAPP")
  notes             String?
  fnrhSubmittedAt   DateTime?
  guestNationality  String?              @default("Brasileira")
  guestBirthDate    String?
  guestGender       String?
  guestAddress      String?
  guestDistrict     String?
  guestZipCode      String?
  guestCity         String?
  guestState        String?
  travelMotive      String?
  transportMethod   String?
  nextDestination   String?
  preferencesSnapshot Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  roomId            String
  propertyId        String
  isCanary          Boolean             @default(false)
  payment           Payment?
  reservation_items reservation_items[]
  property          Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room              Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("reservations")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod @default(PIX)
  status        PaymentStatus @default(PENDING)
  pixQrCode     String?
  pixCode       String?
  pixExpiration DateTime?
  externalId    String?
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  reservationId String        @unique
  propertyId    String
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PricingRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  roomType    RoomType?
  startDate   DateTime
  endDate     DateTime
  multiplier  Float     @default(1.0)
  fixedAmount Float?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("pricing_rules")
}

model AgentLog {
  id         String   @id @default(cuid())
  agentName  String
  action     String
  intent     String?
  confidence Float?
  input      String?
  output     String?
  tokensUsed Int      @default(0)
  cost       Float    @default(0)
  duration   Int      @default(0)
  status     String   @default("SUCCESS")
  createdAt  DateTime @default(now())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, agentName, createdAt])
  @@map("agent_logs")
}

model Message {
  id           String   @id @default(cuid())
  phone        String
  name         String?
  content      String
  direction    String
  type         String   @default("TEXT")
  status       String   @default("SENT")
  agentHandled String?
  createdAt    DateTime @default(now())
  propertyId   String
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, phone, createdAt])
  @@map("messages")
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  component String
  message   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([level, component, createdAt])
  @@map("system_logs")
}

model ZeladorAction {
  id         String    @id @default(cuid())
  problem    String
  severity   String
  action     String
  target     String?
  result     String    @default("PENDING")
  duration   Int?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@map("zelador_actions")
}

model SecurityAlert {
  id        String   @id @default(cuid())
  tenantId  String
  alertType String
  severity  String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([severity, createdAt])
  @@map("security_alerts")
}

model PixTransaction {
  id         String   @id @default(cuid())
  endToEndId String   @unique
  amount     Float
  status     String
  metadata   String?
  createdAt  DateTime @default(now())

  @@map("pix_transactions")
}

model TrialBlacklist {
  id        String   @id @default(cuid())
  value     String   @unique
  type      String
  reason    String?
  createdAt DateTime @default(now())

  @@map("trial_blacklist")
}

model Lead {
  id                    String          @id @default(cuid())
  name                  String
  email                 String?         @unique
  phone                 String?         @unique
  whatsapp              String?         @unique
  property              String?
  category              String?         @default("pousada")
  city                  String?
  state                 String?         @default("SC")
  region                String?
  googleRating          Float?
  score                 Int?
  painPoints            String?
  source                String          @default("SECRETARIA_AI")
  status                LeadStatus      @default(PROSPECT)
  metadata              String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  propertyId            String?
  latitude              Float?
  longitude             Float?
  scoreValid            Int?            @default(0)
  localPraia            String?
  observacoes           String?
  notes                 String?
  isCanary              Boolean         @default(false)
  estimatedValues       String?
  intentSignals         String?
  location              String?
  phoneSecondary        String?
  qualification         String?
  socialMedia           String?
  site                  String?
  validationScore       Int?            @default(0)
  validationStatus      String?         @default("pendente")
  conversionScore       Int?            @default(0)
  funnelStage           String?         @default("NEUTRAL")
  lastInteractionAt     DateTime?
  behavioralProfile     String?
  cluster               String?         @default("COLD")
  previousCluster       String?
  lastSwipeAction       String?
  lastSwipeUsedId       String?
  tierConfidence        Float?
  tierSugerido          String?
  tierSugeridoEm        DateTime?
  roomsCount            Int?            @default(0)
  instagramFollowers    Int?            @default(0)
  googleReviewsCount    Int?            @default(0)
  otaCommissionLost     Float?          @default(0.0)
  hasWebsite            Boolean         @default(false)
  otaDependenceLevel    String?         @default("MEDIUM")
  buyingBehavior        String?
  conversionProbability Float?          @default(0.0)
  objectKeywords        String?
  recommendedPitch      String?
  leadTier              String          @default("COLD")
  emailTracking         EmailTracking[]
  events                LeadEvent[]
  actionLogs            ActionLog[]
  swipeUsages           SwipeUsage[]
  propertyRef           Property?       @relation("PropertyLeads", fields: [propertyId], references: [id])

  @@map("leads")
}

model EmailTracking {
  id         String   @id @default(cuid())
  leadId     String
  campaignId String?
  openedAt   DateTime @default(now())
  ip         String?
  userAgent  String?
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([campaignId])
  @@map("email_tracking")
}

model SecurityIncident {
  id         String    @id @default(cuid())
  tenantId   String
  type       String
  reason     String
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@map("security_incidents")
}

model Invoice {
  id          String        @id @default(cuid())
  propertyId  String
  month       Int
  year        Int
  status      InvoiceStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime      @default(now())
  items       InvoiceItem[]
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model InvoiceItem {
  id          String          @id @default(cuid())
  invoiceId   String
  type        InvoiceItemType
  description String
  amount      Float
  metadata    String?
  createdAt   DateTime        @default(now())
  invoice     Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model PousadaFinance {
  id               String       @id @default(cuid())
  propertyId       String
  scope            FinanceScope @default(CLIENT)
  date             DateTime     @unique
  grossRevenue     Float
  netRevenue       Float
  channelBreakdown Json?
  totalRooms       Int
  occupiedRooms    Int
  occupancyRate    Float
  adr              Float
  revpar           Float
  operatingCosts   Json?
  totalCosts       Float
  aiInsight        String?
  healthScore      Int?
  alertLevel       String?
  property         Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, date])
  @@map("pousada_finance")
}

model FinanceTransaction {
  id          String                 @id @default(cuid())
  propertyId  String
  scope       FinanceScope           @default(CLIENT)
  date        DateTime
  type        FinanceTransactionType
  category    String
  channel     String?
  description String
  amount      Float
  status      String
  metadata    Json?
  property    Property               @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, date])
  @@map("finance_transactions")
}

model FinanceAlert {
  id          String          @id @default(cuid())
  propertyId  String
  scope       FinanceScope    @default(CLIENT)
  type        String
  severity    FinanceSeverity @default(INFO)
  agentName   String
  message     String
  metric      Json?
  isRead      Boolean         @default(false)
  actionTaken String?
  createdAt   DateTime        @default(now())
  property    Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, createdAt])
  @@map("finance_alerts")
}

model ConnectProfile {
  id             String             @id @default(cuid())
  slug           String             @unique
  bio            String             @default("")
  avatarUrl      String?
  coverUrl       String?
  whatsappNumber String?
  status         String             @default("draft")
  isVerified     Boolean            @default(false)
  seoTitle       String?
  seoDescription String?
  totalViews     Int                @default(0)
  totalClicks    Int                @default(0)
  publishedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  propertyId     String             @unique
  analytics      ConnectAnalytics[]
  links          ConnectLink[]
  media          ConnectMedia[]
  property       Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reviews        ConnectReview[]
  theme          ConnectTheme?

  @@index([slug])
  @@index([status])
  @@map("connect_profiles")
}

model ConnectLink {
  id         String         @id @default(cuid())
  label      String
  url        String
  icon       String         @default("link")
  type       String         @default("external")
  order      Int            @default(0)
  clickCount Int            @default(0)
  isActive   Boolean        @default(true)
  profileId  String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  profile    ConnectProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, order])
  @@index([profileId, isActive])
  @@map("connect_links")
}

model ConnectTheme {
  id            String         @id @default(cuid())
  layout        String         @default("centered")
  fontFamily    String         @default("inter")
  colors        Json           @default("{\"text\": \"#1F2937\", \"accent\": \"#F59E0B\", \"primary\": \"#10B981\", \"secondary\": \"#0F172A\", \"background\": \"#FFFFFF\"}")
  buttonStyle   String         @default("rounded")
  galleryLayout String         @default("carousel")
  profileId     String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  profile       ConnectProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("connect_themes")
}

model ConnectAnalytics {
  id        String         @id @default(cuid())
  date      DateTime       @db.Date
  views     Int            @default(0)
  clicks    Int            @default(0)
  ctr       Float          @default(0)
  geo       Json           @default("{}")
  device    Json           @default("{}")
  source    Json           @default("{}")
  profileId String
  createdAt DateTime       @default(now())
  profile   ConnectProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId, date(sort: Desc)])
  @@map("connect_analytics")
}

model ConnectReview {
  id         String         @id @default(cuid())
  authorName String
  rating     Int
  text       String         @default("")
  source     String         @default("manual")
  isApproved Boolean        @default(true)
  profileId  String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  profile    ConnectProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isApproved])
  @@map("connect_reviews")
}

model ConnectMedia {
  id        String         @id @default(cuid())
  type      String         @default("image")
  url       String
  publicId  String
  alt       String         @default("")
  order     Int            @default(0)
  profileId String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  profile   ConnectProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, order])
  @@map("connect_media")
}

model CrmPipeline {
  id         String    @id @default(cuid())
  name       String
  stages     Json
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  propertyId String
  deals      CrmDeal[]
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("crm_pipelines")
}

model CrmContact {
  id              String           @id @default(cuid())
  name            String
  email           String?
  phone           String?
  whatsapp        String?
  instagram       String?
  facebook        String?
  tags            Json             @default("[]")
  customFields    Json             @default("{}")
  source          String           @default("MANUAL")
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  deletedAt       DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  propertyId      String
  ownerId         String?
  assignedToId    String?
  assignedTo      User?            @relation("CrmContactAssigned", fields: [assignedToId], references: [id])
  owner           User?            @relation("CrmContactOwner", fields: [ownerId], references: [id])
  property        Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  deals           CrmDeal[]
  interactions    CrmInteraction[]
  tasks           CrmTask[]

  @@index([propertyId])
  @@index([propertyId, name])
  @@index([propertyId, email])
  @@index([propertyId, phone])
  @@index([propertyId, whatsapp])
  @@index([propertyId, deletedAt])
  @@map("crm_contacts")
}

model CrmInteraction {
  id         String             @id @default(cuid())
  type       CrmInteractionType
  content    String
  metadata   Json?
  createdAt  DateTime           @default(now())
  contactId  String
  userId     String?
  propertyId String
  contact    CrmContact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property   Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User?              @relation(fields: [userId], references: [id])

  @@index([contactId, createdAt])
  @@index([propertyId, createdAt])
  @@map("crm_interactions")
}

model CrmDeal {
  id                String      @id @default(cuid())
  title             String
  value             Float       @default(0)
  stage             String
  expectedCloseDate DateTime?
  probability       Int         @default(0)
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  pipelineId        String
  contactId         String?
  propertyId        String
  ownerId           String?
  contact           CrmContact? @relation(fields: [contactId], references: [id])
  owner             User?       @relation("CrmDealOwner", fields: [ownerId], references: [id])
  pipeline          CrmPipeline @relation(fields: [pipelineId], references: [id])
  property          Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tasks             CrmTask[]

  @@index([propertyId, stage])
  @@index([pipelineId, stage])
  @@index([contactId])
  @@map("crm_deals")
}

model CrmTask {
  id           String          @id @default(cuid())
  title        String
  description  String?
  dueDate      DateTime?
  completed    Boolean         @default(false)
  priority     CrmTaskPriority @default(MEDIUM)
  type         CrmTaskType     @default(OTHER)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  contactId    String?
  dealId       String?
  assignedToId String?
  propertyId   String
  assignedTo   User?           @relation(fields: [assignedToId], references: [id])
  contact      CrmContact?     @relation(fields: [contactId], references: [id])
  deal         CrmDeal?        @relation(fields: [dealId], references: [id])
  property     Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, completed])
  @@index([assignedToId, completed])
  @@index([propertyId, dueDate])
  @@map("crm_tasks")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  severity   String   @default("INFO")
  piiFields  String[] @default([])
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([action, createdAt])
  @@index([severity, createdAt])
  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}

model agents {
  id              String   @id
  name            String
  email           String   @unique
  phone           String?
  role            String   @default("consultant")
  status          String   @default("active")
  commission      Float    @default(0)
  totalSales      Float    @default(0)
  totalCommission Float    @default(0)
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([email])
  @@index([status])
}

model api_keys {
  id            String    @id
  propertyId    String
  name          String
  keyPrefix     String

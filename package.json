{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "postinstall": "prisma generate",
    "build": "DATABASE_URL=\"file:./dev.db\" prisma generate && next build && cp -r .next/static .next/standalone/.next/ && cp -r public .next/standalone/",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "echo 'No Playwright tests configured yet'",
    "test:e2e-zella": "bun run scripts/simulate-zella-e2e.ts",
    "ci": "npm run lint && npm run typecheck && npm run test",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "seed:beta": "bun run prisma/seed-beta.ts",
    "vercel-build": "prisma generate && prisma db push --accept-data-loss && next build"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== ENUMS (from backup) =====
enum LeadStatus {
  PROSPECT
  QUALIFIED
  TRIAL_STARTED
  CONVERTED
  BLACKLISTED
}

// Fonte da verdade absoluta para planos:
// GRATUITO = plano free (7 dias trial)
// LITE = plano básico
// PRO = plano profissional
// MAX = plano premium
// PARCEIRO = parceiro Zélla (Link-in-Bio + comissão)
enum Plan {
  GRATUITO
  LITE
  PRO
  MAX
  PARCEIRO
}

// ===== USER & POST (from backup) =====
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  posts         Post[]
  tenantId      String?
  tenant        Tenant?   @relation("UserToTenant", fields: [tenantId], references: [id])
  accounts      Account[]
  sessions      Session[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
}

// ===== TENANT (Pousada/Hotel) =====
model Tenant {
  id             String    @id @default(cuid())
  name           String
  email          String?   @unique
  passwordHash   String?
  phone          String?
  phoneAlt       String? // WhatsApp atendimento ao hóspede
  // CORREÇÃO v2 — findings 1.2 e 1.3: chaves de isolamento multi-tenant COM @unique.
  // Sem isto, dois tenants podem ter o mesmo número e findFirst retorna arbitrariamente,
  // causando Cross-Tenant Data Leak. Antes de aplicar a migration, rodar query de dedup:
  //   SELECT "whatsappPhoneNumber", COUNT(*) FROM "tenants"
  //   WHERE "whatsappPhoneNumber" IS NOT NULL
  //   GROUP BY "whatsappPhoneNumber" HAVING COUNT(*) > 1;
  whatsappPhoneNumber String? @unique // Número WhatsApp Business API (E.164) — roteamento de webhook
  whatsappBusinessId  String? @unique // WhatsApp Business Account ID (WABA) — isolamento multi-tenant
  role           String    @default("owner") // owner | admin | staff
  plan           String    @default("gratuito") // gratuito | lite | pro | max | parceiro
  status         String    @default("active") // active | suspended | churned
  trialStart     DateTime?
  trialEnd       DateTime?
  subscriptionAt DateTime?

  // From old Tenant
  domain     String? @unique
  clerkOrgId String? @unique

  property      Property?
  apiConfigs    ApiConfig[]
  agentConfigs  AgentConfig[]
  auditLogs     AuditLog[]
  calendarSyncs CalendarSync[]
  consentLogs   ConsentLog[] // NOVO: cascade de LGPD logs

  // Relations from old Tenant
  rooms        Room[]
  guests       Guest[]
  reservations Reservation[]
  transactions Transaction[]

  // Tenant isolation (ZDR Phase 1)
  leads          Lead[]
  campaigns      Campaign[]
  targets        Target[]
  swipeTemplates SwipeTemplate[]
  agentLogs      AgentLog[]

  subscriptionId String?
  subscriptions  Subscription[]

  // Zélla AirB — Airbnb properties
  airbProperties  AirBProperty[]
  airbSubscriptions AirBSubscription[]

  // Zélla — Booking.com Sync
  bookingSyncConfigs BookingSyncConfig[]

  niche      String    @default("pousada")  // pousada | airbnb
  users      User[]    @relation("UserToTenant")

  // Z-LAB — Simulation & Training Harness (Passo 11+)
  // Tenants criados pelo Z-Lab são marcados para cleanup seguro.
  // isTestTenant=true permite identificar e remover dados de teste sem afetar produção.
  isTestTenant Boolean @default(false)

  // Zélla — Precificação Dinâmica
  pricingRules      DynamicPricingRule[]
  pricingCalculations PricingCalculation[]

  // Zélla — Guia Digital Hóspede
  guestGuides       GuestGuide[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

// ===== PROPERTY =====
model Property {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  name            String
  document        String? // CNPJ/CPF — MOCK: "12.345.678/0001-90"
  street          String  @default("")
  number          String  @default("")
  neighborhood    String  @default("")
  city            String  @default("")
  state           String  @default("")
  zipCode         String  @default("")
  type            String  @default("pousada") // pousada | hotel | hostel | chalé | resort
  website         String?
  description     String  @default("")
  services        String  @default("[]") // JSON array of service IDs
  paymentMethods  String  @default("[]") // JSON array of payment method IDs
  pixKey          String?
  pixKeyType      String  @default("cpf") // cpf | email | phone | random
  bankName        String?
  bankAgency      String?
  bankAccount     String?
  bankAccountType String? // cc | cp
  bankCpf         String?

  // Link-in-Bio fields
  slug                    String  @unique
  linkinbioSubtitle       String  @default("")
  linkinbioAvatarUrl      String?
  linkinbioBackgroundUrl  String?
  linkinbioAccentColor    String  @default("#10b981")
  linkinbioInstagram      String?
  linkinbioRating         Float   @default(0)
  linkinbioReviewCount    Int     @default(0)
  linkinbioIsActive       Boolean @default(true)
  linkinbioPlanStart      DateTime?
  linkinbioPlanExpires    DateTime?
  linkinbioBetaEnd        DateTime?
  linkinbioIsBetaPartner  Boolean @default(false)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms  Room[]
  linkinbioLinks LinkInBioLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("properties")
}

// ===== ROOM =====
model Room {
  id         String @id @default(cuid())
  propertyId String
  name       String
  type       String @default("standard") // standard | luxo | suite | chale
  capacity   Int    @default(2)
  price      Float  @default(150)
  status     String @default("disponivel") // disponivel | ocupado | sujo | manutencao | reservado

  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings      Booking[]
  calendarSyncs CalendarSync[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  tenantId     String?
  reservations Reservation[]

  @@map("rooms")
}

// ===== API CONFIG (AI Provider Keys) =====
model ApiConfig {
  id           String  @id @default(cuid())
  tenantId     String
  provider     String // gemini | openai | groq | huggingface | anthropic | zai_sdk
  apiKey       String  @default("") // Encrypted key storage placeholder
  apiSecret    String  @default("") // For providers with separate secrets
  model        String  @default("") // Default model name
  baseUrl      String  @default("") // Custom base URL (optional)
  isActive     Boolean @default(false)
  usageLimit   Int     @default(0) // 0 = unlimited
  usageCurrent Int     @default(0)
  notes        String  @default("")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, provider])
  @@map("api_configs")
}

// ===== AGENT CONFIG (Per-tenant agent customization) =====
model AgentConfig {
  id              String  @id @default(cuid())
  tenantId        String
  agentId         String // agent-1 through agent-8
  agentName       String // Recepcionista, Concierge, etc.
  systemPrompt    String  @default("")
  isActive        Boolean @default(true)
  temperature     Float   @default(0.7)
  maxTokens       Int     @default(2048)
  customKnowledge String  @default("[]")
  learnedPatterns Int     @default(0)
  confidenceScore Float   @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, agentId])
  @@map("agent_configs")
}

// ===== AUDIT LOG =====
model AuditLog {
  id        String  @id @default(cuid())
  tenantId  String
  action    String
  details   String  @default("{}") // JSON
  ipAddress String?
  userAgent String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ===== LEADS (Prospecção Lessie AI + LIS) =====
model Lead {
  id              String  @id @default(cuid())
  tenantId        String
  empresa         String
  decisor         String  @default("")
  cargo           String  @default("")
  email           String  @unique
  whatsapp        String? // Removed @unique to avoid constraints violations on empty/null values, made optional
  setor           String  @default("hospitalidade")
  porte           String  @default("pequeno") // pequeno | medio | grande
  status          String  @default("pending") // pending | verified | contacted | converted | lost
  hook            String  @default("") // Script de e-mail/WhatsApp personalizado
  socialFootprint String  @default("{}") // JSON
  targetId        String?

  // Old/Legacy fields
  name         String  @default("")
  phone        String? // Removed @unique
  property     String?
  category     String? @default("pousada")
  city         String?
  state        String? @default("SC")
  region       String?
  googleRating Float?
  score        Int?    @default(0)
  painPoints   String?
  source       String  @default("SECRETARIA_AI")
  latitude     Float?
  longitude    Float?
  scoreValid   Int     @default(0)
  localPraia   String?
  observacoes  String?

  // DB Mirror / LIS / ZEHLA FISH Extensions
  isCanary              Boolean   @default(false)
  estimatedValues       String?
  intentSignals         String?
  location              String?
  phoneSecondary        String?
  qualification         String?
  socialMedia           String    @default("{}")
  site                  String?
  validationScore       Float     @default(0)
  validationStatus      String    @default("pendente")
  conversionScore       Int       @default(0)
  funnelStage           String    @default("NEUTRAL")
  lastInteractionAt     DateTime?
  behavioralProfile     String?
  cluster               String    @default("COLD")
  previousCluster       String?
  lastSwipeAction       String?
  lastSwipeUsedId       String?
  tierConfidence        Float?
  tierSugerido          String?
  tierSugeridoEm        DateTime?
  roomsCount            Int       @default(0)
  instagramFollowers    Int       @default(0)
  googleReviewsCount    Int       @default(0)
  otaCommissionLost     Float     @default(0.0)
  hasWebsite            Boolean   @default(false)
  otaDependenceLevel    String    @default("MEDIUM")
  buyingBehavior        String?
  conversionProbability Float     @default(0.0)
  objectKeywords        String?
  recommendedPitch      String?
  leadTier              String    @default("COLD")
  metadata              String    @default("{}") // JSON com dados extras

  // Tenant isolation
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  emailTrackings EmailTracking[]
  swipeUsages    SwipeUsage[]
  funnelEvents   FunnelEvent[]
  funnelScore    FunnelScore?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("leads")
}

// ===== EMAIL TRACKING =====
model EmailTracking {
  id         String   @id @default(cuid())
  leadId     String
  campaignId String?
  openedAt   DateTime @default(now())
  ip         String?
  userAgent  String?
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([campaignId])
  @@map("email_tracking")
}

// ===== TARGETS (Pousadas sob mira) =====
model Target {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  domain   String
  website  String?
  city     String  @default("")
  state    String  @default("")
  status   String  @default("active") // active | pending | inactive | prospected
  priority Int     @default(5) // 1-10

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, domain])
  @@index([tenantId])
  @@map("targets")
}

// ===== AGENT LOG (Ações da IA) =====
model AgentLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action    String
  status    String   @default("success") // success | error | timeout
  createdAt DateTime @default(now())

  // New ZEHLA fields
  agentId      String @default("lessie")
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  latencyMs    Int    @default(0)
  costUsd      Float  @default(0)
  errorMsg     String @default("")
  metadata     String @default("{}") // JSON

  // Old fields
  agentName  String?
  intent     String?
  confidence Float?
  input      String?
  output     String?
  tokensUsed Int     @default(0)
  cost       Float   @default(0)
  duration   Int     @default(0)

  @@index([agentName, createdAt])
  @@index([tenantId])
  @@map("agent_logs")
}

// ===== SECURITY ALERT =====
model SecurityAlert {
  id        String   @id @default(cuid())
  severity  String   @default("medium") // low | medium | high | critical
  createdAt DateTime @default(now())

  // New ZEHLA fields
  type        String? // injection | rls_violation | rate_limit | suspicious
  description String    @default("")
  source      String    @default("")
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?

  // Old fields
  tenantId  String?
  alertType String?
  metadata  String?

  @@index([tenantId, createdAt])
  @@index([severity, createdAt])
  @@map("security_alerts")
}

// ===== SWIPE TEMPLATE (Mensagens WhatsApp) =====
model SwipeTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String   @default("") // ZEHLA expects name
  title     String   @default("") // old expects title
  content   String
  variables String   @default("[]")
  category  String   @default("prospecção")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ZEHLA fields
  successRate Float @default(0)
  usageCount  Int   @default(0)

  // Old fields
  channel            String    @default("whatsapp")
  tone               String    @default("casual")
  tier               String    @default("universal")
  painType           String?
  tags               String    @default("[]")
  timesUsed          Int       @default(0)
  conversions        Int       @default(0)
  convRate           Float     @default(0)
  lastUsedAt         DateTime?
  isAiGenerated      Boolean   @default(false)
  provenByConversion Boolean   @default(false)
  createdBy          String?

  usages SwipeUsage[]

  @@index([tenantId])
  @@map("swipe_templates")
}

// ===== SWIPE USAGE =====
model SwipeUsage {
  id             String        @id @default(cuid())
  swipeId        String
  leadId         String
  wasUsed        Boolean
  converted      Boolean?
  agentId        String?
  responseTimeMs Int?
  feedback       String?
  createdAt      DateTime      @default(now())
  swipe          SwipeTemplate @relation(fields: [swipeId], references: [id], onDelete: Cascade)
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([swipeId, leadId])
  @@index([swipeId])
  @@index([leadId])
  @@index([converted])
  @@index([createdAt])
  @@map("swipe_usages")
}

// ===== CAMPAIGN (Orquestração multicanal) =====
model Campaign {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  type      String   @default("whatsapp") // whatsapp | email | ads | multi
  status    String   @default("draft") // draft | active | paused | completed | cancelled
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Tenant isolation
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // From new schema
  targetAudience  String    @default("all") // all | leads | verified | converted
  messageTemplate String    @default("")
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  totalDelivered  Int       @default(0)
  totalRead       Int       @default(0)
  totalReplied    Int       @default(0)
  metadata        String    @default("{}") // JSON

  // From old schema
  variant        String? // "financeira", "operacional", "ocupacao"
  totalSent      Int     @default(0)
  totalOpened    Int     @default(0)
  totalClicked   Int     @default(0)
  totalConverted Int     @default(0)
  openRate       Float   @default(0)
  clickRate      Float   @default(0)
  conversionRate Float   @default(0)

  // Relations
  events      FunnelEvent[]
  webhookLogs WebhookLog[]

  @@index([tenantId])
  @@map("campaigns")
}

// ===== TREND KEYWORD =====
model TrendKeyword {
  id                  String    @id @default(cuid())
  keyword             String    @unique
  category            String    @default("hotelaria")
  geo                 String?
  isActive            Boolean   @default(true)
  tier                String    @default("pro")
  checkFrequencyHours Int       @default(6)
  lastCheckedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // ZEHLA fields
  source String @default("google_trends")
  score  Float  @default(0)
  trend  String @default("stable")

  dataPoints TrendDataPoint[]

  @@map("trend_keywords")
}

// ===== TREND DATA POINT =====
model TrendDataPoint {
  id        String   @id @default(cuid())
  keywordId String
  date      DateTime
  source    String   @default("")
  createdAt DateTime @default(now())

  // New ZEHLA fields
  value Float @default(0)

  // Old fields
  interestScore Int     @default(0)
  interestDelta Float?
  volume        Int?
  geo           String?

  keyword TrendKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date, source])
  @@index([date])
  @@index([keywordId])
  @@map("trend_data_points")
}

// ===== TREND SIGNAL =====
model TrendSignal {
  id             String    @id @default(cuid())
  type           String
  keyword        String
  category       String
  interestScore  Int
  deltaPercent   Float
  severity       String    @default("media")
  geo            String?
  dateDetected   DateTime
  previousScore  Int?
  agentsNotified String    @default("[]")
  actionTaken    Boolean   @default(false)
  actionDetails  String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([type])
  @@index([severity])
  @@index([dateDetected])
  @@index([category])
  @@map("trend_signals")
}

// ===== ADAPTIVE FUNNEL — Event-Driven State Machine =====
model FunnelEvent {
  id          String    @id @default(cuid())
  leadId      String
  campaignId  String?
  type        String // email_opened, email_clicked, whatsapp_replied, lp_visited, ray-x_requested, trial_started, converted
  painCluster String? // financeira, operacional, ocupacao
  score       Int       @default(0)
  metadata    String? // JSON: ip, userAgent, utm, etc
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  @@index([leadId])
  @@index([campaignId])
  @@index([type])
  @@index([painCluster])
  @@index([createdAt])
  @@map("funnel_events")
}

model FunnelScore {
  id                String    @id @default(cuid())
  leadId            String    @unique
  totalScore        Int       @default(0)
  engagementScore   Int       @default(0)
  intentScore       Int       @default(0)
  fitScore          Int       @default(0)
  cluster           String    @default("COLD") // HOT, WARM, COLD
  painCluster       String? // financeira, operacional, ocupacao
  lastEventAt       DateTime?
  lastClusterChange DateTime?
  previousCluster   String?
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([cluster])
  @@index([painCluster])
  @@index([totalScore])
  @@map("funnel_scores")
}

model WebhookLog {
  id          String    @id @default(cuid())
  campaignId  String?
  source      String // resend, sendgrid, zapi, evolution, stripe, asaas
  eventType   String // opened, clicked, replied, delivered, bounced, paid, failed
  payload     String // JSON raw
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  retries     Int       @default(0)
  createdAt   DateTime  @default(now())
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  @@index([source])
  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_logs")
}

// ===== GUEST, RESERVATION & TRANSACTION (from backup and DDC) =====
model Guest {
  id                String    @id @default(cuid())
  tenantId          String
  name              String
  phone             String?
  email             String?
  document          String? // CPF/Passaporte
  status            String    @default("new") // new | warm | hot | booked | staying | checked_out | lost | inactive
  avatar            String?
  source            String    @default("whatsapp") // whatsapp | instagram | booking | airbnb | direct | referral
  value             Float     @default(0)
  lastContact       DateTime  @default(now())
  checkIn           DateTime?
  checkOut          DateTime?
  room              String?
  aiScore           Int       @default(50) // 0-100, lead quality score
  notes             String?
  conversationCount Int       @default(0)
  metadata          String    @default("{}") // JSON
  
  // Novos campos para LGPD e BSUID
  bsuid          String?   // Business Scoped User ID da Meta
  realPhone      String?   // Telefone real capturado
  realEmail      String?   // Email real capturado
  leadCapturedAt DateTime? // Data de captura de dados reais
  optInAt        DateTime? // Consentimento de marketing
  optInMethod    String?   // "whatsapp_cta" | "web_form" | "manual"
  optOutAt       DateTime? // Revogação do consentimento
  optOutMethod   String?   // NOVO v2 (finding 1.6): "keyword_whatsapp" | "web_form" | "manual" | "expiration"

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations  Reservation[]
  bookings      Booking[]
  messages      GuestMessage[]
  bsuidMappings BsuidMapping[]
  consentLogs   ConsentLog[] // NOVO: cascade de LGPD logs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // CORREÇÃO v2 — finding 3.1: chaves únicas compostas para upsert atômico.
  // Sem isto, findFirst+create em paralelo gera Guests duplicados (race condition).
  // resolveGuest() agora usa upsert por estas chaves.
  @@unique([tenantId, bsuid])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, source])
  @@index([bsuid])
  @@index([realPhone])
  @@index([realEmail])
  @@map("guests")
}

model Reservation {
  id         String   @id @default(cuid())
  tenantId   String
  guestId    String
  roomId     String
  checkIn    DateTime
  checkOut   DateTime
  status     String   @default("CONFIRMED") // PENDING, CONFIRMED, CHECKED_IN, CHECKED_OUT, CANCELLED
  totalPrice Float
  source     String   @default("DIRECT") // DIRECT, BOOKING, EXPEDIA
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guest  Guest  @relation(fields: [guestId], references: [id])
  room   Room   @relation(fields: [roomId], references: [id])

  transactions Transaction[]

  @@index([tenantId])
  @@index([guestId])
  @@index([roomId])
  @@map("reservations")
}

model Transaction {
  id            String   @id @default(cuid())
  tenantId      String
  reservationId String?
  type          String // PAYMENT, REFUND, CHARGE
  amount        Float
  method        String // PIX, CREDIT_CARD, CASH
  status        String   @default("COMPLETED")
  createdAt     DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@index([tenantId])
  @@index([reservationId])
  @@map("transactions")
}

// ===== ZAOS ROUTER STATE =====
model RouterProvider {
  id               String    @id @default(cuid())
  provider         String    @unique // openrouter | anthropic | ollama | groq | gemini
  modelName        String
  tier             String    @default("3") // 1=budget, 2=mid, 3=premium
  alpha            Float     @default(1.0) // Thompson Sampling Beta posterior
  beta             Float     @default(1.0)
  circuitStatus    String    @default("closed") // closed | half_open | open
  lastFailureAt    DateTime?
  failureCount     Int       @default(0)
  successCount     Int       @default(0)
  avgLatencyMs     Int       @default(0)
  costPer1kInput   Float     @default(0)
  costPer1kOutput  Float     @default(0)
  isActive         Boolean   @default(true)
  supportsJson     Boolean   @default(false)
  supportsTools    Boolean   @default(false)
  maxContextTokens Int       @default(8192)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("router_providers")
}

// ===== BUDGET GUARD STATE =====
model BudgetGuardState {
  id               String @id @default(cuid())
  date             String @unique // YYYY-MM-DD
  dailySpendUsd    Float  @default(0)
  dailyBudgetUsd   Float  @default(50)
  monthlySpendUsd  Float  @default(0)
  monthlyBudgetUsd Float  @default(1500)
  criticalLevel    String @default("nominal") // nominal | warning | critical

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("budget_guard_state")
}

// ===== LLM COST LOG =====
model CostLog {
  id           String   @id @default(cuid())
  tenantId     String?
  provider     String
  model        String
  inputTokens  Int
  outputTokens Int
  costUsd      Float
  tier         Int      @default(1)
  bucket       String   @default("general")
  cacheHit     Boolean  @default(false)
  latencyMs    Int      @default(0)
  circuitState String?
  budgetLevel  String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@index([provider])
  @@map("cost_logs")
}

// ===== MESSAGE (WhatsApp history) =====
model Message {
  id         String   @id @default(cuid())
  propertyId String
  direction  String // INBOUND | OUTBOUND
  content    String
  createdAt  DateTime @default(now())

  @@map("messages")
}

// ===== SUBSCRIPTION (Payment & Plan Management) =====
model Subscription {
  id                 String    @id @default(cuid())
  tenantId           String
  planType           String // gratuito | lite | pro | max | parceiro
  status             String    @default("pending") // pending | active | canceled | expired
  paymentMethod      String // pix | cartao
  amount             Float
  paymentId          String? // Mercado Pago/Stripe payment ID
  paymentStatus      String? // pending | approved | rejected | refunded
  checkoutUrl        String? // URL for payment checkout
  trialStart         DateTime?
  trialEnd           DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean   @default(false)
  lastProrateAmount  Float?
  lastProrateDate    DateTime?
  metadata           String    @default("{}")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscriptions")
}

// ===== PAYMENT TRANSACTION =====
model PaymentTransaction {
  id             String  @id @default(cuid())
  subscriptionId String
  amount         Float
  status         String // pending | approved | rejected | refunded
  paymentMethod  String // pix | cartao
  type           String?
  externalId     String? // Mercado Pago/Stripe transaction ID
  metadata       String  @default("{}") // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment_transactions")
}

// ===== GUEST MESSAGE =====
model GuestMessage {
  id        String   @id @default(cuid())
  guestId   String
  from      String // guest | ai | human
  content   String
  timestamp DateTime @default(now())
  type      String   @default("text") // text | image | audio | document
  sentiment String? // positive | neutral | negative
  intent    String? // booking | pricing | amenities | complaint
  metadata  String   @default("{}") // JSON

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([guestId])
  @@index([timestamp])
  @@map("guest_messages")
}

// ===== BOOKING (Reservas) =====
model Booking {
  id             String   @id @default(cuid())
  tenantId       String
  guestId        String?
  guestName      String
  roomName       String
  roomId         String?
  checkIn        DateTime
  checkOut       DateTime
  nights         Int
  guests         Int
  totalValue     Float
  status         String   @default("pending") // pending | confirmed | checked_in | checked_out | cancelled | no_show | blocked
  paymentMethod  String   @default("none") // pix | credit_card | debit_card | cash | bank_transfer | none
  paymentStatus  String   @default("pending") // pending | paid | partial | overdue | none
  source         String // whatsapp_ai | whatsapp_human | booking | airbnb | expedia | ical_import | direct
  aiGenerated    Boolean  @default(false)
  externalUid    String? // UID do evento iCal para deduplicação
  externalSource String? // booking | airbnb | expedia — OTA de origem do sync
  metadata       String   @default("{}") // JSON

  guest Guest? @relation(fields: [guestId], references: [id])
  room  Room?  @relation(fields: [roomId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, externalUid])
  @@index([tenantId, status])
  @@index([tenantId, checkIn])
  @@index([guestId])
  @@index([roomId])
  @@map("bookings")
}

// ===== AI ACTIVITY LOG =====
model AIActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  type      String // message | booking | escalation | learning | alert
  guestName String?
  roomName  String?
  message   String
  timestamp DateTime @default(now())
  status    String   @default("success") // success | warning | error | info
  duration  Int? // milliseconds
  metadata  String   @default("{}") // JSON

  createdAt DateTime @default(now())

  @@index([tenantId, timestamp])
  @@index([type])
  @@map("ai_activity_logs")
}

// ===== CONVERSATION LOG =====
model ConversationLog {
  id           String   @id @default(cuid())
  tenantId     String
  guestId      String
  guestName    String
  guestPhone   String
  status       String   @default("active") // active | resolved | escalated | abandoned
  lastUpdate   DateTime @default(now())
  aiConfidence Float    @default(0) // 0-100
  metadata     String   @default("{}") // JSON

  messages ConversationMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([guestId])
  @@map("conversation_logs")
}

// ===== CONVERSATION MESSAGE =====
model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  from           String // guest | ai | human
  content        String
  timestamp      DateTime @default(now())
  read           Boolean  @default(false)
  metadata       String   @default("{}") // JSON

  conversation ConversationLog @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@index([timestamp])
  @@map("conversation_messages")
}

// ===== KNOWLEDGE ENTRY =====
model KnowledgeEntry {
  id            String    @id @default(cuid())
  tenantId      String
  category      String // pricing | rooms | amenities | policies | location | activities | food | custom
  question      String
  answer        String
  priority      String    @default("medium") // low | medium | high | critical
  usage         Int       @default(0)
  effectiveness Float     @default(0) // 0-100
  createdFor    String    @default("both") // ai | human | both
  lastUsed      DateTime?
  /** TF-IDF embedding vector stored as JSON array of numbers */
  embeddingJson String    @default("[]")
  metadata      String    @default("{}") // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, category])
  @@index([priority])
  @@map("knowledge_entries")
}

// ===== TRAINING PROMPT =====
model TrainingPrompt {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  type        String // persona | response | escalation | proactive
  content     String
  variables   String    @default("[]") // JSON array
  isActive    Boolean   @default(true)
  successRate Float     @default(0) // 0-100
  usageCount  Int       @default(0)
  lastUsed    DateTime?
  metadata    String    @default("{}") // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, type])
  @@index([isActive])
  @@map("training_prompts")
}

// ===== NOTIFICATION =====
model Notification {
  id          String  @id @default(cuid())
  tenantId    String
  type        String // booking | payment | escalation | system | alert | achievement
  priority    String  @default("medium") // low | medium | high | urgent
  title       String
  message     String
  actionUrl   String?
  actionLabel String?
  read        Boolean @default(false)
  metadata    String  @default("{}") // JSON

  createdAt DateTime @default(now())

  @@index([tenantId, read])
  @@index([priority])
  @@index([createdAt])
  @@map("notifications")
}

// ===== PERFORMANCE METRICS SNAPSHOT =====
model PerformanceSnapshot {
  id                String @id @default(cuid())
  tenantId          String
  date              String // YYYY-MM-DD
  aiResponseTime    Float // avg seconds
  conversionRate    Float // percentage
  guestSatisfaction Float // 0-5
  occupancyRate     Float // percentage
  revenueGrowth     Float // percentage
  aiAutonomy        Float // percentage
  totalRevenue      Float
  totalBookings     Int
  aiConversations   Int
  metadata          String @default("{}") // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date])
  @@index([tenantId, date])
  @@map("performance_snapshots")
}

// ===== QUICK ACTION (Custom actions per tenant) =====
model QuickAction {
  id                   String  @id @default(cuid())
  tenantId             String
  category             String // booking | communication | analytics | settings | emergency
  label                String
  icon                 String
  action               String
  shortcut             String?
  requiresConfirmation Boolean @default(false)
  isActive             Boolean @default(true)
  order                Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, category])
  @@index([isActive])
  @@map("quick_actions")
}

// ===== FEEDBACK (Guest and admin ratings of AI messages) =====
model Feedback {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String // Relacionamento com logs de conversa
  messageId      String // ID da ConversationMessage avaliada
  rating         Int // Nota de 1 a 5 estrelas
  notes          String? // Comentário opcional do atendente
  source         String   @default("ddc") // ddc | whatsapp | auto
  metadata       String   @default("{}") // JSON
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([conversationId])
  @@index([messageId])
  @@index([tenantId, createdAt])
  @@map("feedbacks")
}

// ===== ZELLADOR MESSAGE (Conversas do Gerente de Treinamento IA) =====
model ZelladorMessage {
  id             String  @id @default(cuid())
  tenantId       String
  conversationId String // Agrupa mensagens da mesma sessão de chat
  role           String // user | assistant
  content        String
  blocked        Boolean @default(false) // true se a mensagem foi bloqueada por segurança
  blockReason    String? // Motivo do bloqueio (injection, output_filtered, etc.)

  createdAt DateTime @default(now())

  @@index([tenantId, conversationId])
  @@index([conversationId, createdAt])
  @@map("zellador_messages")
}

// ===== CALENDAR SYNC (iCal Integration) =====
model CalendarSync {
  id           String    @id @default(cuid())
  tenantId     String
  roomId       String
  otaName      String // booking | airbnb | expedia
  syncUrl      String
  syncToken    String    @unique // hash SHA-256 público para acesso ao feed iCal
  lastSync     DateTime?
  status       String    @default("active") // active | error | paused
  errorMessage String    @default("")
  syncCount    Int       @default(0)
  metadata     String    @default("{}") // JSON

  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, otaName]) // Um canal por quarto
  @@index([tenantId, status]) // Busca eficiente por tenant
  @@map("calendar_syncs")
}

// ===== BSUID MAPPING =====
model BsuidMapping {
  id        String   @id @default(cuid())
  bsuid     String   @unique // Business Scoped User ID da Meta
  guestId   String
  createdAt DateTime @default(now())

  guest Guest @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([guestId])
  @@map("bsuid_mappings")
}

// ===== CONSENT LOG =====
// CORREÇÃO v2 — finding 1.6: adicionadas relações com Tenant e Guest (cascade).
// Antes: tenantId e guestId eram apenas strings soltas, sem integridade referencial.
// Agora: Tenant deletado → ConsentLogs deletados (LGPD "direito ao esquecimento" controlado).
//        Guest deletado → ConsentLogs deletados.
model ConsentLog {
  id        String   @id @default(cuid())
  tenantId  String
  guestId   String
  type      String   // "opt_in" | "opt_out"
  channel   String   // "whatsapp" | "web" | "manual"
  ip        String?
  userAgent String?
  evidence  String   @default("{}") // Payload original / texto
  createdAt DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guest     Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([tenantId, guestId])
  @@index([type])
  @@map("consent_logs")
}

// ===== META COST LOG =====
model MetaCostLog {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String
  messageId      String?
  guestId        String?
  costUsd        Float
  messageType    String   // "service_reply" | "marketing_template" | "utility_template"
  intent         String?  // "cotacao_reserva" | "suporte" | "info_geral" etc.
  metadata       String   @default("{}") // JSON: response_tokens, provider, latency
  createdAt      DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([conversationId])
  @@map("meta_cost_logs")
}

// ===== LINK-IN-BIO LINK =====
model LinkInBioLink {
  id          String @id @default(cuid())
  propertyId  String
  label       String
  url         String
  icon        String @default("🔗")
  isHighlight Boolean @default(false)
  order       Int    @default(0)
  isActive    Boolean @default(true)

  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@map("linkinbio_links")
}

// ===== ZÉLLA AIRB — Airbnb Property Management =====

model AirBProperty {
  id              String   @id @default(cuid())
  tenantId        String
  airbnbId        String?              // Airbnb listing ID (e.g. "18584298")
  airbnbUrl       String?              // Full Airbnb URL
  name            String               // Property title from Airbnb
  description     String   @default("")
  propertyType    String   @default("apartment") // apartment | house | loft | studio | chalet | villa
  city            String   @default("")
  state           String   @default("")
  neighborhood    String   @default("")
  address         String   @default("")
  latitude        Float?              // Geolocation
  longitude       Float?              // Geolocation
  bedrooms        Int      @default(1)
  bathrooms       Int      @default(1)
  maxGuests       Int      @default(2)
  amenities       String   @default("[]")       // JSON array of amenities
  houseRules      String   @default("[]")       // JSON array of house rules
  checkinTime     String   @default("15:00")
  checkoutTime    String   @default("11:00")
  wifiName        String?
  wifiPassword    String?
  lockProvider    String?              // smartlock provider
  lockCode        String?              // smartlock code
  hostKnowledge   String   @default("[]")       // JSON: host tips & knowledge
  neighborhoodTips String  @default("[]")       // JSON: nearby tips
  emergencyContacts String  @default("[]")      // JSON: emergency contacts
  imageUrl        String?              // Main property image
  pricePerNight   Float?
  currency        String   @default("BRL")
  status          String   @default("active")   // active | inactive | suspended | scraping_pending | scraping_failed
  scrapedAt       DateTime?            // When data was last scraped from Airbnb
  scrapingSource  String?              // "api" | "ai_extractor" | "manual"

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations   AirBConversation[]
  regionalKnowledge AirBRegionalKnowledge[]
  scrapingJobs    AirBScrapingJob[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([airbnbId])
  @@map("airb_properties")
}

model AirBConversation {
  id              String   @id @default(cuid())
  tenantId        String
  propertyId      String
  guestName       String
  guestPhone      String?
  guestBsuid      String?              // Meta BSUID mapping
  platformContext String   @default("unknown") // airbnb_app | airbnb_web | direct | whatsapp | unknown
  mode            String   @default("post_booking") // pre_booking | post_booking
  status          String   @default("active")  // active | resolved | escalated
  lastIntent      String?              // Last detected intent
  lastMessageAt   DateTime?
  messageCount    Int      @default(0)

  property        AirBProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  messages        AirBMessage[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@map("airb_conversations")
}

model AirBMessage {
  id              String   @id @default(cuid())
  conversationId  String
  direction       String   // "inbound" | "outbound"
  content         String
  intent          String?  // Detected intent
  isAiGenerated   Boolean  @default(true)
  costUsd         Float?   // WhatsApp message cost

  conversation    AirBConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("airb_messages")
}

// ===== Zélla AirB — Regional Knowledge =====
model AirBRegionalKnowledge {
  id            String   @id @default(cuid())
  tenantId      String
  propertyId    String
  category      String   // beach | bakery | pharmacy | supermarket | tourism | restaurant | hospital | transport | atm | leisure | other
  name          String
  distance      Float?   // distance in km
  walkingTimeMin Int?    // walking time in minutes
  drivingTimeMin Int?    // driving time in minutes
  address       String?
  rating        Float?   // 1.0-5.0
  googlePlaceId String?
  description   String?
  embeddingId   String?  // Reference to vector DB embedding (for future pgvector migration)

  property      AirBProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([propertyId])
  @@index([category])
  @@map("airb_regional_knowledge")
}

// ===== Zélla AirB — Scraping Jobs =====
model AirBScrapingJob {
  id              String   @id @default(cuid())
  tenantId        String
  propertyId      String?  // Null until property is created from scrape
  airbnbUrl       String
  status          String   @default("queued") // queued | running | completed | failed | cancelled
  result          String?  // JSON string of scraped data
  error           String?
  retryCount      Int      @default(0)
  maxRetries      Int      @default(3)
  idempotencyKey  String   @unique
  scrapingSource  String?  // api | headless | ai_extractor | manual

  property        AirBProperty? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  scheduledAt     DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([idempotencyKey])
  @@map("airb_scraping_jobs")
}

// ===== Zélla AirB — Subscriptions =====
model AirBSubscription {
  id                  String   @id @default(cuid())
  tenantId            String
  planType            String   // airb_lite | airb_pro | airb_max
  status              String   @default("active") // active | past_due | cancelled | expired
  propertyLimit       Int      // LITE=2, PRO=4, MAX=12
  currentPropertyCount Int     @default(0) // Denormalized for fast queries
  amount              Float    // 397.0 (PRO) | 797.0 (MAX)
  paymentMethod       String?  // pix | cartao
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)

  tenant              Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions        AirBTransaction[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
  @@map("airb_subscriptions")
}

// ===== Zélla AirB — Transactions =====
model AirBTransaction {
  id              String   @id @default(cuid())
  tenantId        String
  propertyId      String?
  subscriptionId  String?
  type            String   // subscription_payment | refund | adjustment
  amount          Float
  status          String   @default("pending") // pending | approved | rejected | refunded
  externalId      String?  // Mercado Pago payment ID
  description     String?

  subscription    AirBSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([subscriptionId])
  @@map("airb_transactions")
}

// ===== ZCC ACCESS LOG =====
model ZCCAccessLog {
  id        String   @id @default(cuid())
  ip        String
  userAgent String?
  method    String   // godmode_param | godmode_cookie | master_key_header | nextauth_admin | failed
  success   Boolean
  country   String?  // for future geo-IP
  requestId String?
  createdAt DateTime @default(now())

  @@index([method])
  @@index([success])
  @@index([createdAt])
  @@map("zcc_access_logs")
}

// ===== WHATSAPP MESSAGE COST =====
model WhatsAppMessageCost {
  id              String   @id @default(cuid())
  tenantId        String
  direction       String   // inbound | outbound
  messageTemplate String?  // WhatsApp template category
  costUsd         Float    @default(0.0068) // US$0.0068 per service message (Meta 2026 tariff)
  costBrl         Float?   // cached BRL equivalent
  bundled         Boolean  @default(false) // was this message bundled?
  bundleId        String?  // reference to MessageBundle
  conversationId  String?  // WhatsApp conversation ID
  aiGenerated     Boolean  @default(false)
  intent          String?  // detected intent
  oneShot         Boolean  @default(false) // was this a one-shot resolution?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@index([bundleId])
  @@map("whatsapp_message_costs")
}

// ===== MESSAGE BUNDLE =====
model MessageBundle {
  id                   String    @id @default(cuid())
  tenantId             String
  originalMessageCount Int       // number of messages that were bundled
  finalMessageCount    Int       @default(1) // after bundling (always 1)
  savingsUsd           Float     // cost saved by bundling
  bufferMs             Int       @default(3000) // buffer time in milliseconds
  status               String    @default("completed") // pending | completed | expired
  createdAt            DateTime  @default(now())
  completedAt          DateTime?

  @@index([tenantId])
  @@index([status])
  @@map("message_bundles")
}

// ===== CONSENT RECORD =====
model ConsentRecord {
  id          String    @id @default(cuid())
  tenantId    String
  guestPhone  String    // WhatsApp number of the guest
  consentType String    // whatsapp_communication | data_processing | marketing
  status      String    // granted | denied | pending | withdrawn
  source      String    // whatsapp_opt_in | ddc_checkbox | link_in_bio | admin_manual
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime? // consent expiration
  withdrawnAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, guestPhone, consentType])
  @@index([tenantId])
  @@index([guestPhone])
  @@index([status])
  @@map("consent_records")
}

// ===== AIRBNB WEBHOOK EVENT =====
model AirbnbWebhookEvent {
  id                   String    @id @default(cuid())
  tenantId             String
  eventType            String    // reservation.created | reservation.updated | reservation.cancelled | listing.updated | review.posted
  airbnbReservationId  String?
  airbnbListingId      String?
  payload              String    // JSON string with full event data
  processed            Boolean   @default(false)
  processedAt          DateTime?
  mockTriggered        Boolean   @default(false) // was this triggered by ZCC mock button?
  createdAt            DateTime  @default(now())

  @@index([tenantId])
  @@index([eventType])
  @@index([processed])
  @@map("airbnb_webhook_events")
}

// ===== AIRBNB OAUTH TOKEN =====
model AirbnbOAuthToken {
  id          String   @id @default(cuid())
  tenantId    String
  accessToken String
  refreshToken String?
  tokenType   String   @default("Bearer")
  expiresIn   Int      // seconds until expiration
  scope       String?  // comma-separated scopes
  isMock      Boolean  @default(true) // flag to identify mock tokens
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("airbnb_oauth_tokens")
}

// ===== DYNAMIC PRICING RULE (Precificação Dinâmica) =====
model DynamicPricingRule {
  id            String    @id @default(cuid())
  tenantId      String
  name          String    // "Feriado Nacional", "Alta Season Ubatuba", etc.
  type          String    @default("seasonal") // seasonal | holiday | demand | event | occupancy
  status        String    @default("active") // active | paused | archived

  // Condições de aplicação
  startDate     DateTime? // início da regra (null = sempre ativa)
  endDate       DateTime? // fim da regra
  minOccupancy  Float     @default(0) // % mínima de ocupação para trigger (0 = qualquer)
  maxOccupancy  Float     @default(100) // % máxima de ocupação
  daysOfWeek    String    @default("[]") // JSON: [0,1,2,3,4,5,6] — dias da semana (0=dom)
  minDaysBefore Int       @default(0) // mínimo dias antes do check-in para aplicar

  // Ação de precificação
  modifierType  String    @default("multiplier") // multiplier | fixed | percent_increase | percent_decrease
  modifierValue Float     // 1.5 = 50% aumento (multiplier), 250 = R$250 fixo (fixed), 30 = +30% (percent_increase)
  minPrice      Float?    // preço mínimo absoluto (floor)
  maxPrice      Float?    // preço máximo absoluto (cap)
  priority      Int       @default(0) // maior = aplicado primeiro

  // Resultados
  appliedCount  Int       @default(0) // quantas vezes foi aplicada
  revenueImpact Float     @default(0) // R$ gerados por esta regra

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([startDate, endDate])
  @@map("dynamic_pricing_rules")
}

// ===== PRICING CALCULATION (Precificação Dinâmica — Cache) =====
model PricingCalculation {
  id                String    @id @default(cuid())
  tenantId          String
  roomId            String?
  airbPropertyId    String?   // para Airbnb properties
  date              DateTime  // data da diária calculada
  basePrice         Float     // preço base (original do quarto)
  calculatedPrice   Float     // preço final após todas regras
  modifierBreakdown String    @default("[]") // JSON: [{ruleId, ruleName, modifierType, modifierValue, priceBefore, priceAfter}]
  occupancyAtCalc   Float     @default(0) // ocupação na data do cálculo
  daysBeforeCheckIn Int       @default(0) // dias antes do check-in
  appliedRulesCount Int       @default(0) // quantas regras foram aplicadas
  createdAt         DateTime  @default(now())

  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, roomId, date])
  @@index([tenantId, date])
  @@index([tenantId, roomId])
  @@map("pricing_calculations")
}

// ===== GUEST GUIDE (Guia Digital do Hóspede) =====
model GuestGuide {
  id            String    @id @default(cuid())
  tenantId      String
  airbPropertyId String?  // se for guia de Airbnb property
  propertyId    String?   // se for guia de Property (pousada)
  slug          String    @unique // URL slug público (ex: "praia-grande-5g")
  title         String    // "Guia do Hóspede — Apt Praia Grande"
  welcomeMessage String   @default("") // mensagem de boas-vindas personalizada
  status        String    @default("active") // active | draft | archived
  viewCount     Int       @default(0) // quantas vezes o guia foi acessado
  lastViewedAt  DateTime?
  qrCodeUrl     String?   // URL do QR Code gerado

  // Seções do guia (JSON ordenado)
  sections      String    @default("[]") // JSON: [{type, title, items}] — tipos: essentials, wifi, checkin, checkout, rules, restaurants, supermarkets, attractions, emergency, transport, faq

  // Auto-gerado a partir de dados do imóvel?
  autoGenerated Boolean   @default(false)
  generatedAt   DateTime?

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([slug])
  @@map("guest_guides")
}

// ===== BOOKING.COM SYNC CONFIG =====
model BookingSyncConfig {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String?   // Property para pousada
  airbPropertyId  String?   // AirBProperty para Airbnb
  hotelId         String?   // Booking.com Hotel ID
  icalExportUrl   String?   // URL iCal export (generated by us)
  icalImportUrl   String?   // URL iCal import from Booking.com
  syncToken       String    @unique // hash SHA-256 público para acesso ao feed iCal
  status          String    @default("pending") // pending | connected | error | disconnected
  lastSync        DateTime?
  syncCount       Int       @default(0)
  bookingsImported Int      @default(0) // reservas importadas do Booking.com
  bookingsExported Int      @default(0) // reservas exportadas para Booking.com
  errorMessage    String    @default("")
  metadata        String    @default("{}") // JSON: booking.com config data

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, propertyId])
  @@unique([tenantId, airbPropertyId])
  @@index([tenantId, status])
  @@map("booking_sync_configs")
}

// ===== NEXTAUTH ADAPTER MODELS =====
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// CÉREBRO ZÉLLA — ENTIDADE AUTÔNOMA (GLM 5.2 SUPERVISOR)
// ============================================================================
// 5 models para a entidade orquestradora que supervisiona o próprio sistema.
// Implementada em "modo mock" por padrão — integrações de IA, Redis e canais
// externos só ativam quando env vars específicas são configuradas.
// ============================================================================

/// Análise contextual produzida pelo GlmCerebroService após examinar logs,
/// anomalias ou contexto financeiro. Cada análise é uma invocação do GLM 5.2
/// que retorna summary + severity + recommended_action.
model CerebroAnalysis {
  id            String   @id @default(cuid())
  /// Tipo da análise: "anomaly_scan" | "budget_forecast" | "security_audit" | "refactor_suggestion" | "inadimplencia_check"
  analysisType  String
  /// Escopo: "global" | "tenant:<id>" | "module:<name>" | "route:<path>"
  scope         String
  /// Resumo de 1 frase (LLM output)
  summary       String
  /// JSON completo com detalhes da análise (input events, LLM response, recommended_action)
  details       String   @default("{}")
  /// Severidade: "info" | "warning" | "critical" | "emergency"
  severity      String   @default("info")
  /// Ação tomada automaticamente: "alert_sent" | "tenant_suspended" | "none"
  actionTaken   String?
  /// Custo LLM desta análise em USD (para FinOps do próprio Cérebro)
  costUsd       Float    @default(0)
  /// Modo: "mock" | "live" — indica se a análise usou LLM real ou dados sintéticos
  mode          String   @default("mock")
  createdAt     DateTime @default(now())

  /// FK opcional para AlertDelivery (se gerou alerta)
  alerts        AlertDelivery[]

  @@index([analysisType, createdAt])
  @@index([severity, createdAt])
  @@index([scope, createdAt])
  @@map("cerebro_analyses")
}

/// Evento de anomalia detectado pelo AnomalyDetector (estatístico, sem LLM).
/// Um AnomalyEvent pode disparar uma CerebroAnalysis se for classificado como
/// merecedor de investigação profunda pelo GLM 5.2.
model AnomalyEvent {
  id              String   @id @default(cuid())
  /// Tipo: "error_spike" | "latency_degradation" | "cost_anomaly" | "auth_failure_pattern" | "tenant_under_attack" | "webhook_throughput_burst"
  anomalyType     String
  /// Escopo: "global" | tenant ID | route path | module name
  scope           String
  /// Métrica observada: "error_rate" | "p99_latency_ms" | "cost_usd_per_hour" | "auth_failures_per_min"
  metric          String
  /// Valor observado no momento da detecção
  observed        Float
  /// Valor esperado (média móvel 7 dias ou baseline estatístico)
  baseline        Float
  /// Desvio normalizado: (observed - baseline) / baseline. >3 = anomalia
  deviation       Float
  /// Detecção foi por threshold hard (regra) ou estatística (3σ)?
  detectionMethod String   @default("statistical") // "statistical" | "threshold"
  detectedAt      DateTime @default(now())
  /// Foi acknowledge por humano?
  acknowledged    Boolean  @default(false)
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  /// Notas do admin (ex: "falso positivo — manutenção programada")
  acknowledgeNotes String?

  @@index([anomalyType, detectedAt])
  @@index([scope, detectedAt])
  @@index([acknowledged, detectedAt])
  @@map("anomaly_events")
}

/// Sugestão de refatoração proposta pelo GLM 5.2 após detectar erro recorrente.
/// Status "pending_review" por padrão — humano decide se aplica.
model RefactorSuggestion {
  id              String   @id @default(cuid())
  /// Hash do erro recorrente que motivou a sugestão (stack trace hash)
  sourceErrorHash  String
  /// Caminho do arquivo: ex "src/lib/bsuid-resolver.ts"
  filePath        String
  /// Range de linhas: ex "45-80"
  lineRange        String
  /// Trecho atual do código (para diff visual)
  currentCode      String
  /// Código proposto pelo GLM 5.2
  proposedCode     String
  /// Justificativa da mudança (LLM racional)
  rationale        String
  /// Status do review humano
  status          String   @default("pending_review") // "pending_review" | "approved" | "rejected" | "applied"
  /// Confiança do LLM (0-1)
  confidence      Float
  /// Notas do revisor humano
  reviewNotes      String?
  /// Modo: "mock" | "live"
  mode            String   @default("mock")
  createdAt       DateTime @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?

  @@index([status, createdAt])
  @@index([filePath])
  @@index([sourceErrorHash])
  @@map("refactor_suggestions")
}

/// Audit de envio de alertas pelo AlertBus. Cada alerta enviado (email, Slack,
/// SMS, dashboard) gera uma entrada aqui para rastreabilidade.
model AlertDelivery {
  id            String   @id @default(cuid())
  /// FK opcional para CerebroAnalysis que motivou o alerta
  analysisId    String?
  /// Canal: "email" | "slack" | "sms" | "dashboard" | "webhook"
  channel       String
  /// Destinatário: email, webhook URL, ou phone number
  recipient     String
  subject       String
  body          String
  /// Status: "queued" | "sent" | "failed" | "delivered"
  status        String   @default("queued")
  /// Modo: "mock" | "live"
  mode          String   @default("mock")
  sentAt        DateTime?
  deliveredAt   DateTime?
  errorMessage  String?
  createdAt     DateTime @default(now())

  /// Relation opcional para CerebroAnalysis
  analysis      CerebroAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([channel, createdAt])
  @@map("alert_deliveries")
}

/// Base de conhecimento RAG para o RefactorSuggester. Em produção, contém
/// embeddings de trechos de código do repo (indexados em build time).
/// Em modo mock, apenas armazena texto sem embedding (busca por substring).
model KnowledgeChunk {
  id            String   @id @default(cuid())
  /// Origem: "github" | "error_log" | "refactor_applied" | "docs"
  source        String
  /// Referência: commit SHA, error hash, ou doc URL
  sourceRef     String
  /// Caminho do arquivo (se aplicável)
  filePath      String?
  /// Conteúdo: trecho de código ou descrição
  content       String
  /// Embedding em JSON: array de floats. Em mock mode fica "[]" (vazio).
  embedding     String   @default("[]")
  /// Metadata JSON: { startLine, endLine, language, tags }
  metadata      String   @default("{}")
  createdAt     DateTime @default(now())

  @@index([source, createdAt])
  @@index([filePath])
  @@map("knowledge_chunks")
}

// ============================================================================
// CÉREBRO ZÉLLA — AUDIT LOG PERSISTENTE (Passo 10 Hardening)
// ============================================================================
// Antes: audit log em Map em memória (perdia em cold start Vercel)
// Agora: persistido em DB para auditoria completa e sobrevivência entre lambdas
// ============================================================================

/// Audit log do ZCC Security Gate V3 — registra toda tentativa de acesso
/// (autorizada ou negada) às rotas /api/zcc/* para compliance e detecção
/// de tentativas de invasão.
model ZccAuditLog {
  id            String   @id @default(cuid())
  /// Timestamp ISO do evento
  timestamp     DateTime @default(now())
  /// IP de origem (X-Forwarded-For ou X-Real-IP)
  ip            String
  /// User-Agent (truncado para 200 chars)
  userAgent     String   @default("")
  /// Método de auth usado: "header" | "param" | "cookie" | "session" | "denied"
  method        String
  /// Sucesso da tentativa
  success       Boolean
  /// Path acessado: /api/zcc/...
  path          String
  /// Notas adicionais (ex: "rate_limited", "nonce_expired")
  notes         String?
  /// ID do deploy (Vercel) para correlação
  deploymentId  String?

  @@index([ip, timestamp])
  @@index([success, timestamp])
  @@index([path, timestamp])
  @@map("zcc_audit_logs")
}

// ============================================================================
// CÉREBRO ZÉLLA — TELEMETRY EVENTS PERSISTENTES (Passo 10 Hardening)
// ============================================================================
// Antes: telemetry-store.ts em ring buffer in-memory (10k eventos, perdidos em cold start)
// Agora: persistido em DB com TTL via cron de cleanup (7 dias)
// ============================================================================

/// Eventos de telemetria persistidos para análise histórica de performance,
/// anomalias e auditoria. Substitui o ring buffer in-memory do telemetry-store.ts.
model CerebroTelemetryEvent {
  id            String   @id @default(cuid())
  /// Tipo: "request" | "error" | "anomaly" | "alert" | "llm_call" | "webhook" | "cron"
  type          String
  /// Nome do evento (ex: "request.duration", "llm_call.complete")
  name          String
  /// Módulo de origem (ex: "whatsapp-webhook", "glm-cerebro", "anomaly-detector")
  module        String
  /// Severity: "info" | "warn" | "error" | "critical"
  severity      String   @default("info")
  /// Mensagem human-readable
  message       String
  /// Contexto estruturado (JSON: tenantId, latencyMs, costUsd, etc)
  context       String   @default("{}")
  /// Tenant ID se aplicável (para correlação cross-tenant)
  tenantId      String?
  /// Timestamp do evento
  timestamp     DateTime @default(now())
  /// ID do deploy (Vercel) para correlação
  deploymentId  String?

  @@index([type, timestamp])
  @@index([module, timestamp])
  @@index([severity, timestamp])
  @@index([tenantId, timestamp])
  @@map("cerebro_telemetry_events")
}

{  
  "$schema": "https://openapi.vercel.sh/vercel.json",  
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npx prisma generate && DATABASE_URL=\"file:./dev.db\" NEXTAUTH_SECRET=\"zehla-demo-secret-2026-prod\" NEXTAUTH_URL=\"https://smart-hotel-zehla.vercel.app\" next build",

  "regions": ["gru1"],  
  "headers": [  
    {  
      "source": "/api/(.*)",  
      "headers": [  
        {  
          "key": "Cache-Control",  
          "value": "no-store, max-age=0, must-revalidate"  
        }  
      ]  
    },  
    {  
      "source": "/(.*)\\.(ico|png|jpg|jpeg|svg|webp|woff2)",  
      "headers": [  
        {  
          "key": "Cache-Control",  
          "value": "public, max-age=31536000, immutable"  
        }  
      ]  
    }  
  ],  
  "rewrites": [],  
  "crons": [  
    {  
      "path": "/api/cron/budget-reset",  
      "schedule": "0 0 * * *"  
    },  
    {  
      "path": "/api/cron/metrics-snapshot",  
      "schedule": "0 6 * * *"  
    }  
  ]  
}

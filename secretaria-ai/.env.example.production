# ==============================================================================  
# ZEHLA SmartHotel — Variáveis de Ambiente PRODUÇÃO  
# ==============================================================================  
# Use este arquivo como referencia para configurar o ambiente de produção  
# na Vercel e Railway. TODOS OS VALORES DEVEM SER SUBSTITUÍDOS POR REAIS.  
# ==============================================================================

# ===== DATABASE (Produção — Vercel Postgres recomendado) =====  
DATABASE_URL="PROVIDE_REAL_DATABASE_URL"

# ===== NEXTAUTH (Produção) =====  
NEXTAUTH_URL="https://zehla.com.br"  
NEXTAUTH_SECRET="PROVIDE_REAL_NEXTAUTH_SECRET"

# ===== MERCADO PAGO (Produção) =====  
MP_ACCESS_TOKEN="PROVIDE_REAL_MP_ACCESS_TOKEN"  
MP_WEBHOOK_URL="https://zehla.com.br/api/checkout/webhook"

# ===== WHATSAPP CLOUD API (Produção) =====  
WHATSAPP_VERIFY_TOKEN="PROVIDE_REAL_VERIFY_TOKEN"  
WHATSAPP_PHONE_NUMBER_ID="PROVIDE_REAL_PHONE_NUMBER_ID"  
WHATSAPP_ACCESS_TOKEN="PROVIDE_REAL_ACCESS_TOKEN"  
WHATSAPP_BUSINESS_ACCOUNT_ID="PROVIDE_REAL_BUSINESS_ACCOUNT_ID"

# ===== Z.AI SDK =====  
ZAI_API_KEY="PROVIDE_REAL_ZAI_SDK_KEY"

# ===== SOCKET.IO REALTIME (Railway Production) =====  
NEXT_PUBLIC_SOCKET_URL="https://zehla-realtime-production.up.railway.app"

# ===== AI PROVIDERS (Produção) =====
DEEPSEEK_API_KEY="PROVIDE_REAL_DEEPSEEK_API_KEY"
ZHIPU_API_KEY="PROVIDE_REAL_ZHIPU_API_KEY"
MOONSHOT_API_KEY="PROVIDE_REAL_MOONSHOT_API_KEY"
UPSTASH_REDIS_REST_URL="PROVIDE_REAL_UPSTASH_URL"
UPSTASH_REDIS_REST_TOKEN="PROVIDE_REAL_UPSTASH_TOKEN"
BATCH_API_ENABLED="false"

# ===== GOOGLE OAUTH (Produção) =====  
GOOGLE_CLIENT_ID="PROVIDE_REAL_GOOGLE_CLIENT_ID"  
GOOGLE_CLIENT_SECRET="PROVIDE_REAL_GOOGLE_CLIENT_SECRET"

# ==============================================================================  
# VARIÁVEIS DO RAILWAY (realtime-service — PRODUÇÃO)  
# ==============================================================================  
# Configure no dashboard do Railway (Production environment):  
# PORT=3005  
# CORS_ORIGINS=https://zehla.com.br

# ==============================================================================  
# DNS & SSL  
# ==============================================================================  
# CNAME  zehla.com.br     → cname.vercel-dns.com  
# CNAME  www.zehla.com.br → cname.vercel-dns.com  
# SSL é automático via Vercel (Let's Encrypt)

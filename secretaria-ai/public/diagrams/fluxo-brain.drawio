<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram name="Fluxo do Brain" id="brain-flow">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Input -->
        <mxCell id="input" value="📨 Mensagem do Hóspede" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e94560;fontColor=#ffffff;strokeColor=#c23152;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="200" height="50" as="geometry"/>
        </mxCell>

        <!-- Pipeline container -->
        <mxCell id="pipeline" value="&lt;b&gt;PIPELINE DO CÉREBRO ZÉLLA&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#1b4332;fontColor=#ffffff;strokeColor=#0d1f14;startSize=30;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="980" height="620" as="geometry"/>
        </mxCell>

        <!-- Step 1: Classifier -->
        <mxCell id="step1" value="1️⃣ Intent Classifier&#10;Classifica intenção do hóspede" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2d6a4f;fontColor=#ffffff;strokeColor=#1b4332;arcSize=10;" vertex="1" parent="pipeline">
          <mxGeometry x="60" y="50" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Step 2: Context -->
        <mxCell id="step2" value="2️⃣ Context Discretizer&#10;Categoriza em buckets de contexto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#40916c;fontColor=#ffffff;strokeColor=#2d6a4f;arcSize=10;" vertex="1" parent="pipeline">
          <mxGeometry x="370" y="50" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Arrow 1->2 -->
        <mxCell id="arrow-1-2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#52b788;strokeWidth=2;" edge="1" parent="pipeline" source="step1" target="step2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 3: Thompson Sampling -->
        <mxCell id="step3" value="3️⃣ Thompson Sampling&#10;Seleciona melhor provedor LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#52b788;fontColor=#ffffff;strokeColor=#40916c;arcSize=10;" vertex="1" parent="pipeline">
          <mxGeometry x="680" y="50" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- Arrow 2->3 -->
        <mxCell id="arrow-2-3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#52b788;strokeWidth=2;" edge="1" parent="pipeline" source="step2" target="step3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Guard rails -->
        <mxCell id="guard-circuit" value="🔒 Circuit Breaker&#10;Provedor saudável?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f48c06;fontColor=#000000;strokeColor=#dc2f02;arcSize=10;dashed=1;" vertex="1" parent="pipeline">
          <mxGeometry x="60" y="180" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="guard-budget" value="💰 Budget Guard&#10;Orçamento disponível?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f48c06;fontColor=#000000;strokeColor=#dc2f02;arcSize=10;dashed=1;" vertex="1" parent="pipeline">
          <mxGeometry x="300" y="180" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="guard-cache" value="⚡ Semantic Cache&#10;Já respondida antes?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f48c06;fontColor=#000000;strokeColor=#dc2f02;arcSize=10;dashed=1;" vertex="1" parent="pipeline">
          <mxGeometry x="540" y="180" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- Cache Hit -->
        <mxCell id="cache-hit" value="✅ Cache Hit!&#10;Retorna resposta salva" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e9c46a;fontColor=#000000;strokeColor=#d4a373;" vertex="1" parent="pipeline">
          <mxGeometry x="780" y="180" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- LLM Providers -->
        <mxCell id="llm-providers" value="🤖 LLM PROVIDERS&#10;━━━━━━━━━━━━━━&#10;Tier 1: Ollama (Local - Grátis)&#10;Tier 2: Groq / Gemini Flash (Médio)&#10;Tier 3: GPT-4o / Claude (Premium)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#370617;fontColor=#ffffff;strokeColor=#24040e;" vertex="1" parent="pipeline">
          <mxGeometry x="60" y="300" width="300" height="120" as="geometry"/>
        </mxCell>

        <!-- Arrow guards -> LLM -->
        <mxCell id="arrow-guard-llm" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.4;exitY=1;entryX=0.3;entryY=0;strokeColor=#f48c06;strokeWidth=1;dashed=1;" edge="1" parent="pipeline" source="guard-cache" target="llm-providers">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Response Processing -->
        <mxCell id="response-process" value="🔄 Processamento da Resposta&#10;━━━━━━━━━━━━━━&#10;• Persona WhatsApp&#10;• PII Sanitizer&#10;• Receipt Extractor&#10;• Security Guard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#533483;fontColor=#ffffff;strokeColor=#3d2460;" vertex="1" parent="pipeline">
          <mxGeometry x="500" y="300" width="280" height="120" as="geometry"/>
        </mxCell>

        <!-- Arrow LLM -> Response -->
        <mxCell id="arrow-llm-resp" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;strokeColor=#52b788;strokeWidth=2;" edge="1" parent="pipeline" source="llm-providers" target="response-process">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stickiness -->
        <mxCell id="stickiness" value="🔗 Adaptive Stickiness&#10;Mantém consistência&#10;na conversa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0aaff;fontColor=#000000;strokeColor=#c77dff;arcSize=10;dashed=1;" vertex="1" parent="pipeline">
          <mxGeometry x="750" y="320" width="180" height="70" as="geometry"/>
        </mxCell>

        <!-- Output -->
        <mxCell id="output" value="📤 Resposta para o Hóspede&#10;via WhatsApp / DDC" style="ellipse;whiteSpace=wrap;html=1;fillColor=#e94560;fontColor=#ffffff;strokeColor=#c23152;" vertex="1" parent="pipeline">
          <mxGeometry x="340" y="480" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- Arrow Response -> Output -->
        <mxCell id="arrow-resp-out" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#533483;strokeWidth=2;" edge="1" parent="pipeline" source="response-process" target="output">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DDC Log -->
        <mxCell id="ddc-log" value="📊 Log no DDC&#10;Histórico + Métricas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;fontColor=#ffffff;strokeColor=#0f3460;arcSize=10;" vertex="1" parent="pipeline">
          <mxGeometry x="620" y="480" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="arrow-out-ddc" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#e0aaff;strokeWidth=1;" edge="1" parent="pipeline" source="output" target="ddc-log">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Arrow Input -> Step1 -->
        <mxCell id="arrow-in-step1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#e94560;strokeWidth=2;" edge="1" parent="1" source="input" target="pipeline">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

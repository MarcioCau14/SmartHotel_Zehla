generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== ENUMS (from backup) =====
enum LeadStatus {
  PROSPECT
  QUALIFIED
  TRIAL_STARTED
  CONVERTED
  BLACKLISTED
}

enum Plan {
  LITE
  PRO
  MAX
}

// ===== USER & POST (from backup) =====
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id])
}

// ===== TENANT (Pousada/Hotel) =====
model Tenant {
  id             String    @id @default(cuid())
  name           String
  email          String?   @unique
  passwordHash   String?
  phone          String?
  phoneAlt       String?                // WhatsApp atendimento ao hóspede
  role           String    @default("owner") // owner | admin | staff
  plan           String    @default("trial") // trial | starter | pro | business
  status         String    @default("active") // active | suspended | churned
  trialStart     DateTime?
  trialEnd       DateTime?
  subscriptionAt DateTime?

  // From old Tenant
  domain         String?   @unique
  clerkOrgId     String?   @unique

  // Relations from new Tenant
  property       Property?
  apiConfigs     ApiConfig[]
  agentConfigs   AgentConfig[]
  auditLogs      AuditLog[]

  // Relations from old Tenant
  rooms          Room[]
  guests         Guest[]
  reservations   Reservation[]
  transactions   Transaction[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("tenants")
}

// ===== PROPERTY =====
model Property {
  id          String  @id @default(cuid())
  tenantId    String  @unique
  name        String
  document    String? // CNPJ/CPF — MOCK: "12.345.678/0001-90"
  street      String  @default("")
  number      String  @default("")
  neighborhood String @default("")
  city        String  @default("")
  state       String  @default("")
  zipCode     String  @default("")
  type        String  @default("pousada") // pousada | hotel | hostel | chalé | resort
  website     String?
  description String  @default("")
  services    String  @default("[]") // JSON array of service IDs
  paymentMethods String @default("[]") // JSON array of payment method IDs
  pixKey      String?
  pixKeyType  String  @default("cpf") // cpf | email | phone | random
  bankName    String?
  bankAgency  String?
  bankAccount String?
  bankAccountType String? // cc | cp
  bankCpf     String?

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rooms       Room[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("properties")
}

// ===== ROOM =====
model Room {
  id         String  @id @default(cuid())
  propertyId String?
  tenantId   String?
  name       String? // new Room has name
  number     String? // old Room has number
  type       String  @default("standard") // standard | luxo | suite | chale / STANDARD, DELUXE, SUITE
  capacity   Int     @default(2)
  price      Float?  @default(150)
  basePrice  Float?  // old basePrice
  status     String  @default("disponivel") // disponivel | ocupado | sujo | manutencao | reservado / AVAILABLE, OCCUPIED, MAINTENANCE

  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
  @@index([propertyId])
  @@map("rooms")
}

// ===== API CONFIG (AI Provider Keys) =====
model ApiConfig {
  id        String   @id @default(cuid())
  tenantId  String
  provider  String   // gemini | openai | groq | huggingface | anthropic | zai_sdk
  apiKey    String   @default("")    // Encrypted key storage placeholder
  apiSecret String   @default("")    // For providers with separate secrets
  model     String   @default("")    // Default model name
  baseUrl   String   @default("")    // Custom base URL (optional)
  isActive  Boolean  @default(false)
  usageLimit Int     @default(0)     // 0 = unlimited
  usageCurrent Int   @default(0)
  notes     String   @default("")

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, provider])
  @@map("api_configs")
}

// ===== AGENT CONFIG (Per-tenant agent customization) =====
model AgentConfig {
  id          String  @id @default(cuid())
  tenantId    String
  agentId     String  // agent-1 through agent-8
  agentName   String  // Recepcionista, Concierge, etc.
  systemPrompt String @default("")
  isActive    Boolean @default(true)
  temperature Float   @default(0.7)
  maxTokens   Int     @default(2048)
  customKnowledge String @default("[]")
  learnedPatterns Int  @default(0)
  confidenceScore Float @default(0)

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, agentId])
  @@map("agent_configs")
}

// ===== AUDIT LOG =====
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  action    String
  details   String   @default("{}") // JSON
  ipAddress String?
  userAgent String?

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// ===== LEADS (Prospecção Lessie AI + LIS) =====
model Lead {
  id              String   @id @default(cuid())
  empresa         String
  decisor         String   @default("")
  cargo           String   @default("")
  email           String   @unique
  whatsapp        String?  // Removed @unique to avoid constraints violations on empty/null values, made optional
  setor           String   @default("hospitalidade")
  porte           String   @default("pequeno") // pequeno | medio | grande
  status          String   @default("pending") // pending | verified | contacted | converted | lost
  hook            String   @default("") // Script de e-mail/WhatsApp personalizado
  socialFootprint String   @default("{}") // JSON
  targetId        String?

  // Old/Legacy fields
  name            String   @default("")
  phone           String?  // Removed @unique
  property        String?
  category        String?  @default("pousada")
  city            String?
  state           String?  @default("SC")
  region          String?
  googleRating    Float?
  score           Int?     @default(0)
  painPoints      String?
  source          String   @default("SECRETARIA_AI")
  latitude        Float?
  longitude       Float?
  scoreValid      Int      @default(0)
  localPraia      String?
  observacoes     String?

  // DB Mirror / LIS / ZEHLA FISH Extensions
  isCanary              Boolean   @default(false)
  estimatedValues       String?
  intentSignals         String?
  location              String?
  phoneSecondary        String?
  qualification         String?
  socialMedia           String    @default("{}")
  site                  String?
  validationScore       Float     @default(0)
  validationStatus      String    @default("pendente")
  conversionScore       Int       @default(0)
  funnelStage           String    @default("NEUTRAL")
  lastInteractionAt     DateTime?
  behavioralProfile     String?
  cluster               String    @default("COLD")
  previousCluster       String?
  lastSwipeAction       String?
  lastSwipeUsedId       String?
  tierConfidence        Float?
  tierSugerido          String?
  tierSugeridoEm        DateTime?
  roomsCount            Int       @default(0)
  instagramFollowers    Int       @default(0)
  googleReviewsCount    Int       @default(0)
  otaCommissionLost     Float     @default(0.0)
  hasWebsite            Boolean   @default(false)
  otaDependenceLevel    String    @default("MEDIUM")
  buyingBehavior        String?
  conversionProbability Float     @default(0.0)
  objectKeywords        String?
  recommendedPitch      String?
  leadTier              String    @default("COLD")
  metadata              String    @default("{}") // JSON com dados extras

  // Relations
  emailTrackings EmailTracking[]
  swipeUsages    SwipeUsage[]
  funnelEvents   FunnelEvent[]
  funnelScore    FunnelScore?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("leads")
}

// ===== EMAIL TRACKING =====
model EmailTracking {
  id         String   @id @default(cuid())
  leadId     String
  campaignId String?
  openedAt   DateTime @default(now())
  ip         String?
  userAgent  String?
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([campaignId])
  @@map("email_tracking")
}

// ===== TARGETS (Pousadas sob mira) =====
model Target {
  id        String  @id @default(cuid())
  name      String
  domain    String  @unique
  website   String?
  city      String  @default("")
  state     String  @default("")
  status    String  @default("active") // active | pending | inactive | prospected
  priority  Int     @default(5) // 1-10
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("targets")
}

// ===== AGENT LOG (Ações da IA) =====
model AgentLog {
  id          String   @id @default(cuid())
  action      String
  status      String   @default("success") // success | error | timeout
  createdAt   DateTime @default(now())

  // New ZEHLA fields
  agentId     String   @default("lessie")
  inputTokens Int      @default(0)
  outputTokens Int     @default(0)
  latencyMs   Int      @default(0)
  costUsd     Float    @default(0)
  errorMsg    String   @default("")
  metadata    String   @default("{}") // JSON

  // Old fields
  agentName   String?
  intent      String?
  confidence  Float?
  input       String?
  output      String?
  tokensUsed  Int      @default(0)
  cost        Float    @default(0)
  duration    Int      @default(0)

  @@index([agentName, createdAt])
  @@map("agent_logs")
}

// ===== SECURITY ALERT =====
model SecurityAlert {
  id          String   @id @default(cuid())
  severity    String   @default("medium") // low | medium | high | critical
  createdAt   DateTime @default(now())

  // New ZEHLA fields
  type        String?   // injection | rls_violation | rate_limit | suspicious
  description String   @default("")
  source      String   @default("")
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?

  // Old fields
  tenantId    String?
  alertType   String?
  metadata    String?

  @@index([tenantId, createdAt])
  @@index([severity, createdAt])
  @@map("security_alerts")
}

// ===== SWIPE TEMPLATE (Mensagens WhatsApp) =====
model SwipeTemplate {
  id                 String       @id @default(cuid())
  name               String       @default("") // ZEHLA expects name
  title              String       @default("") // old expects title
  content            String
  variables          String       @default("[]")
  category           String       @default("prospecção")
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // ZEHLA fields
  successRate        Float        @default(0)
  usageCount         Int          @default(0)

  // Old fields
  channel            String       @default("whatsapp")
  tone               String       @default("casual")
  tier               String       @default("universal")
  painType           String?
  tags               String       @default("[]")
  timesUsed          Int          @default(0)
  conversions        Int          @default(0)
  convRate           Float        @default(0)
  lastUsedAt         DateTime?
  isAiGenerated      Boolean      @default(false)
  provenByConversion Boolean      @default(false)
  createdBy          String?

  usages             SwipeUsage[]

  @@map("swipe_templates")
}

// ===== SWIPE USAGE =====
model SwipeUsage {
  id             String        @id @default(cuid())
  swipeId        String
  leadId         String
  wasUsed        Boolean
  converted      Boolean?
  agentId        String?
  responseTimeMs Int?
  feedback       String?
  createdAt      DateTime      @default(now())
  swipe          SwipeTemplate @relation(fields: [swipeId], references: [id], onDelete: Cascade)
  lead           Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([swipeId, leadId])
  @@index([swipeId])
  @@index([leadId])
  @@index([converted])
  @@index([createdAt])
  @@map("swipe_usages")
}

// ===== CAMPAIGN (Orquestração multicanal) =====
model Campaign {
  id              String        @id @default(cuid())
  name            String
  type            String        @default("whatsapp") // whatsapp | email | ads | multi
  status          String        @default("draft") // draft | active | paused | completed | cancelled
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // From new schema
  targetAudience  String        @default("all") // all | leads | verified | converted
  messageTemplate String        @default("")
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  totalDelivered  Int           @default(0)
  totalRead       Int           @default(0)
  totalReplied    Int           @default(0)
  metadata        String        @default("{}") // JSON

  // From old schema
  variant         String? // "financeira", "operacional", "ocupacao"
  totalSent       Int           @default(0)
  totalOpened     Int           @default(0)
  totalClicked    Int           @default(0)
  totalConverted  Int           @default(0)
  openRate        Float         @default(0)
  clickRate       Float         @default(0)
  conversionRate  Float         @default(0)

  // Relations
  events          FunnelEvent[]
  webhookLogs     WebhookLog[]

  @@map("campaigns")
}

// ===== TREND KEYWORD =====
model TrendKeyword {
  id                  String           @id @default(cuid())
  keyword             String           @unique
  category            String           @default("hotelaria")
  geo                 String?
  isActive            Boolean          @default(true)
  tier                String           @default("pro")
  checkFrequencyHours Int              @default(6)
  lastCheckedAt       DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  // ZEHLA fields
  source              String           @default("google_trends")
  score               Float            @default(0)
  trend               String           @default("stable")

  dataPoints          TrendDataPoint[]

  @@map("trend_keywords")
}

// ===== TREND DATA POINT =====
model TrendDataPoint {
  id            String       @id @default(cuid())
  keywordId     String
  date          DateTime
  source        String       @default("")
  createdAt     DateTime     @default(now())

  // New ZEHLA fields
  value         Float        @default(0)

  // Old fields
  interestScore Int          @default(0)
  interestDelta Float?
  volume        Int?
  geo           String?

  keyword       TrendKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([keywordId, date, source])
  @@index([date])
  @@index([keywordId])
  @@map("trend_data_points")
}

// ===== TREND SIGNAL =====
model TrendSignal {
  id             String    @id @default(cuid())
  type           String
  keyword        String
  category       String
  interestScore  Int
  deltaPercent   Float
  severity       String    @default("media")
  geo            String?
  dateDetected   DateTime
  previousScore  Int?
  agentsNotified String    @default("[]")
  actionTaken    Boolean   @default(false)
  actionDetails  String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([type])
  @@index([severity])
  @@index([dateDetected])
  @@index([category])
  @@map("trend_signals")
}

// ===== ADAPTIVE FUNNEL — Event-Driven State Machine =====
model FunnelEvent {
  id          String    @id @default(cuid())
  leadId      String
  campaignId  String?
  type        String // email_opened, email_clicked, whatsapp_replied, lp_visited, ray-x_requested, trial_started, converted
  painCluster String? // financeira, operacional, ocupacao
  score       Int       @default(0)
  metadata    String? // JSON: ip, userAgent, utm, etc
  createdAt   DateTime  @default(now())
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  @@index([leadId])
  @@index([campaignId])
  @@index([type])
  @@index([painCluster])
  @@index([createdAt])
  @@map("funnel_events")
}

model FunnelScore {
  id                String    @id @default(cuid())
  leadId            String    @unique
  totalScore        Int       @default(0)
  engagementScore   Int       @default(0)
  intentScore       Int       @default(0)
  fitScore          Int       @default(0)
  cluster           String    @default("COLD") // HOT, WARM, COLD
  painCluster       String? // financeira, operacional, ocupacao
  lastEventAt       DateTime?
  lastClusterChange DateTime?
  previousCluster   String?
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([cluster])
  @@index([painCluster])
  @@index([totalScore])
  @@map("funnel_scores")
}

model WebhookLog {
  id          String    @id @default(cuid())
  campaignId  String?
  source      String // resend, sendgrid, zapi, evolution, stripe, asaas
  eventType   String // opened, clicked, replied, delivered, bounced, paid, failed
  payload     String // JSON raw
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  retries     Int       @default(0)
  createdAt   DateTime  @default(now())
  campaign    Campaign? @relation(fields: [campaignId], references: [id])

  @@index([source])
  @@index([eventType])
  @@index([processed])
  @@index([createdAt])
  @@map("webhook_logs")
}

// ===== GUEST, RESERVATION & TRANSACTION (from backup) =====
model Guest {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  document  String? // CPF/Passaporte
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@index([tenantId])
  @@map("guests")
}

model Reservation {
  id         String   @id @default(cuid())
  tenantId   String
  guestId    String
  roomId     String
  checkIn    DateTime
  checkOut   DateTime
  status     String   @default("CONFIRMED") // PENDING, CONFIRMED, CHECKED_IN, CHECKED_OUT, CANCELLED
  totalPrice Float
  source     String   @default("DIRECT") // DIRECT, BOOKING, EXPEDIA
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  guest  Guest  @relation(fields: [guestId], references: [id])
  room   Room   @relation(fields: [roomId], references: [id])

  transactions Transaction[]

  @@index([tenantId])
  @@index([guestId])
  @@index([roomId])
  @@map("reservations")
}

model Transaction {
  id            String   @id @default(cuid())
  tenantId      String
  reservationId String?
  type          String // PAYMENT, REFUND, CHARGE
  amount        Float
  method        String // PIX, CREDIT_CARD, CASH
  status        String   @default("COMPLETED")
  createdAt     DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  @@index([tenantId])
  @@index([reservationId])
  @@map("transactions")
}

// ===== ZAOS ROUTER STATE =====
model RouterProvider {
  id          String   @id @default(cuid())
  provider    String   @unique // openrouter | anthropic | ollama | groq | gemini
  modelName   String
  tier        String   @default("3") // 1=budget, 2=mid, 3=premium
  alpha       Float    @default(1.0) // Thompson Sampling Beta posterior
  beta        Float    @default(1.0)
  circuitStatus String @default("closed") // closed | half_open | open
  lastFailureAt DateTime?
  failureCount Int    @default(0)
  successCount Int    @default(0)
  avgLatencyMs Int    @default(0)
  costPer1kInput Float @default(0)
  costPer1kOutput Float @default(0)
  isActive    Boolean  @default(true)
  supportsJson Boolean @default(false)
  supportsTools Boolean @default(false)
  maxContextTokens Int @default(8192)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("router_providers")
}

// ===== BUDGET GUARD STATE =====
model BudgetGuardState {
  id           String  @id @default(cuid())
  date         String  @unique // YYYY-MM-DD
  dailySpendUsd Float  @default(0)
  dailyBudgetUsd Float @default(50)
  monthlySpendUsd Float @default(0)
  monthlyBudgetUsd Float @default(1500)
  criticalLevel String @default("nominal") // nominal | warning | critical
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("budget_guard_state")
}

// ===== MESSAGE (WhatsApp history) =====
model Message {
  id         String   @id @default(cuid())
  propertyId String
  direction  String   // INBOUND | OUTBOUND
  content    String
  createdAt  DateTime @default(now())

  @@map("messages")
}

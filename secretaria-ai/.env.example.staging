# ==============================================================================  
# ZEHLA SmartHotel — Variáveis de Ambiente STAGING  
# ==============================================================================  
# Use este arquivo como referencia para configurar o ambiente de staging  
# na Vercel e Railway. Todos os valores sao MOCK.  
# ==============================================================================

# ===== DATABASE (Vercel Postgres ou Turso — Staging) =====  
DATABASE_URL="file:./db/staging.db"

# ===== NEXTAUTH (Staging) =====  
NEXTAUTH_URL="https://smart-hotel-zehla-staging.vercel.app"  
NEXTAUTH_SECRET="staging-secret-replace-with-openssl-rand-base64-32"

# ===== MERCADO PAGO (Mock — Staging) =====  
MP_ACCESS_TOKEN="TEST-staging-mock-token-no-real-payments"  
MP_WEBHOOK_URL="https://smart-hotel-zehla-staging.vercel.app/api/checkout/webhook"

# ===== WHATSAPP CLOUD API (Mock — Staging) =====  
WHATSAPP_VERIFY_TOKEN="zehla_staging_verify_token"  
# WHEN REAL (uncomment and fill):  
# WHATSAPP_PHONE_NUMBER_ID="staging_phone_number_id"  
# WHATSAPP_ACCESS_TOKEN="staging_access_token"  
# WHATSAPP_BUSINESS_ACCOUNT_ID="staging_business_id"

# ===== Z.AI SDK =====  
ZAI_API_KEY="staging-zai-sdk-key"

# ===== SOCKET.IO REALTIME (Railway Staging) =====  
NEXT_PUBLIC_SOCKET_URL="https://zehla-realtime-staging.up.railway.app"

# ===== GOOGLE OAUTH (Opcional — Staging) =====  
GOOGLE_CLIENT_ID=""  
GOOGLE_CLIENT_SECRET=""

# ==============================================================================  
# VARIÁVEIS DO RAILWAY (realtime-service)  
# ==============================================================================  
# Configure no dashboard do Railway:  
# PORT=3005  
# CORS_ORIGINS=https://smart-hotel-zehla-staging.vercel.app,https://smart-hotel-zehla.vercel.app

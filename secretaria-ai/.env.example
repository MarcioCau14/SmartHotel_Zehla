# ==============================================================================
# ZEHLA SmartHotel — Environment Variables
# ==============================================================================

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="file:./db/dev.db"

# ── NextAuth ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ── Mercado Pago ──────────────────────────────────────────────────────
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""

# ── WhatsApp Cloud API ────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# ── AI Providers (optional — for real AI calls) ──────────────────────
OPENAI_API_KEY=""
GROQ_API_KEY=""
# ANTHROPIC_API_KEY=""  # Removido — mais caro, sem integração
GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""
ZHIPU_API_KEY=""
MOONSHOT_API_KEY=""

# ── Upstash Redis (semantic cache distribuído) ──────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Batch API (desconto para chamadas em lote) ─────────────────────
BATCH_API_ENABLED="false"

# ── Monitoring ────────────────────────────────────────────────────────
MONITORING_SECRET=""

# ── App ───────────────────────────────────────────────────────────────
NODE_ENV="development"

# ==============================================================================
# ZEHLA SmartHotel — Environment Variables
# ==============================================================================
# Use este arquivo como referência. NUNCA commite secrets reais.
# ==============================================================================

# ===== DEVELOPMENT (SQLite — padrão local) =====
DATABASE_URL="file:./db/dev.db"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"
NODE_ENV="development"

# ===== MERCADO PAGO =====
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""

# ===== WHATSAPP CLOUD API =====
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# ===== AI PROVIDERS (Mock = empty or sk-mock...) =====
OPENAI_API_KEY=""
GROQ_API_KEY=""
GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""
ZHIPU_API_KEY=""
GLM_5_2_API_KEY=""
MOONSHOT_API_KEY=""
KIMI_K2_6_API_KEY=""
OPENROUTER_API_KEY=""

# ===== UPSTASH REDIS (semantic cache) =====
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ===== BATCH API =====
BATCH_API_ENABLED="false"

# ===== MONITORING =====
MONITORING_SECRET=""

# ===== SOCKET.IO REALTIME =====
# NEXT_PUBLIC_SOCKET_URL="http://localhost:3005"

# ===== GOOGLE OAUTH =====
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ==============================================================================
# STAGING — descomente e ajuste para deploy em staging
# ==============================================================================
# DATABASE_URL="postgresql://zehla_user:YOUR_PASSWORD@localhost:5432/zehla_staging"
# NEXTAUTH_URL="https://staging.smart-hotel-zehla.vercel.app"
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ==============================================================================
# PRODUCTION — descomente e ajuste para deploy em produção
# ==============================================================================
# DATABASE_URL="PROVIDE_REAL_DATABASE_URL"
# NEXTAUTH_URL="https://zehla.com.br"
# NEXTAUTH_SECRET="PROVIDE_REAL_NEXTAUTH_SECRET"
# MP_ACCESS_TOKEN="PROVIDE_REAL_MP_ACCESS_TOKEN"
# MP_WEBHOOK_URL="https://zehla.com.br/api/checkout/webhook"
# WHATSAPP_VERIFY_TOKEN="PROVIDE_REAL_VERIFY_TOKEN"
# WHATSAPP_PHONE_NUMBER_ID="PROVIDE_REAL_PHONE_NUMBER_ID"
# WHATSAPP_ACCESS_TOKEN="PROVIDE_REAL_ACCESS_TOKEN"
# WHATSAPP_BUSINESS_ACCOUNT_ID="PROVIDE_REAL_BUSINESS_ACCOUNT_ID"

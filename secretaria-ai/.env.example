# ==============================================================================
# ZEHLA SmartHotel — Environment Variables
# ==============================================================================

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="file:./db/dev.db"

# ── NextAuth ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ── Mercado Pago ──────────────────────────────────────────────────────
MP_ACCESS_TOKEN=""
MP_WEBHOOK_SECRET=""

# ── WhatsApp Cloud API ────────────────────────────────────────────────
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# ── AI Providers (optional — for real AI calls) ──────────────────────
OPENAI_API_KEY=""
GROQ_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# ── Monitoring ────────────────────────────────────────────────────────
MONITORING_SECRET=""

# ── App ───────────────────────────────────────────────────────────────
NODE_ENV="development"

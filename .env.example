# ═══════════════════════════════════════════════════════════════════
# SEU ZÉLLA — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git — it contains secrets.
# All secrets are REQUIRED in production (app will throw if missing).

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=file:./db/custom.db

# ── NextAuth (REQUIRED in production) ───────────────────────────────
NEXTAUTH_SECRET=           # Cryptographically random value (≥32 chars) — generate with: openssl rand -base64 32
NEXTAUTH_URL=https://your-domain.vercel.app

# ── Google OAuth (optional) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Encryption (REQUIRED in production) ─────────────────────────────
ENCRYPTION_SECRET=         # Cryptographically random value — generate with: openssl rand -base64 32
CACHE_SIGNING_SECRET=      # Cryptographically random value — generate with: openssl rand -base64 32

# ── ZCC Admin Panel (REQUIRED for ZCC access) ───────────────────────
ZCC_GODMODE_TOKEN=         # Cryptographically random value for admin panel access

# ── AI Providers (optional — app falls back to cheaper models) ─────
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# ── Meta WhatsApp Business API (REQUIRED for WhatsApp integration) ──
META_VERIFY_TOKEN=         # Your webhook verification token from Meta Developer Platform
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_WABA_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=  # Same as META_VERIFY_TOKEN (used in webhook handler)

# ── Calendar Sync (REQUIRED for iCal channel manager) ───────────────
CALENDAR_SYNC_SECRET=      # Cryptographically random value for sync endpoint auth

# ── Payment Gateways (optional) ────────────────────────────────────
MP_ACCESS_TOKEN=           # Mercado Pago access token
STRIPE_SECRET_KEY=         # Stripe secret key
STRIPE_WEBHOOK_SECRET=     # Stripe webhook signing secret

# ── Redis (REQUIRED in production — for rate limiting and message bundler) ──
# Without Redis, rate limiting fails CLOSED (deny-all) in production
# and message-bundler falls back to synchronous processing (blocks webhook).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── QStash (REQUIRED in production for WhatsApp message bundler) ──
# QStash defers message bundling by 3s without blocking the Vercel lambda.
# Without QStash, the webhook handler blocks for 3s per message (high latency).
# Create at: https://console.upstash.com/qstash
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app   # QStash callback target

# ── Internal Endpoint Protection (REQUIRED in production) ──
# Protects /api/internal/flush-buffer from unauthorized access.
# QStash will call this endpoint after the 3s bundle delay.
INTERNAL_ENDPOINT_TOKEN=           # Cryptographically random — generate with: openssl rand -base64 32

# ── Webhook Security Bypass (DEV ONLY — never set in production) ──
# In dev, allows you to test webhook without META_APP_SECRET configured.
# MUST be unset in production — if META_APP_SECRET is missing in prod, webhook fails CLOSED.
WEBHOOK_ALLOW_NO_SECRET=false

# ── Meta Cost Tracking (production tuning) ──
# When true, records Meta cost even when WhatsApp send is in MOCK mode (no real credentials).
# Default: false (recommended — don't inflate cost stats with mock sends).
META_COST_RECORD_MOCK=false

# ── LGPD Opt-Out Keywords (configurable per tenant language) ──
# Comma-separated. Default covers PT-BR + EN.
LGPD_OPT_OUT_KEYWORDS=SAIR,STOP,PARAR,CANCELAR,DESCADASTRAR,UNSUBSCRIBE,NAOQUERO,REMOVER,OPTOUT

# ── Meta Budget Limits per Plan (USD/month) ──
# Tunable per-plan WhatsApp cost ceilings. When tenant exceeds, AI is silenced.
META_BUDGET_GRATUITO_USD=3.40
META_BUDGET_LITE_USD=12.00
META_BUDGET_PRO_USD=34.00
META_BUDGET_MAX_USD=68.00
META_BUDGET_PARCEIRO_USD=34.00

# ── Dev-only Bypass Flags (NEVER set in production) ──
# BYPASS_MIDDLEWARE_AUTH=true bypasses NextAuth in dev (uses first tenant).
# BYPASS_TENANT_LOOKUP=true makes resolveTenantByPhone return first active tenant.
BYPASS_MIDDLEWARE_AUTH=false
BYPASS_TENANT_LOOKUP=false

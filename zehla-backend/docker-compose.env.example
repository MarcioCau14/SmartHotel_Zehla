# ============================================================
# ZEHLA Backend — Docker Compose environment (EXEMPLO)
# ============================================================
# Copie este arquivo para `docker-compose.env` e preencha com
# valores reais. NUNCA commite o docker-compose.env.
#
# Uso:
#   docker compose --env-file docker-compose.env up -d
# ============================================================

# --- PostgreSQL (banco principal) ---
POSTGRES_USER=zehla
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=zehla_db

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_KEY=change-me-evolution-api-key

# --- Evolution API — banco dedicado ---
EVOLUTION_DB_PASSWORD=change-me-evolution-db-password

# --- Grafana (perfil monitoring) ---
GRAFANA_PASSWORD=change-me-grafana-admin-password

# --- Headroom (proxy LLM) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
HEADROOM_DAILY_BUDGET=50.0

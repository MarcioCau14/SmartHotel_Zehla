## 6\. PROVISIONAMENTO AUTOMÁTICO DO GRAFANA

yamlCopy

*\# docker-compose.yml — ADIÇÃO (serviços monitoring)*  
  grafana:  
    image: grafana/grafana:10.4.0  
    container\_name: zehla-grafana  
    restart: unless-stopped  
    environment:  
      GF\_SECURITY\_ADMIN\_PASSWORD: ${GRAFANA\_PASSWORD}  
      GF\_INSTALL\_PLUGINS: grafana-clock-panel  
      GF\_SERVER\_ROOT\_URL: https://zehla.io/grafana  
      GF\_AUTH\_ANONYMOUS\_ENABLED: "false"  
      GF\_SECURITY\_ALLOW\_EMBEDDING: "false"  
      GF\_SECURITY\_COOKIE\_SECURE: "true"  
      GF\_SECURITY\_COOKIE\_SAMESITE: "strict"  
      GF\_DASHBOARDS\_DEFAULT\_HOME\_DASHBOARD\_PATH: /etc/grafana/provisioning/dashboards/guardian-dashboard.json  
    volumes:  
      \- grafana-data:/var/lib/grafana  
      \- ./grafana/provisioning:/etc/grafana/provisioning:ro  
      \- ./grafana/dashboards:/etc/grafana/provisioning/dashboards:ro  
    networks:  
      \- zehla-internal  
    ports:  
      \- "127.0.0.1:3001:3000"  
    profiles:

      \- monitoring

yamlCopy

*\# grafana/provisioning/datasources/prometheus.yml*  
apiVersion: 1

datasources:  
  \- name: Prometheus  
    type: prometheus  
    access: proxy  
    url: http://prometheus:9090  
    isDefault: true  
    editable: false  
    jsonData:  
      timeInterval: "10s"

      httpMethod: POST

yamlCopy

*\# grafana/provisioning/dashboards/dashboards.yml*  
apiVersion: 1

providers:  
  \- name: 'ZEHLA Security'  
    orgId: 1  
    folder: 'ZCC'  
    type: file  
    disableDeletion: false  
    updateIntervalSeconds: 10  
    allowUiUpdates: true  
    options:  
      path: /etc/grafana/provisioning/dashboards

      foldersFromFilesStructure: false


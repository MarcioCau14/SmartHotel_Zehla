{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "temp_api",
    "scratch",
    "BLUEPRINTS",
    "INTELLIGENCE",
    "packages",
    "automation",
    "tests/xtress",
    "prisma/seed",
    "scripts",
    "prisma.config.ts",
    "prisma/seed-trends.ts",
    "next.config.ts",
    "src/proxy.ts",
    "INFRA",
    "src/infrastructure/persistence/**/*InMemoryRepository.ts",
    "src/infrastructure/persistence/**/InMemory*.ts",
    "**/__tests__/**",
    "src/lib/delivery/load-test.ts",
    "src/lib/swipe/seed-swipes.ts",
    "src/lib/swipe/swipe-generator.ts",
    "src/lib/testing/**"
  ]
}

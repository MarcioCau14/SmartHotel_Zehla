// ===== MISSING MODELS (adicionados pelo ZehlaTestAgent) =====

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiConfigs ApiConfig[]

  @@map("tenants")
}

model ApiConfig {
  id        String   @id @default(cuid())
  provider  String
  model     String   @default("default")
  isActive  Boolean  @default(true)
  hasKey    Boolean  @default(false)
  usageCurrent Int   @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("api_configs")
}

model CognitiveTerminalLog {
  id         String   @id @default(cuid())
  level      String   @default("info")
  source     String
  message    String   @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())
  propertyId String

  @@index([propertyId, createdAt])
  @@map("cognitive_terminal_logs")
}

model BrainSimulationScenario {
  id        String   @id @default(cuid())
  tenantId  String
  title     String
  context   String   @db.Text
  status    String   @default("pending")
  rounds    Int      @default(3)
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  roundsRel SimulationRound[]
  agents    SimulationAgent[]

  @@index([tenantId])
  @@map("brain_simulation_scenarios")
}

model SimulationRound {
  id        String   @id @default(cuid())
  round     Int
  input     String   @db.Text
  output    String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  scenarioId String
  scenario   BrainSimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId, round])
  @@map("simulation_rounds")
}

model SimulationAgent {
  id         String   @id @default(cuid())
  role       String
  name       String
  config     Json?
  status     String   @default("idle")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  scenarioId String
  scenario   BrainSimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@map("simulation_agents")
}

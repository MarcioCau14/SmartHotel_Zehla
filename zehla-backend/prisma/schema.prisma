  updatedAt           DateTime
  createdAt           DateTime              @default(now())
  properties          Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  credit_transactions credit_transactions[]

  @@index([propertyId])
}

model credit_transactions {
  id              String          @id
  accountId       String
  type            String
  amount          Float
  description     String
  referenceId     String?
  metadata        Json?
  createdAt       DateTime        @default(now())
  credit_accounts credit_accounts @relation(fields: [accountId], references: [id], onDelete: Cascade)


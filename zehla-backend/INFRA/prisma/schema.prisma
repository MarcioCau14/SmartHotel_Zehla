// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          Role      @default(CLIENT)
  phone         String?
  cpf           String?
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  permissions   String[]  @default([]) // Para controle granular de acesso (Equipe ZCC)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  properties    Property[]
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Property {
  id                 String   @id @default(cuid())
  registrationNumber String?  @unique // Format: 0001/PRO/SC
  name               String
  slug        String   @unique
  description String?  @db.Text
  address     String
  city        String   @default("Imbituba")
  state       String   @default("SC")
  zipCode     String?
  latitude    Float?
  longitude   Float?
  capacity    Int      @default(10)
  status      PropertyStatus @default(ACTIVE)
  plan        Plan     @default(LITE)
  trialEndsAt DateTime?
  isTrial     Boolean  @default(true)
  phone       String?
  whatsapp    String?
  email       String?
  website     String?
  pixKey      String?
  pixKeyType  PixKeyType?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isCanary    Boolean  @default(false)
  whatsappChannelType WhatsappChannelType @default(GUESTS_ONLY)
  supplierContact     String?

  // FNRH & Cadastur (Modernização 2026)
  cadastur          String?   @unique
  cadasturStatus    String?   @default("VALID") // VALID, EXPIRED, PENDING
  cadasturExpiry    DateTime?
  fnrhEnabled       Boolean   @default(false)
  fnrhManagerCpf    String?
  checkInWindow     Int       @default(24) // Horas (padrão 24h)
  cleaningWindow    Int       @default(3)  // Horas (padrão 3h para higienização)

  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rooms       Room[]
  reservations Reservation[]
  services    Service[]
  payments    Payment[]
  agentLogs   AgentLog[]
  messages    Message[]
  pricingRules PricingRule[]
  invoices    Invoice[]
  leads       Lead[] @relation("PropertyLeads")
  telemetries BusinessTelemetry[]
  workflows   Workflow[]

  // ZEHLA DNA & Payments
  toneProfile     ToneProfile?
  discountKeys    DiscountKey[]
  operationalPains OperationalPain[]
  stripeConfig    StripeConfig?

  // ZEHLA Voice
  voicePrints     VoicePrint[]
  voiceTokensUsed Int @default(0)
  voiceTokensLimit Int @default(100000)

  @@map("properties")
}

model VoicePrint {
  id              String   @id @default(cuid())
  propertyId      String
  name            String   // Ex: "Voz do Marcio", "Voz da Recepcionista"
  modelType       String   @default("GPT_SOVITS") // GPT_SOVITS ou F5_TTS
  status          String   @default("TRAINING") // TRAINING, ACTIVE, INACTIVE, FAILED
  referenceAudio  String?  // URL do bucket do audio
  similarityScore Float?   // 0.0 - 1.0 (Voice Fingerprinting)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("voice_prints")
}

model ToneProfile {
  id                    String   @id @default(cuid())
  propertyId            String   @unique
  property              Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  // Pilar 1: Termômetro de Tom
  tonePosition          Int      @default(3) // 1-5
  toneProactivity       String   @default("HYBRID") // PROACTIVE, REACTIVE, HYBRID
  toneEmojiLevel        String   @default("MODERATE") // GENEROUS, MODERATE, MINIMAL
  toneFormality         String   @default("ADAPTIVE") // INFORMAL, FORMAL, ADAPTIVE
  toneStyle             String   @default("CONSULTATIVE") // IMMEDIATE, CONTEXTUALIZED, CONSULTATIVE
  toneGrammar           String   @default("NORMAL") // INFORMAL, NORMAL, CAREFUL
  toneHumor             String   @default("FRIENDLY") // PLAYFUL, FRIENDLY, PROFESSIONAL
  
  // Amostras de Voz (Cenários)
  voiceSample1          String?  @db.Text // Primeiro contato
  voiceSample2          String?  @db.Text // Pedido de desconto
  voiceSample3          String?  @db.Text // Reclamação
  
  generatedSystemPrompt String?  @db.Text
  
  updatedAt             DateTime @updatedAt
  @@map("tone_profiles")
}

model DiscountKey {
  id                String   @id @default(cuid())
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  // Pilar 2: Chaves de Desconto
  type              String   // PAYMENT, SEASON, STAY, GROUP, RETURN, COMPETITOR
  maxPercent        Float    // ex: 0.10
  triggerCondition  String?  @db.Text
  isActive          Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("discount_keys")
}

model OperationalPain {
  id                String   @id @default(cuid())
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  // Pilar 3: Dores de Operação (Insights)
  questionId        Int
  score             Int      // 1-5 (Likert)
  priority          Boolean  @default(false)
  
  createdAt         DateTime @default(now())
  @@map("operational_pains")
}

model StripeConfig {
  id                String   @id @default(cuid())
  propertyId        String   @unique
  property          Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  stripeAccountId   String?  // ID da conta conectada
  chargesEnabled    Boolean  @default(false)
  payoutsEnabled    Boolean  @default(false)
  
  // Regras de Checkout
  allowInstallments Boolean  @default(true)
  maxInstallments   Int      @default(12)
  interestFreeLimit Int      @default(3)
  
  updatedAt         DateTime @updatedAt
  @@map("stripe_configs")
}

model Room {
  id          String     @id @default(cuid())
  number      String
  name        String?
  type        RoomType   @default(STANDARD)
  pricingType PricingType @default(PER_ROOM)
  capacity    Int        @default(2)
  basePrice   Float      @default(150.00)
  description String?    @db.Text
  amenities   String[]   @default([])
  status      RoomStatus @default(AVAILABLE)
  images      String[]   @default([])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  isCanary    Boolean    @default(false)

  propertyId  String
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  reservations Reservation[]

  @@unique([propertyId, number])
  @@map("rooms")
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float?
  isIncluded  Boolean  @default(false)
  icon        String?
  createdAt   DateTime @default(now())

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("services")
}

model Reservation {
  id            String            @id @default(cuid())
  code          String            @unique
  guestName     String
  guestEmail    String?
  guestPhone    String
  guestCpf      String?
  guestCount    Int               @default(1)
  checkIn       DateTime
  checkOut      DateTime
  nights        Int
  roomPrice     Float
  totalAmount   Float
  discount      Float             @default(0)
  paidAmount    Float             @default(0)
  status        ReservationStatus @default(CONFIRMED)
  checkInStatus CheckInStatus     @default(PENDING)
  source        String            @default("WHATSAPP")
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  isCanary      Boolean           @default(false)

  // Campos FNRH (Modernização)
  guestNationality  String?   @default("Brasileira")
  guestBirthDate    String?   // Formato YYYY-MM-DD
  guestGender       String?   // M, F, O
  guestAddress      String?
  guestDistrict     String?
  guestZipCode      String?
  guestCity         String?
  guestState        String?
  travelMotive      String?   // LAZER, NEGOCIOS, SAUDE, RELIGIAO, OUTROS
  transportMethod   String?   // AVIAO, CARRO, ONIBUS, NAVIO, OUTROS
  nextDestination   String?   
  fnrhSubmittedAt   DateTime?
  preferencesSnapshot Json?   @db.JsonB // ZDR: ZEHLA Data Redundancy para Flow Builder (SDE)

  roomId        String
  room          Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payment       Payment?

  @@map("reservations")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  method        PaymentMethod @default(PIX)
  status        PaymentStatus @default(PENDING)
  pixQrCode     String?       @db.Text
  pixCode       String?       @db.Text
  pixExpiration DateTime?
  externalId    String?
  paidAt        DateTime?
  refundedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  reservationId String        @unique
  reservation   Reservation   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  propertyId    String
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model PricingRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  roomType    RoomType?
  startDate   DateTime
  endDate     DateTime
  multiplier  Float    @default(1.0)
  fixedAmount Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("pricing_rules")
}

model AgentLog {
  id          String   @id @default(cuid())
  agentName   String
  action      String
  intent      String?
  confidence  Float?
  input       String?  @db.Text
  output      String?  @db.Text
  tokensUsed  Int      @default(0)
  cost        Float    @default(0)
  duration    Int      @default(0)
  status      String   @default("SUCCESS")
  createdAt   DateTime @default(now())

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, agentName, createdAt])
  @@map("agent_logs")
}

model Message {
  id          String   @id @default(cuid())
  phone       String
  name        String?
  content     String   @db.Text
  direction   String
  type        String   @default("TEXT")
  status      String   @default("SENT")
  agentHandled String?
  createdAt   DateTime @default(now())

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, phone, createdAt])
  @@map("messages")
}

model SystemLog {
  id          String   @id @default(cuid())
  level       String
  component   String
  message     String   @db.Text
  metadata    String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([level, component, createdAt])
  @@map("system_logs")
}

model ZeladorAction {
  id          String   @id @default(cuid())
  problem     String
  severity    String
  action      String
  target      String?
  result      String   @default("PENDING")
  duration    Int?
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@map("zelador_actions")
}

model SecurityAlert {
  id          String   @id @default(cuid())
  tenantId    String
  alertType   String   // CANARY_TOUCHED, HMAC_FAIL, etc.
  severity    String   // LOW, MEDIUM, HIGH, CRITICAL
  metadata    String?  @db.Text
  createdAt   DateTime @default(now())
  
  @@index([tenantId, createdAt])
  @@index([severity, createdAt])
  @@map("security_alerts")
}

model PixTransaction {
  id          String   @id @default(cuid())
  endToEndId  String   @unique
  amount      Float
  status      String
  metadata    String?  @db.Text
  createdAt   DateTime @default(now())

  @@map("pix_transactions")
}

model FinancialAudit {
  id            String   @id @default(cuid())
  tenantId      String
  action        String   // e.g., 'PAYMENT_RECEIVED', 'REFUND_ISSUED'
  amount        Float
  currency      String   @default("BRL")
  source        String   // e.g., 'PIX_WEBHOOK', 'STRIPE_EVENT'
  externalId    String?  // ID do gateway
  metadata      String?  @db.Text
  hash          String   // Hash chain para garantir imutabilidade
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@map("financial_audit")
}

enum Role {
  CLIENT
  ADMIN
  SUPER_ADMIN
  TEAM
}

enum PropertyStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL_EXPIRED
}

enum Plan {
  LITE
  PRO
  MAX
  BETA_TESTER
  EARLY_ADOPTER
}

enum WhatsappChannelType {
  GUESTS_ONLY
  GUESTS_AND_SUPPLIERS
}

enum PixKeyType {
  CPF
  CNPJ
  EMAIL
  PHONE
  RANDOM
}

enum RoomType {
  STANDARD
  DELUXE
  SUITE
  MASTER
  FAMILY
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
  BLOCKED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum CheckInStatus {
  PENDING
  READY
  DONE
  DELAYED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum LeadEventType {
  EMAIL_OPEN
  LINK_CLICK
  LANDING_VISIT
  WHATSAPP_OPEN
  WHATSAPP_REPLY
  WHATSAPP_SENT
  WHATSAPP_DELIVERED
  WHATSAPP_BLOCKED
  WHATSAPP_OPTED_OUT
  WHATSAPP_LINK_CLICKED
  AD_VIEW
  TRIAL_STARTED
  PAYMENT_MADE
  CONVERSION
}

model TrialBlacklist {
  id        String   @id @default(cuid())
  value     String   @unique // Email ou Telefone (WhatsApp)
  type      String   // 'EMAIL' ou 'PHONE'
  reason    String?
  createdAt DateTime @default(now())

  @@map("trial_blacklist")
}

model Lead {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phone         String?
  whatsapp      String?  @unique
  property      String?
  category      String?  @default("pousada")
  city          String?
  state         String?  @default("SC")
  region        String?  // Sul, Sudeste, Norte, Nordeste, Centro-Oeste
  
  // Geospatial Data
  latitude      Float?
  longitude     Float?
  
  googleRating  Float?
  
  // Protocolo de Extração: Secretaria-IA (18 Campos)
  roomsCount        Int?      @default(0)
  location          String?   // Local / Praia
  estimatedValues   String?   // Valores Estimados
  qualification     String?   @db.Text
  validationStatus  String?   // Validação
  buyingBehavior    String?   @db.Text // Comportamento de Compra
  intentSignals     String?   @db.Text // Sinais de Intenção
  socialMedia       String?   // Redes Sociais
  site              String?   // Site
  phoneSecondary    String?   // Telefone
  validationScore   Int?      @default(0) // Score Valid.
  
  // Cognitive Intelligence (ZEHLA Brain)
  score             Int?      @default(0) // Score Qual.
  conversionScore   Int?      @default(0) // 0-100 (Engajamento Real)
  funnelStage       String?   @default("NEUTRAL") // NEUTRAL, AWARE, INTEREST, TRIAL, CONVERTED
  behavioralProfile String?   // conservador, curioso, urgente, resistente
  cluster           String?   @default("COLD") // HOT, WARM, COLD
  previousCluster   String?   // Cluster anterior (para detecção de transição)
  lastInteractionAt DateTime?
  
  // Swipe Intelligence (Etapa 4.5)
  tierSugerido         String?   // lite, pro, max
  tierConfidence       Float?    // 0.0 - 1.0
  tierSugeridoEm       DateTime?
  lastSwipeUsedId      String?   // ultimo swipe sugerido/usado
  lastSwipeAction      String?   // usado, ignorado, modificado
  
  painPoints    String?  @db.Text
  source        String   @default("SECRETARIA_AI")
  status        LeadStatus @default(PROSPECT)
  metadata      String?  @db.Text // Dados brutos da planilha
  isCanary      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  propertyId    String?
  propertyRef   Property? @relation("PropertyLeads", fields: [propertyId], references: [id])
  
  emailTracking EmailTracking[]
  events        LeadEvent[]
  actionLogs    ActionLog[]
  swipeUsages   SwipeUsage[]

  @@map("leads")
}

model LeadEvent {
  id          String        @id @default(cuid())
  leadId      String
  type        LeadEventType
  scoreImpact Int           @default(0) // Pontos gerados por este evento
  dedupHash   String?       // SHA-256 para deduplicação temporal
  sessionId   String?       // Sessão do usuário
  fingerprint String?       // Fingerprint do dispositivo
  eventSource String        @default("api") // api, webhook, pixel, client
  status      String        @default("received") // received, validated, enriched, classified, acted
  metadata    Json?         // Ex: campaignId, browser info, click URL
  timestamp   DateTime      @default(now())
  
  lead        Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, type, timestamp])
  @@index([dedupHash])
  @@index([status])
  @@map("lead_events")
}

model ActionLog {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actionType  String   // nurture_email, sales_alert, bid_adjustment, whatsapp_notify
  trigger     String   // cluster_change, score_threshold, manual, scheduled
  cluster     String   // Cluster do lead no momento da ação
  payload     Json?    // Dados detalhados da ação executada
  status      String   @default("pending") // pending, sent, failed, retried
  error       String?
  retriedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([leadId])
  @@index([actionType])
  @@index([status])
  @@map("action_logs")
}

model WebhookLog {
  id          String   @id @default(cuid())
  source      String   // n8n, make, segment, mparticle, z-api
  eventType   String?
  payload     Json
  headers     Json?    // Request headers for verification
  status      String   @default("received") // received, processed, failed
  response    String?
  createdAt   DateTime @default(now())

  @@index([source])
  @@index([status])
  @@map("webhook_logs")
}

model EmailTracking {
  id          String   @id @default(cuid())
  leadId      String
  campaignId  String?
  openedAt    DateTime @default(now())
  ip          String?
  userAgent   String?
  
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([campaignId])
  @@map("email_tracking")
}

enum LeadStatus {
  PROSPECT
  QUALIFIED
  TRIAL_STARTED
  CONVERTED
  BLACKLISTED
}

model SecurityIncident {
  id          String    @id @default(cuid())
  tenantId    String
  type        String
  reason      String
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@map("security_incidents")
}

model Invoice {
  id          String   @id @default(cuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  status      InvoiceStatus @default(PENDING)
  totalAmount Float
  items       InvoiceItem[]
  createdAt   DateTime @default(now())

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  type        InvoiceItemType
  description String
  amount      Float
  metadata    String?  @db.Text // reservationId, timestamp, etc
  createdAt   DateTime @default(now())

  @@map("invoice_items")
}

enum PricingType {
  PER_ROOM
  PER_PERSON
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
}

enum InvoiceItemType {
  PACKAGE_FEE
  BOOKING_COMMISSION
}

model BusinessTelemetry {
  id                  String   @id @default(cuid())
  propertyId          String
  date                DateTime // Agregado por hora ou dia
  
  leadConversionRate  Float    @default(0) // Leads -> Trial/Venda
  avgResponseTimeMs   Float    @default(0) // Média de resposta no WhatsApp
  bookingSuccessRate  Float    @default(0) // Links de reserva -> Reservas confirmadas
  agentCloseRate      Float    @default(0) // Eficácia do fechamento (intent CLOSING)
  abandonmentCount    Int      @default(0) // Sessões abandonadas
  
  property            Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@unique([propertyId, date])
  @@map("business_telemetry")
}

model BlastCampaign {
  id            String   @id @default(cuid())
  name          String                        // Nome da campanha
  status        String   @default("draft")
  // draft, scheduled, active, paused,
  // completed, failed

  // Content
  messageTemplate String                     // Template com {variaveis}
  mediaUrl      String?                      // Imagem/video/documento
  mediaType     String?                      // image, video, document, audio

  // Targeting
  contactGroup  String                       // Grupo de contatos
  totalContacts Int      @default(0)
  sentCount     Int      @default(0)
  deliveredCount Int     @default(0)
  readCount     Int      @default(0)
  repliedCount  Int      @default(0)
  failedCount   Int      @default(0)
  optedOutCount Int     @default(0)

  // Scheduling
  scheduledAt   DateTime?                    // Agendamento
  startedAt     DateTime?
  completedAt   DateTime?

  // Throttling config (JSON)
  config        Json?     // delayMsg, batchSize,
  // batchPause, jitter, hours, days

  // Instance pool
  instanceIds   String[]                     // IDs das instancias Evolution API

  // Relations
  messages      BlastMessage[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("blast_campaigns")
}

model BlastMessage {
  id            String   @id @default(cuid())
  campaignId    String
  campaign      BlastCampaign @relation(fields: [campaignId], references: [id])

  contactPhone  String                       // 5511999999999
  contactName   String?
  leadId        String?                      // Link com Lead do LIS

  // Status pipeline
  status        String   @default("pending")
  // pending, queued, sent, delivered,
  // read, replied, failed, opted_out

  // Personalized content
  renderedMessage String?                    // Template preenchido
  mediaUrl      String?

  // Instance used
  instanceId    String?

  // Tracking
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  repliedAt     DateTime?
  failedReason  String?
  optedOutAt    DateTime?

  // ZEHLA Brain event tracking
  brainEventId  String?                      // Link com LeadEvent

  createdAt     DateTime @default(now())

  @@index([campaignId])
  @@index([status])
  @@index([contactPhone])
  @@map("blast_messages")
}

model BlastInstance {
  id            String   @id @default(cuid())
  name          String                       // Nome amigavel
  phone         String                       // 5511999999999
  evolutionUrl  String                       // URL do Evolution API
  apiKey        String                       // API key da instancia
  instanceName  String                       // Nome no Evolution API
  status        String   @default("disconnected")
  // connected, disconnected, banned, paused

  // Warmup tracking
  createdAt     DateTime @default(now())     // Data de criacao
  warmupStage   Int      @default(0)         // Dias de aquecimento
  dailyLimit    Int      @default(20)        // Limite diario atual
  hourlyLimit   Int      @default(10)        // Limite por hora
  sentToday     Int      @default(0)         // Enviadas hoje
  sentThisHour  Int      @default(0)         // Enviadas esta hora

  // Health
  lastError     String?
  lastErrorAt   DateTime?
  bannedAt      DateTime?
  qualityScore  Float?                       // 0-1

  @@unique([phone])
  @@map("blast_instances")
}

model BlastContact {
  id            String   @id @default(cuid())
  phone         String                       // 5511999999999
  name          String?
  email         String?
  pousadaName   String?
  city          String?
  state         String?
  group         String   @default("geral")

  // Consent
  optIn         Boolean  @default(false)
  optInSource   String?                      // csv_import, form, manual
  optInDate     DateTime?
  optedOut      Boolean  @default(false)
  optedOutAt    DateTime?
  optedOutReason String?

  // Link with LIS
  leadId        String?                      // Link com Lead do LIS

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([phone])
  @@index([group])
  @@index([optedOut])
  @@map("blast_contacts")
}


model ExclusiveWaitlist {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  phone       String?
  pousadaName String?
  roomCount   Int?     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("exclusive_waitlist")
}

// ----------------------------------------------------------------------------
// ZEHLA FLOW BUILDER & ZAOS (ZEHLA Agent Operating System)
// ----------------------------------------------------------------------------

model Workflow {
  id          String   @id @default(cuid())
  propertyId  String   // Obrigatório para RLS
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(false)
  version     Int      @default(1)
  
  nodes       WorkflowNode[]
  edges       WorkflowEdge[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  
  @@index([propertyId])
  @@map("workflows")
}

model WorkflowNode {
  id          String   @id @default(cuid())
  workflowId  String
  propertyId  String   // Obrigatório para RLS
  type        String   // message, gpt, condition, blast_campaign, etc
  positionX   Float
  positionY   Float
  data        Json     // Dados específicos do nó (prompt, chaves, template)
  
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  @@index([workflowId])
  @@index([propertyId])
  @@map("workflow_nodes")
}

model WorkflowEdge {
  id          String   @id @default(cuid())
  workflowId  String
  propertyId  String   // Obrigatório para RLS
  sourceNode  String
  targetNode  String
  sourceHandle String?
  targetHandle String?
  condition   Json?    // Condição lógica para transição
  
  workflow    Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  @@index([workflowId])
  @@index([propertyId])
  @@map("workflow_edges")
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  nodes       Json     // Nodes schema
  edges       Json     // Edges schema
  category    String   // RECEPTION, BOOKING, POST_CHECKOUT, etc
  isGlobal    Boolean  @default(true) // Se for template público
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("workflow_templates")
}
model SwipeTemplate {
  id                  String   @id @default(cuid())
  title               String
  content             String                // Texto do template com {{VARS}}
  variables           String   @default("[]") // JSON array: ["NOME","POUSADA","PRECO"]
  channel             String   @default("whatsapp") // whatsapp, email, instagram, voice, chat_widget
  category            String   @default("saudacao")
  tone                String   @default("casual")
  tier                String   @default("universal") // lite, pro, max, universal
  painType            String?  // financeiro, operacional, ocupacao
  tags                String[] @default([]) 
  timesUsed           Int      @default(0)
  conversions         Int      @default(0)
  convRate            Float    @default(0)
  lastUsedAt          DateTime?
  isAiGenerated       Boolean  @default(false)
  provenByConversion Boolean  @default(false)
  createdBy           String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  usages              SwipeUsage[]

  @@index([channel])
  @@index([category])
  @@index([tier])
  @@index([painType])
  @@index([convRate])
  @@index([isActive])
  @@map("swipe_templates")
}

model SwipeUsage {
  id              String   @id @default(cuid())
  swipeId         String
  leadId          String
  wasUsed         Boolean
  converted       Boolean? // null = pendente
  agentId         String?  // null = envio automatico pela IA
  responseTimeMs  Int?     // tempo entre sugestao e envio
  feedback        String?  // positivo, neutro, negativo
  createdAt       DateTime @default(now())

  swipe           SwipeTemplate @relation(fields: [swipeId], references: [id], onDelete: Cascade)
  lead            Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([swipeId, leadId]) // nao rastrear uso duplicado
  @@index([swipeId])
  @@index([leadId])
  @@index([converted])
  @@index([createdAt])
  @@map("swipe_usages")
}

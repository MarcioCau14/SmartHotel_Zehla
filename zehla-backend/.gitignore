# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# reports
.fsa-reports/

# FSA backups
.fsa-backups/

# encrypted env
*.env.encrypted

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.encrypted

# docker compose env (credenciais reais — nunca commitar)
docker-compose.env
!docker-compose.env.example

# security
.master-key

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# akashico
services/akashico/__pycache__/
services/akashico/data/

/src/generated/prisma

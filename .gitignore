# ==========================================
# ANTIGRAVITY & GIT IDE SPEED OPTIMIZATION
# ==========================================
# Ignore everything at the root level of the home folder
/*

# Allow the .github directory (tracked workflows)
!/.github/
!/.github/**

# Allow the Projetos directory (tracked project code)
!/Projetos/
!/Projetos/**

# Allow the old zehla-backend path if needed (marked as deleted)
!/zehla-backend/
!/zehla-backend/**

# Allow the secretaria-ai project (SmartHotel_Zehla)
!/secretaria-ai/
!/secretaria-ai/**

# Allow the unified dependency versions reference
!/VERSIONS.md

# Allow the opencode ECC plugin configuration
!/.opencode/
!/.opencode/**
__pycache__/
.vercel
.env*
!.env.example
!.env.example.staging

# Docker compose env com credenciais reais — nunca commitar
docker-compose.env
!docker-compose.env.example

# Temporarios
*.bak
*.log
tsc-errors.log
build.log
**/test-results/
**/graphify-out/
**/scratch/
